<div class="container mx-auto mt-6 px-4">
    {{!-- the icon makes the variant actually paint the error accent (the
          variant only tints the icon container, which needs an icon) --}}
    {{#> ui/stat-card variant="error" icon="icon-[tabler--alert-triangle]"}}
    <h1 class="text-xl font-semibold mb-4">{{_ "Something went wrong" templateLocale}}</h1>
    <p class="mb-2">{{message}}</p>
    <p class="text-base-content/60 text-sm mb-4">{{_ "Error code: %s" templateLocale statusCode}}</p>
    {{#if details}}
    {{#each details}}
    <div class="alert alert-soft alert-error mb-2">{{this}}</div>
    {{/each}}
    {{/if}}
    <div class="mt-4 flex gap-2">
        <a href="javascript:history.back()" class="btn btn-neutral btn-soft btn-sm">
            <span class="icon-[tabler--arrow-left] size-4"></span> {{_ "Go back" templateLocale}}
        </a>
        <a href="/admin" class="btn btn-primary btn-sm">
            <span class="icon-[tabler--home] size-4"></span> {{_ "Dashboard" templateLocale}}
        </a>
    </div>
    {{/ui/stat-card}}
</div>
