{{!-- Generic error page: rendered for any non-API error response (missing
pages, blocked access, failed form submissions without a friendlier page). --}}

<div class="ee-error-card">
    <div class="ee-error-card-content">
        <h1>{{_ "Something went wrong" templateLocale}}</h1>
        <p>{{message}}</p>
        <p class="ee-muted">{{_ "Error code: %s" templateLocale statusCode}}</p>
        {{#if details}}
        <div class="ee-error-details">
            {{#each details}}
            <div class="ee-alert ee-alert-error">{{this}}</div>
            {{/each}}
        </div>
        {{/if}}
        <div class="ee-form-actions">
            <a href="javascript:history.back()" class="ee-btn ee-btn-neutral ee-btn-soft ee-btn-sm">
                <span class="ee-icon ee-icon-arrow-left"></span> {{_ "Go back" templateLocale}}
            </a>
            <a href="/admin" class="ee-btn ee-btn-primary ee-btn-sm">
                <span class="ee-icon ee-icon-home"></span> {{_ "Dashboard" templateLocale}}
            </a>
        </div>
    </div>
    <div class="ee-error-card-icon">
        <span class="ee-icon ee-icon-alert-triangle ee-icon-lg"></span>
    </div>
</div>
