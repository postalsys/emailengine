{{> tokens_header}}

{{#if account}}
{{> ui/breadcrumb parentHref="/admin/tokens" parentLabel="Access tokens" midHref=accountTokensLink midLabel=account.name current="New" class="mt-6 mb-6"}}
{{else}}
{{> ui/breadcrumb parentHref="/admin/tokens" parentLabel="Access tokens" current="New" class="mt-6 mb-6"}}
{{/if}}

<form method="post" id="token-form" action="/admin/tokens/new">
    <input type="hidden" name="crumb" value="{{crumb}}" />
    <input type="hidden" id="account" name="account" value="{{values.account}}" />

    <div class="card bg-base-100 shadow-md mb-6">

        <div class="card-body space-y-4">

            {{> ui/form-field id="description" label="Description" value=values.description error=errors.description required=true hint="This description is shown when listing active tokens."}}

            <div>
                <h6 class="mb-2 font-bold">Allowed scopes</h6>

                <ul class="divide-y divide-base-content/10 rounded-box border border-base-content/10">
                    <li class="flex items-center gap-2 p-[1rem]">
                        <input type="checkbox" class="checkbox checkbox-sm or-else-all scope-entry"
                            data-target="scope-list" id="scopesAll" data-scope="*" name="scopesAll" {{#if
                            values.scopesAll}}checked{{/if}} />
                        <label class="label-text grow p-0" for="scopesAll">All scopes</label>
                        <div class="text-base-content/60 code-link">["*"]</div>
                    </li>

                    <li class="flex items-center gap-2 p-[1rem]">
                        <input type="checkbox" class="checkbox checkbox-sm scope-entry scope-list" id="scopesAPI"
                            name="scopesAPI" data-scope="api" {{#if values.scopesAPI}}checked{{/if}} />
                        <label class="label-text grow p-0" for="scopesAPI">API</label>
                        <div class="text-base-content/60 code-link">["api"]</div>
                    </li>

                    <li class="flex items-center gap-2 p-[1rem]">
                        <input type="checkbox" class="checkbox checkbox-sm scope-entry scope-list" id="scopesSMTP"
                            name="scopesSMTP" data-scope="smtp" {{#if values.scopesSMTP}}checked{{/if}} />
                        <label class="label-text grow p-0" for="scopesSMTP">SMTP</label>
                        <div class="text-base-content/60 code-link">["smtp"]</div>
                    </li>

                    <li class="flex items-center gap-2 p-[1rem]">
                        <input type="checkbox" class="checkbox checkbox-sm scope-entry scope-list" id="scopesImapProxy"
                            name="scopesImapProxy" data-scope="imap-proxy" {{#if values.scopesImapProxy}}checked{{/if}} />
                        <label class="label-text grow p-0" for="scopesImapProxy">IMAP Proxy</label>
                        <div class="text-base-content/60 code-link">["imap-proxy"]</div>
                    </li>

                    <li class="flex items-center gap-2 p-[1rem]">
                        <input type="checkbox" class="checkbox checkbox-sm scope-entry scope-list" id="scopesMetrics"
                            name="scopesMetrics" data-scope="metrics" {{#if values.scopesMetrics}}checked{{/if}} />
                        <label class="label-text grow p-0" for="scopesMetrics">Metrics</label>
                        <div class="text-base-content/60 code-link">["metrics"]</div>
                    </li>
                </ul>
            </div>

        </div>
    </div>

    <div class="mb-6">
        {{> ui/btn label="Generate a token" type="submit" icon="icon-[tabler--key]"}}
    </div>
</form>

{{#> ui/modal id="showToken" title="Access tokens" static=true}}
<div class="modal-body">
    <div id="showTokenLoader" class="py-2 text-center">
        <span class="loading loading-spinner loading-sm align-middle"></span> Generating token&hellip;
    </div>
    <div id="showTokenContent" class="hidden">

        <div class="mb-2">Access token:</div>
        <div class="flex gap-2">
            <input type="text" id="showTokenValue" class="input grow font-mono" aria-label="Access token" readonly>
            {{#> ui/tooltip text="Copy to clipboard"}}
            <button class="btn btn-primary copy-btn" type="button" data-clipboard-action="copy"
                data-clipboard-target="#showTokenValue" aria-label="Copy to clipboard">
                <span class="icon-[tabler--copy] size-4"></span>
            </button>
            {{/ui/tooltip}}
        </div>

    </div>
    <div id="showTokenError" class="hidden alert alert-soft alert-error whitespace-pre-line"></div>
</div>
<div class="modal-footer">
    {{> ui/btn label="Done" variant="neutral" style="soft" overlay="#showToken"}}
</div>
{{/ui/modal}}

<script>
    document.addEventListener('DOMContentLoaded', () => {

        let showTokenValueElm = document.getElementById('showTokenValue');

        showTokenValueElm.addEventListener('click', () => {
            showTokenValueElm.focus();
            showTokenValueElm.select();
        })

        document.getElementById('token-form').addEventListener('submit', e => {
            e.preventDefault()

            let crumb = document.getElementById('crumb').value;
            let description = document.getElementById('description').value.trim();
            document.getElementById('description').value = description

            let scopes = [];
            let scopeElms = document.querySelectorAll('.scope-entry');
            for (let elm of scopeElms) {
                if (elm.checked && !elm.disabled) {
                    scopes.push(elm.dataset.scope);
                }
            }

            if (scopes.includes('*')) {
                scopes = ['*'];
            }

            let wasShown = false;

            document.getElementById('showToken').addEventListener('close.overlay', () => {
                document.getElementById('showTokenLoader').classList.remove('hidden');
                document.getElementById('showTokenContent').classList.add('hidden');
                document.getElementById('showTokenError').classList.add('hidden');
                showTokenValueElm.value = '';

                if (wasShown) {
                    let account = document.getElementById('account').value || '';
                    location.assign("/admin/tokens" + (account ? '?account=' + encodeURIComponent(account) : ''));
                }
            }, { once: true });

            document.getElementById('showTokenLoader').classList.remove('hidden');
            document.getElementById('showTokenContent').classList.add('hidden');
            document.getElementById('showTokenError').classList.add('hidden');
            uiModal.open('#showToken');

            fetch('/admin/tokens/new', {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value,
                    description,
                    scopes,
                    account: document.getElementById('account').value || ''
                })
            }).then(res => {
                if (!res.ok) {
                    throw new Error(`HTTP error! status: ${res.status}`);
                }
                return res.json()
            }).then(data => {

                if (!data.success) {
                    throw new Error(`${data.error}\n${data.message}`);
                }

                document.getElementById('showTokenLoader').classList.add('hidden');
                document.getElementById('showTokenContent').classList.remove('hidden');
                document.getElementById('showTokenError').classList.add('hidden');
                showTokenValueElm.value = data.token;

                wasShown = true
            }).catch(err => {
                document.getElementById('showTokenLoader').classList.add('hidden');
                document.getElementById('showTokenContent').classList.add('hidden');
                document.getElementById('showTokenError').classList.remove('hidden');

                document.getElementById('showTokenError').textContent = err.message;
            });
        });
    })
</script>
