{{#> ui/page-header title="Access Tokens" icon="icon-[tabler--key]" subtitle="Bearer tokens that authenticate requests to the EmailEngine API." badgeLabel=total badgeVariant="neutral" class="mb-6"}}
{{> ui/btn href=newLink label="Create access token" icon="icon-[tabler--plus]"}}
{{/ui/page-header}}

{{> ui/search-crumb parentHref="/admin/tokens" parentLabel="Access Tokens" query=query}}

{{#if data.tokens}}
<div class="card bg-base-100 shadow-md mb-6">
    {{#if account}}
    <div class="card-body">
        <div>
            Currently showing tokens for <strong><a href="/admin/accounts/{{account.account}}"
                    class="link link-animated">{{account.name}}</a></strong>. These tokens cannot be
            used by other accounts.
        </div>
    </div>
    {{/if}}
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr>
                    <th>Description</th>
                    <th>Scopes</th>
                    <th>Last used</th>
                    <th class="w-12"><span class="sr-only">Actions</span></th>
                </tr>
            </thead>

            <tbody>
                {{#each data.tokens}}
                <tr>
                    <td>
                        <div><strong>{{description}}</strong></div>
                        {{> ui/entity-id id=id short=idShort label="Token ID"}}
                    </td>

                    <td>
                        {{#if scopes}}
                        {{#each scopes}}{{#unless first}}, {{/unless}}{{name}}{{/each}}
                        {{/if}}
                    </td>

                    <td>
                        {{#if access.timeStr}}
                        <span class="relative-time" data-time="{{access.timeStr}}"></span>
                        {{else}}
                        <span>Never used</span>
                        {{/if}}
                    </td>

                    <td class="text-end">
                        {{> ui/row-actions label="Token actions" deleteModal="#deleteToken" deleteId=id deleteName=description}}
                    </td>

                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    {{> ui/pagination showPaging=showPaging prevPage=prevPage nextPage=nextPage pageLinks=pageLinks}}
</div>

{{else}}
{{#> ui/list-empty noun="access tokens" query=query firstPage=firstPage createHref=newLink createLabel="Create your first access token" clearHref="/admin/tokens"}}
{{#if account}}
<div class="mb-2">
    Currently showing tokens for <strong><a href="/admin/accounts/{{account.account}}"
            class="link link-animated">{{#if account.name}}{{account.name}}{{else}}{{account.email}}{{/if}}</a></strong>.
    These tokens cannot be used by other accounts.
</div>
{{/if}}
{{/ui/list-empty}}
{{/if}}


{{#> ui/details summary="Usage instructions" class="card bg-base-100 shadow-md mb-6"}}
<div>
        <p class="mb-4">You must use either the <em>Authorization: Bearer</em> header (recommended) or the
            <em>access_token</em> query parameter to make API requests. Avoid using the query parameter as it is
            not redacted from HTTP logs.
        </p>

        <pre class="ee-code-block">$ curl "<span class="cur-base-url" data-origin="">http://127.0.0.1:3000</span>/v1/stats?access_token=&lt;token&gt;"
$ curl "<span class="cur-base-url" data-origin="">http://127.0.0.1:3000</span>/v1/stats" --header "Authorization: Bearer &lt;token&gt;"</pre>

        <p class="mt-4 mb-4">Prometheus endpoint at <code>/metrics</code> also requires an authorization
            token. Use the following configuration for setting up the token for a scraping endpoint:
        </p>

        <pre class="ee-code-block">authorization:
  type: Bearer
  credentials: &lt;token&gt;</pre>

        <hr class="my-4">
        <div class="text-base-content/60">
            <code>&lt;token&gt;</code> is the full access token string without any quoting.
        </div>
        <div class="text-base-content/60">Read more about setting
            up Prometheus and Grafana with EmailEngine from the <a href="https://learn.emailengine.app/docs/advanced/monitoring#prometheus-metrics"
                target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer"
                class="link link-animated">documentation</a>.
        </div>

</div>
{{/ui/details}}

{{> ui/delete-modal id="deleteToken" noun="access token" action="/admin/tokens/delete" fieldName="token"}}
