{{#> ui/page-header title="Email Accounts" icon="icon-[tabler--users]" class="mb-6"}}
{{> ui/btn label="Add an account" icon="icon-[tabler--user-plus]" overlay="#addAccount"}}
{{/ui/page-header}}

{{#if query}}
{{> ui/breadcrumb parentHref="/admin/accounts" parentLabel="Accounts" current=(concat 'Results for "' query '"') class="mb-6"}}
{{/if}}

{{#if accounts}}
<div class="card bg-base-100 shadow-md mb-6">

    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Type</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                {{#each accounts}}
                <tr class="hover:bg-base-200/60">
                    <td class="relative">
                        <a href="/admin/accounts/{{account}}" class="absolute inset-0" aria-label="Open account"></a>
                        {{account}}
                    </td>
                    <td class="relative">
                        <a href="/admin/accounts/{{account}}" class="absolute inset-0" tabindex="-1" aria-hidden="true"></a><strong>{{name}}</strong>
                    </td>
                    <td class="relative">
                        <a href="/admin/accounts/{{account}}" class="absolute inset-0" tabindex="-1" aria-hidden="true"></a>{{email}}
                    </td>

                    <td class="relative">
                        <a href="/admin/accounts/{{account}}" class="absolute inset-0" tabindex="-1" aria-hidden="true"></a>
                        {{#if type.icon}}
                        {{!-- relative z-[1] lifts the tooltip trigger above the row link --}}
                        {{#> ui/tooltip text=type.label class="relative z-[1]"}}
                        {{!-- provider logos are still Font Awesome classes served by the
                              backend; converted to Tabler at the end of the migration --}}
                        <i class="{{type.icon}} fa-fw"></i>
                        {{/ui/tooltip}}
                        {{else}}
                        {{type.name}}
                        {{#if type.comment}}
                        <span class="text-base-content/60">({{type.comment}})</span>
                        {{/if}}
                        {{/if}}
                    </td>

                    <td class="relative w-32">
                        <a href="/admin/accounts/{{account}}" class="absolute inset-0" tabindex="-1" aria-hidden="true"></a>
                        {{!-- legacy badge classes + data-toggle popover stay until the
                              app.js SSE state updater is retargeted (Phase 5); the shim
                              and compat aliases keep them working on converted pages.
                              The wrapping link lifts the badge above the row overlay so
                              the hover popover fires while clicks still navigate. --}}
                        <a href="/admin/accounts/{{account}}" class="relative z-[1] inline-flex">
                            <span class="badge badge-pill badge-{{stateLabel.type}} state-info"
                                data-account="{{account}}" style="cursor:pointer;" data-toggle="popover"
                                data-trigger="hover" {{#if stateLabel.error}}data-title="Connection error"
                                data-content="{{stateLabel.error}}" {{/if}}>

                                {{#if stateLabel.spinner}}
                                <i class="fas fa-spinner fa-spin fa-fw"></i>
                                {{/if}}

                                {{stateLabel.name}}</span>
                        </a>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    {{#if showPaging}}
    <div class="card-footer border-base-content/10 border-t px-6 py-[1rem]">
        {{> ui/pagination prevPage=prevPage nextPage=nextPage pageLinks=pageLinks}}
    </div>
    {{/if}}
</div>
{{else}}
<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-body">
        No accounts found.
    </div>
</div>
{{/if}}

{{>add_account_modal}}
