    {{#if account.smtpServerEhlo}}
    <div class="card-footer border-base-content/10 border-t px-6 py-[1rem]">

        <dl class="ee-dl">
            <dt>Extensions</dt>
            <dd>
                {{#each account.smtpServerEhlo}}
                <small style="cursor: default;">{{this}}</small>
                {{/each}}
            </dd>

            <dt>Authentication</dt>
            <dd>
                {{#each account.smtpAuthMechanisms}}
                {{#if url}}
                {{#> ui/tooltip text=rfc}}<a href="{{url}}" target="_blank" rel="noopener noreferrer"
                    referrerpolicy="no-referrer" class="link link-animated"><small>{{auth}}</small></a>{{/ui/tooltip}}
                {{else}}
                <small class="cursor-default">{{this}}</small>
                {{/if}}
                {{/each}}
            </dd>
        </dl>

    </div>
    {{/if}}
</div>

{{/if}}

{{/unless}}

{{#if showAdvanced}}
<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-header"><h6 class="card-title text-primary">Advanced</h6>
    </div>
    <div class="card-body">

        <dl class="ee-dl">

            {{#if account.path}}
            <dt>Path to sync</dt>
            <dd><code class="text-base-content/60">{{account.path}}</code></dd>
            {{/if}}

            {{#if account.proxy}}
            <dt>Proxy</dt>
            <dd><code class="text-base-content/60">{{account.proxy}}</code></dd>
            {{/if}}

            {{#if account.webhooks}}
            <dt>Webhook URL</dt>
            <dd><code class="text-base-content/60">{{account.webhooks}}</code></dd>
            {{/if}}

        </dl>

        {{#if account.webhooks}}
        {{#if account.webhookErrorFlag.message}}
        <hr />

        <div><small><strong>Note:</strong> The last webhook attempt failed with the following response.</small></div>
        <div><code>{{account.webhookErrorFlag.message}}</code></div>

        {{/if}}
        {{/if}}

    </div>
</div>
{{/if}}

{{#> ui/modal id="renewGrantModal" title="Re-authenticate account"}}
<div class="modal-body">
    <p>
        When renewing the OAuth2 grant, ensure you are not logged in to another account for the same
        provider in this browser. Otherwise, that account might override the settings and messages for
        <em>{{account.name}}</em> in EmailEngine.
    </p>
</div>
<div class="modal-footer">
    <form method="post" action="/accounts/new" class="flex gap-2">
        <input type="hidden" name="crumb" value="{{crumb}}">
        <input type="hidden" name="type" value="{{account.oauth2.provider}}">
        <input type="hidden" name="data" value="{{accountForm.data}}">
        <input type="hidden" name="sig" value="{{accountForm.signature}}">
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#renewGrantModal"}}
        <button type="submit" class="btn btn-primary">
            {{#if account.type.icon}}
            <i class="{{account.type.icon}} fa-fw"></i>
            {{/if}} Re-authenticate
        </button>
    </form>
</div>
{{/ui/modal}}

{{#> ui/modal id="deleteModal" title="Delete Account"}}
<div class="modal-body">
    <p>Are you sure you want to delete the account for {{account.name}}? This action cannot be
        undone.</p>
</div>
<div class="modal-footer">
    <form method="post" action="/admin/accounts/{{account.account}}/delete" class="flex gap-2">
        <input type="hidden" name="crumb" value="{{crumb}}" />
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#deleteModal"}}
        {{> ui/btn label="Delete account" variant="error" type="submit"}}
    </form>
</div>
{{/ui/modal}}

{{#> ui/modal id="testSendModal" title="Email delivery test" dialogClass="max-w-3xl"}}
<div class="modal-body">
    <p><small class="text-base-content/60">EmailEngine sends a test email from the selected account to EmailEngine's
            remote testing server. Once the test email has been processed, EmailEngine displays the
            authorization validation results below.</small>
    </p>
    <div id="test-send-pending-message">
        <p><span class="loading loading-spinner loading-sm align-middle"></span> Testing email delivery settings, please
            wait&mldr;<br />
            <small><strong>Note:</strong> This process may take several
                minutes depending on the SMTP server.</small>
        </p>
    </div>
    <div id="test-send-error">
        <p>Message submission failed with the following result:</p>
        <div>
            <small class="alert alert-soft alert-error error-message block font-mono"></small>
        </div>
    </div>
    <div id="test-send-results"></div>
</div>
<div class="modal-footer">
    {{> ui/btn label="Close" variant="neutral" style="soft" overlay="#testSendModal"}}
</div>
{{/ui/modal}}

{{#> ui/modal id="watchDetails" title="Renewal request details" dialogClass="max-w-3xl"}}
<div class="modal-body">
    <dl class="ee-dl">

        <dt>Error message</dt>
        <dd>{{gmailWatch.error}}</dd>

        <dt>Request time</dt>
        <dd>
            <span class="local-date-time" data-time="{{gmailWatch.lastCheckStr}}"
                title="{{gmailWatch.lastCheckStr}}"></span>
        </dd>

        {{#if gmailWatch.request.status}}
        <dt>Response status</dt>
        <dd>
            {{gmailWatch.request.status}}
        </dd>
        {{/if}}

        {{#if gmailWatch.request.contentType}}
        <dt>Content Type</dt>
        <dd>
            <span class="code-link">{{gmailWatch.request.contentType}}</span>
        </dd>
        {{/if}}

    </dl>

    {{#if gmailWatch.request.response}}

    <div class="mt-[1rem]">
        <textarea class="textarea font-mono w-full" rows="5" spellcheck="false" data-enable-grammarly="false"
            readonly>{{json gmailWatch.request.response}}</textarea>
    </div>

    {{/if}}

</div>
<div class="modal-footer">
    {{> ui/btn label="Close" variant="neutral" style="soft" overlay="#watchDetails"}}
</div>
{{/ui/modal}}

{{#> ui/modal id="exportModal" title="Export Messages"}}
<div class="modal-body">
    <div class="alert alert-soft alert-info mb-[1rem] flex items-start gap-2">
        <span class="icon-[tabler--flask] size-5 shrink-0"></span>
        <span><strong>Beta Feature:</strong> The export feature is currently in beta. If you encounter any issues,
            please contact <a href="mailto:support@postalsys.com" class="link link-animated">support@postalsys.com</a>.</span>
    </div>
    <div id="export-form-view" class="space-y-4">
        {{> ui/form-field id="export-start-date" type="date" label="Start Date"}}
        {{> ui/form-field id="export-end-date" type="date" label="End Date"}}
        <div>
            <div class="flex items-center gap-2">
                <input type="checkbox" class="checkbox checkbox-sm" id="export-include-attachments">
                <label class="label-text p-0" for="export-include-attachments">Include attachments</label>
            </div>
            <span class="helper-text">Download and include attachment file contents in the export.
                This increases export size and time.</span>
        </div>
        <small class="text-base-content/60 block">Gmail accounts export from All Mail. Other accounts export all folders
            (excluding Junk and Trash).</small>
    </div>

    <div id="export-status-view" class="hidden">
        <div class="mb-[1rem]">
            <strong>Status:</strong>
            <span id="export-status-badge" class="badge badge-info">Queued</span>
            <span id="export-phase-badge" class="badge badge-neutral ms-1 hidden"></span>
        </div>
        <div class="mb-[1rem]">
            <strong>Expires:</strong>
            <span id="export-expires-at" class="text-base-content/60"></span>
        </div>
        <div id="export-progress-section">
            <div class="progress mb-2">
                <div id="export-progress-bar" class="progress-bar bg-info" role="progressbar" aria-valuenow="0"
                    aria-valuemin="0" aria-valuemax="100" style="width: 0%"></div>
            </div>
            <small id="export-progress-text" class="text-base-content/60"></small>
        </div>
        <div id="export-error-section" class="hidden">
            <div class="alert alert-soft alert-error" id="export-error-message"></div>
        </div>
        <div id="export-download-section" class="hidden mt-[1rem]">
            <a href="#" id="export-download-link" class="btn btn-success btn-block">
                <span class="icon-[tabler--download] size-4"></span> Download Export
            </a>
        </div>
    </div>
</div>
<div class="modal-footer">
    {{> ui/btn label="Close" variant="neutral" style="soft" overlay="#exportModal"}}
    <button type="button" class="btn btn-error hidden" id="export-reset-btn">
        <span class="icon-[tabler--trash] size-4"></span> Reset
    </button>
    <button type="button" class="btn btn-primary" id="export-start-btn">
        <span class="icon-[tabler--file-export] size-4" id="export-start-icon"></span> Start Export
    </button>
</div>
{{/ui/modal}}

<input type="hidden" id="account-id" value="{{account.account}}">
<input type="hidden" id="crumb" value="{{crumb}}">

<script>
    document.addEventListener('DOMContentLoaded', () => {

        const reconnectAccount = async () => {
            const account = document.getElementById('account-id').value.trim();

            const res = await fetch(`/admin/accounts/${account}/reconnect`, {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value,
                    reconnect: true
                })
            })
            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }
            const data = await res.json();

            return data;
        }

        let reconnecting = false;
        const requestReconnectElm = document.getElementById('request-reconnect');
        requestReconnectElm.addEventListener('click', e => {
            e.preventDefault();
            if (requestReconnectElm.classList.contains('disabled')) {
                return;
            }

            if (reconnecting) {
                return
            }

            reconnecting = true;
            document.getElementById('reconnect-icon').classList.add('animate-spin');
            reconnectAccount().then(data => {
                document.getElementById('reconnect-icon').classList.remove('animate-spin');
                reconnecting = false;
                showToast(data.error ? data.error : (data.success ? 'Account reconnection requested' : 'Failed to request reconnect'), data.success ? 'check-circle' : 'alert-triangle');
            }).catch(err => {
                document.getElementById('reconnect-icon').classList.remove('animate-spin');
                reconnecting = false;
                showToast('Request failed\n' + err.message, 'alert-triangle');
            })
        });

        const syncAccount = async () => {
            const account = document.getElementById('account-id').value.trim();

            const res = await fetch(`/admin/accounts/${account}/sync`, {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value,
                    sync: true
                })
            })
            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }
            const data = await res.json();

            return data;
        }

        let syncing = false;
        const requestSyncElm = document.getElementById('request-sync');
        requestSyncElm.addEventListener('click', e => {
            e.preventDefault();
            if (requestSyncElm.classList.contains('disabled')) {
                return;
            }

            if (syncing) {
                return
            }

            syncing = true;
            document.getElementById('sync-icon').classList.add('animate-spin');
            syncAccount().then(data => {
                document.getElementById('sync-icon').classList.remove('animate-spin');
                syncing = false;
                showToast(data.error ? data.error : (data.success ? 'Account sync requested' : 'Failed to request syncing'), data.success ? 'check-circle' : 'alert-triangle');
            }).catch(err => {
                document.getElementById('sync-icon').classList.remove('animate-spin');
                syncing = false;
                showToast('Request failed\n' + err.message, 'alert-triangle');
            })
        });

        const toggleLogs = async () => {
            const account = document.getElementById('account-id').value.trim();

            let current = document.getElementById('logs-info').dataset.logs;
            let toggled = current === 'enabled' ? false : true;

            const res = await fetch(`/admin/accounts/${account}/logs`, {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value,
                    enabled: toggled
                })
            })
            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }
            const data = await res.json();
            if (data.enabled) {
                // mark as enabled
                document.getElementById('logs-info-label').textContent = 'Enabled';
                document.getElementById('logs-info').dataset.logs = 'enabled'
                document.getElementById('toggle-logs').textContent = 'Disable';
            } else {
                // mark as disabled
                document.getElementById('logs-info-label').textContent = 'Disabled';
                document.getElementById('logs-info').dataset.logs = 'disabled'
                document.getElementById('toggle-logs').textContent = 'Enable';
            }
            return data;
        }

        let togglingLogs = false;
        document.getElementById('toggle-logs').addEventListener('click', e => {
            e.preventDefault();
            if (togglingLogs) {
                return
            }
            togglingLogs = true;

            toggleLogs().then(data => {
                togglingLogs = false;
                showToast(data.error ? data.error : (data.success ? 'Logging settings updated' : 'Failed to request reconnect'), data.success ? 'check-circle' : 'alert-triangle');
            }).catch(err => {
                togglingLogs = false;
                showToast('Request failed\n' + err.message, 'alert-triangle');
            })
        });

        const flushLogs = async () => {
            const account = document.getElementById('account-id').value.trim();

            const res = await fetch(`/admin/accounts/${account}/logs-flush`, {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value
                })
            })
            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }
            const data = await res.json();
            return data;
        }

        let flushingLogs = false;
        document.getElementById('flush-logs').addEventListener('click', e => {
            e.preventDefault();
            if (flushingLogs) {
                return
            }
            flushingLogs = true;

            flushLogs().then(data => {
                flushingLogs = false;
                showToast(data.error ? data.error : (data.success ? 'Stored logs were flushed' : 'Failed to flush logs'), data.success ? 'check-circle' : 'alert-triangle');
            }).catch(err => {
                flushingLogs = false;
                showToast('Request failed\n' + err.message, 'alert-triangle');
            })
        });

        // Export status indicator on page load
        async function updateExportIndicator() {
            const account = document.getElementById('account-id').value.trim();
            const indicator = document.getElementById('export-status-indicator');
            if (!indicator) return;

            try {
                const res = await fetch(`/admin/accounts/${account}/exports?pageSize=1`);
                if (!res.ok) {
                    indicator.classList.add('hidden');
                    return;
                }
                const data = await res.json();

                if (data.exports && data.exports.length > 0) {
                    const latest = data.exports[0];
                    if (latest.status === 'queued' || latest.status === 'processing') {
                        indicator.textContent = latest.status === 'queued' ? 'Queued' : 'Exporting';
                        indicator.className = 'badge badge-info badge-sm rounded-full ms-1';
                    } else if (latest.status === 'completed') {
                        indicator.textContent = 'Ready';
                        indicator.className = 'badge badge-success badge-sm rounded-full ms-1';
                    } else {
                        indicator.classList.add('hidden');
                        return;
                    }
                    indicator.classList.remove('hidden');
                } else {
                    indicator.classList.add('hidden');
                }
            } catch (err) {
                console.error('Failed to check export status', err);
                indicator.classList.add('hidden');
            }
        }

        // Check export status on page load
        updateExportIndicator();

        // Export modal functionality
        let currentExportId = null;
        let exportPollingInterval = null;

        function showFormView() {
            document.getElementById('export-form-view').classList.remove('hidden');
            document.getElementById('export-status-view').classList.add('hidden');
            document.getElementById('export-start-btn').classList.remove('hidden');
            document.getElementById('export-reset-btn').classList.add('hidden');

            // Set default dates (last 1 year)
            const today = new Date();
            const lastYear = new Date(today);
            lastYear.setFullYear(lastYear.getFullYear() - 1);
            document.getElementById('export-end-date').value = today.toISOString().split('T')[0];
            document.getElementById('export-start-date').value = lastYear.toISOString().split('T')[0];
        }

        function showStatusView() {
            document.getElementById('export-form-view').classList.add('hidden');
            document.getElementById('export-status-view').classList.remove('hidden');
            document.getElementById('export-start-btn').classList.add('hidden');
            document.getElementById('export-reset-btn').classList.remove('hidden');
        }

        function getStatusBadgeClass(status) {
            switch (status) {
                case 'completed': return 'success';
                case 'failed': return 'error';
                case 'processing': return 'info';
                default: return 'neutral';
            }
        }

        function startPolling() {
            if (exportPollingInterval) return;
            exportPollingInterval = setInterval(updateExportStatus, 3000);
        }

        function stopPolling() {
            if (exportPollingInterval) {
                clearInterval(exportPollingInterval);
                exportPollingInterval = null;
            }
        }

        async function updateExportStatus() {
            if (!currentExportId) return;

            const account = document.getElementById('account-id').value.trim();
            try {
                const res = await fetch(`/admin/accounts/${account}/export/${currentExportId}`);
                if (!res.ok) {
                    throw new Error(`HTTP error! status: ${res.status}`);
                }
                const data = await res.json();

                // Update status badge
                const badge = document.getElementById('export-status-badge');
                badge.textContent = data.status.charAt(0).toUpperCase() + data.status.slice(1);
                badge.className = 'badge badge-' + getStatusBadgeClass(data.status);

                // Update phase badge
                const phaseBadge = document.getElementById('export-phase-badge');
                if (data.phase && data.status === 'processing') {
                    phaseBadge.textContent = data.phase.charAt(0).toUpperCase() + data.phase.slice(1);
                    phaseBadge.classList.remove('hidden');
                } else {
                    phaseBadge.classList.add('hidden');
                }

                // Update expiration date
                const expiresAtEl = document.getElementById('export-expires-at');
                if (data.expiresAt) {
                    const expiresDate = new Date(data.expiresAt);
                    expiresAtEl.textContent = expiresDate.toLocaleString();
                } else {
                    expiresAtEl.textContent = 'Unknown';
                }

                // Update progress bar
                const progressBar = document.getElementById('export-progress-bar');
                const progressText = document.getElementById('export-progress-text');

                if (data.phase === 'indexing' && data.progress) {
                    // During indexing, show folders scanned progress
                    const pct = data.progress.foldersTotal > 0
                        ? Math.round((data.progress.foldersScanned / data.progress.foldersTotal) * 100)
                        : 0;
                    progressBar.style.width = pct + '%';
                    progressBar.setAttribute('aria-valuenow', pct);
                    progressText.textContent = `Scanning folders: ${data.progress.foldersScanned || 0} / ${data.progress.foldersTotal || '?'}`;
                } else if (data.progress) {
                    // During exporting, show messages exported progress
                    const pct = data.progress.messagesQueued > 0
                        ? Math.round((data.progress.messagesExported / data.progress.messagesQueued) * 100)
                        : 0;
                    progressBar.style.width = pct + '%';
                    progressBar.setAttribute('aria-valuenow', pct);
                    progressText.textContent =
                        `${data.progress.messagesExported} / ${data.progress.messagesQueued} messages exported`;
                }

                // Handle completion
                if (data.status === 'completed') {
                    stopPolling();
                    document.getElementById('export-download-section').classList.remove('hidden');
                    document.getElementById('export-download-link').href =
                        `/admin/accounts/${account}/export/${currentExportId}/download`;
                    progressBar.style.width = '100%';
                    progressBar.setAttribute('aria-valuenow', 100);
                    progressBar.classList.remove('bg-info');
                    progressBar.classList.add('bg-success');
                }

                // Handle failure
                if (data.status === 'failed') {
                    stopPolling();
                    document.getElementById('export-error-section').classList.remove('hidden');
                    document.getElementById('export-error-message').textContent = data.error || 'Export failed';
                    document.getElementById('export-progress-section').classList.add('hidden');
                }
            } catch (err) {
                console.error('Failed to update export status', err);
            }
        }

        async function checkExistingExport() {
            const account = document.getElementById('account-id').value.trim();
            try {
                const res = await fetch(`/admin/accounts/${account}/exports?pageSize=1`);
                if (!res.ok) {
                    showFormView();
                    return;
                }
                const data = await res.json();

                if (data.exports && data.exports.length > 0) {
                    const latest = data.exports[0];
                    if (latest.status === 'queued' || latest.status === 'processing' || latest.status === 'completed') {
                        currentExportId = latest.exportId;
                        showStatusView();
                        // Reset progress display state
                        document.getElementById('export-progress-section').classList.remove('hidden');
                        document.getElementById('export-error-section').classList.add('hidden');
                        document.getElementById('export-download-section').classList.add('hidden');
                        document.getElementById('export-phase-badge').classList.add('hidden');
                        const progressBar = document.getElementById('export-progress-bar');
                        progressBar.classList.remove('bg-success');
                        progressBar.classList.add('bg-info');
                        await updateExportStatus();
                        if (latest.status !== 'completed' && latest.status !== 'failed') {
                            startPolling();
                        }
                        return;
                    }
                }
                showFormView();
            } catch (err) {
                console.error('Failed to check existing export', err);
                showFormView();
            }
        }

        const exportModalElm = document.getElementById('exportModal');
        if (exportModalElm) {
            exportModalElm.addEventListener('open.overlay', () => {
                checkExistingExport().catch(err => console.error(err));
            });

            exportModalElm.addEventListener('close.overlay', () => {
                stopPolling();
                updateExportIndicator();
            });
        }

        document.getElementById('export-start-btn').addEventListener('click', async function () {
            const account = document.getElementById('account-id').value.trim();
            const startDate = document.getElementById('export-start-date').value;
            const endDate = document.getElementById('export-end-date').value;
            const includeAttachments = document.getElementById('export-include-attachments').checked;

            if (!startDate || !endDate) {
                showToast('Please select date range', 'alert-triangle');
                return;
            }

            document.getElementById('export-start-icon').classList.add('animate-spin');

            try {
                const res = await fetch(`/admin/accounts/${account}/export`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        crumb: document.getElementById('crumb').value,
                        startDate: startDate + 'T00:00:00Z',
                        endDate: endDate + 'T23:59:59Z',
                        includeAttachments
                    })
                });

                const data = await res.json();
                if (data.exportId) {
                    currentExportId = data.exportId;
                    showStatusView();
                    // Reset progress display state
                    document.getElementById('export-progress-section').classList.remove('hidden');
                    document.getElementById('export-error-section').classList.add('hidden');
                    document.getElementById('export-download-section').classList.add('hidden');
                    document.getElementById('export-phase-badge').classList.add('hidden');
                    const progressBar = document.getElementById('export-progress-bar');
                    progressBar.classList.remove('bg-success');
                    progressBar.classList.add('bg-info');
                    progressBar.style.width = '0%';
                    progressBar.setAttribute('aria-valuenow', 0);
                    document.getElementById('export-progress-text').textContent = '';
                    await updateExportStatus();
                    startPolling();
                    showToast('Export started', 'check-circle');
                } else {
                    showToast(data.error || data.message || 'Failed to start export', 'alert-triangle');
                }
            } catch (err) {
                showToast('Export failed: ' + err.message, 'alert-triangle');
            } finally {
                document.getElementById('export-start-icon').classList.remove('animate-spin');
            }
        });

        document.getElementById('export-reset-btn').addEventListener('click', async function () {
            if (!currentExportId) return;

            const account = document.getElementById('account-id').value.trim();

            try {
                await fetch(`/admin/accounts/${account}/export/${currentExportId}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ crumb: document.getElementById('crumb').value })
                });

                stopPolling();
                currentExportId = null;
                showFormView();
                showToast('Export cleared', 'check-circle');
            } catch (err) {
                showToast('Failed to clear export: ' + err.message, 'alert-triangle');
            }
        });
    });
</script>

<script id="test-send-template" type="text/x-handlebars-template">{{{testSendTemplate}}}</script>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        Handlebars.registerHelper('equals', function (compareVal, baseVal, options) {
            if (baseVal == compareVal) {
                return options.fn(this);
            }
            return options.inverse(this);
        });

        Handlebars.registerHelper('inc', function (nr, inc, options) {
            return Number(nr) + Number(inc);
        });

        // status -> FlyonUI color/icon maps for the delivery-test results template
        const STATUS_COLORS = { pass: 'success', softfail: 'warning', fail: 'error', permerror: 'info', temperror: 'info' };
        Handlebars.registerHelper('statusColor', result => STATUS_COLORS[result] || 'neutral');

        Handlebars.registerHelper('statusIcon', result => {
            switch (result) {
                case 'pass':
                    return 'icon-[tabler--circle-check]';
                case 'neutral':
                case 'none':
                    return 'icon-[tabler--circle-off]';
                default:
                    return 'icon-[tabler--alert-triangle]';
            }
        });

        const testSendTemplate = Handlebars.compile(document.getElementById('test-send-template').innerHTML);

        let aborted = false;

        const createSmtpTestAccount = async (account, gateway) => {
            aborted = false;
            const res = await fetch(`/admin/smtp/create-test`, {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value,
                    account,
                    gateway
                })
            })
            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }
            const data = await res.json();

            return data;
        }


        const checkSmtpTestAccount = async user => {
            if (aborted) {
                return false
            }

            const res = await fetch(`/admin/smtp/check-test`, {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value,
                    user
                })
            });

            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }

            const data = await res.json();

            return data;
        }

        const waitForTestResults = async user => {
            let results;

            while (!results) {
                if (aborted) {
                    return false
                }

                let data = await checkSmtpTestAccount(user);
                switch (data.status) {
                    case 'error':
                        throw new Error(data.error)
                    case 'success':
                        results = data;
                        break;
                    case 'no data':
                    default:
                        await new Promise(r => setTimeout(r, 5 * 1000))
                }

            }

            return results;
        }

        const runDeliveryTest = testData => {
            document.getElementById('test-send-pending-message').classList.remove('hidden');
            document.getElementById('test-send-results').classList.add('hidden');
            document.getElementById('test-send-error').classList.add('hidden');
            document.getElementById('test-send-results').innerHTML = '';

            uiModal.open('#testSendModal');

            createSmtpTestAccount(testData.account, testData.gateway).then((result) => {
                return waitForTestResults(result.user);
            }).then(results => {
                document.getElementById('test-send-pending-message').classList.add('hidden');
                document.getElementById('test-send-error').classList.add('hidden');
                if (aborted) {
                    return false
                }
                document.getElementById('test-send-results').classList.remove('hidden');
                document.getElementById('test-send-results').innerHTML = testSendTemplate(results);
            }).catch(err => {
                if (aborted) {
                    return false
                }
                document.getElementById('test-send-pending-message').classList.add('hidden');
                document.getElementById('test-send-results').classList.add('hidden');
                document.getElementById('test-send-error').classList.remove('hidden');
                document.querySelector('#test-send-error .error-message').textContent = err.message;
            });
        };

        for (let trigger of document.querySelectorAll('.test-send-trigger')) {
            trigger.addEventListener('click', e => {
                e.preventDefault();
                runDeliveryTest({
                    account: trigger.dataset.account || '',
                    gateway: trigger.dataset.gateway || ''
                });
            });
        }

        const testSendModalElm = document.getElementById('testSendModal');
        if (testSendModalElm) {
            testSendModalElm.addEventListener('close.overlay', () => {
                aborted = true;
            });
        }
    })
</script>