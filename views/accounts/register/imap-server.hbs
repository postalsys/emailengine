{{!-- Hosted authentication form, step 3 (IMAP path): IMAP and SMTP server
settings. "Verify connection" tests the settings through
/accounts/new/imap/test before the form is submitted; the split button's
dropdown allows skipping the test. --}}

<form method="post" id="settings-form" action="/accounts/new/imap/server">
    <input type="hidden" name="crumb" value="{{crumb}}">
    <input type="hidden" name="data" value="{{values.data}}">
    <input type="hidden" name="sig" value="{{values.sig}}">
    <input type="hidden" name="email" value="{{values.email}}">
    <input type="hidden" name="name" value="{{values.name}}">

    {{!-- The appPassword_* hint values are server-derived only (initial render and the failAction
    re-render both compute them from the static provider table), never read back from the
    submission - the payload schemas stripUnknown any posted copy. Do not reintroduce hidden
    inputs for them: echoing a client-controlled hint into the page was an XSS vector. --}}

    <input type="hidden" id="tz" name="tz" value="{{values.tz}}">

    <div class="ee-form-grid">
        <div class="ee-form-col">
            <h6>{{_ "IMAP" templateLocale }}</h6>

            <div class="ee-field">
                <label class="ee-label" for="imap_auth_user">{{_ "Username" templateLocale }}</label>
                <input type="text" class="ee-input{{#if errors.imap_auth_user}} ee-invalid{{/if}}"
                    id="imap_auth_user" name="imap_auth_user" value="{{values.imap_auth_user}}" data-lpignore="true"
                    autocomplete="off" required tabindex="1" />
                {{#if errors.imap_auth_user}}
                <span class="ee-field-error">{{errors.imap_auth_user}}</span>
                {{/if}}
            </div>

            <div class="ee-field">

                {{#unless values.appPassword_required}}

                <label class="ee-label" for="imap_auth_pass">
                    {{_ "Password" templateLocale }}
                </label>

                {{else}}

                {{#if values.appPassword_warning}}

                <div class="ee-label-aside">
                    <span class="ee-tooltip">
                        <span class="ee-tooltip-trigger"><span
                                class="ee-icon ee-icon-alert-circle ee-error-text"></span></span>
                        <span class="ee-tooltip-content" role="tooltip">
                            <strong>{{_ 'Important' templateLocale }}</strong><br>
                            {{values.appPassword_warning}}
                        </span>
                    </span>
                </div>

                {{else}}

                <div class="ee-label-aside">
                    <span class="ee-tooltip">
                        <span class="ee-tooltip-trigger"><a target="_blank" rel="noopener noreferrer" class="ee-link"
                                href="{{values.appPassword_instructions}}" tabindex="-1">{{_ 'Instructions'
                                templateLocale }}</a></span>
                        <span class="ee-tooltip-content" role="tooltip">{{_
                            '%s accounts require an application password for %s.' templateLocale
                            values.appPassword_provider "IMAP"}}</span>
                    </span>
                </div>

                {{/if}}

                <label class="ee-label" for="imap_auth_pass">
                    {{_ "Application Password" templateLocale }}
                </label>

                {{/unless}}

                <input type="password" class="ee-input{{#if errors.imap_auth_pass}} ee-invalid{{/if}}"
                    id="imap_auth_pass" name="imap_auth_pass" value="{{values.imap_auth_pass}}" data-lpignore="true"
                    autocomplete="off" required tabindex="2" />
                {{#if errors.imap_auth_pass}}
                <span class="ee-field-error">{{errors.imap_auth_pass}}</span>
                {{/if}}
            </div>

            <div class="ee-field">
                <label class="ee-label" for="imap_host">{{_ "Hostname" templateLocale }}</label>
                <input type="text" class="ee-input{{#if errors.imap_host}} ee-invalid{{/if}}" data-lpignore="true"
                    autocomplete="off" id="imap_host" name="imap_host" value="{{values.imap_host}}" required
                    tabindex="3" />
                {{#if errors.imap_host}}
                <span class="ee-field-error">{{errors.imap_host}}</span>
                {{/if}}
            </div>

            <div class="ee-field">
                <label class="ee-label" for="imap_port">{{_ "Port" templateLocale }}</label>
                <input type="number" class="ee-input{{#if errors.imap_port}} ee-invalid{{/if}}" data-lpignore="true"
                    autocomplete="off" id="imap_port" name="imap_port" value="{{values.imap_port}}" required
                    tabindex="4" />
                {{#if errors.imap_port}}
                <span class="ee-field-error">{{errors.imap_port}}</span>
                {{/if}}
            </div>

            <div class="ee-field">
                <div class="ee-label-aside">
                    <span class="ee-tooltip">
                        <span class="ee-tooltip-trigger"><span
                                class="ee-icon ee-icon-help-circle ee-icon-muted"></span></span>
                        <span class="ee-tooltip-content" role="tooltip">
                            <strong>{{_ 'TLS for IMAP' templateLocale }}</strong><br>
                            {{_ 'TLS (also known as SSL) is usually only needed when using port 993. For other ports EmailEngine falls back to using STARTTLS based encryption.' templateLocale }}
                        </span>
                    </span>
                </div>
                <div class="ee-checkbox-row">
                    <input type="checkbox" class="ee-checkbox{{#if errors.imap_secure}} ee-invalid{{/if}}"
                        id="imap_secure" name="imap_secure" {{#if values.imap_secure}}checked{{/if}} tabindex="5" />
                    <label class="ee-label" for="imap_secure">{{_ "Use TLS" templateLocale }}</label>
                </div>
                {{#if errors.imap_secure}}
                <span class="ee-field-error">{{errors.imap_secure}}</span>
                {{/if}}
            </div>

        </div>
        <div class="ee-form-col">
            <h6>{{_ "SMTP" templateLocale }}</h6>

            <div class="ee-field">
                <label class="ee-label" for="smtp_auth_user">{{_ "Username" templateLocale }}</label>
                <input type="text" class="ee-input{{#if errors.smtp_auth_user}} ee-invalid{{/if}}"
                    id="smtp_auth_user" name="smtp_auth_user" value="{{values.smtp_auth_user}}" data-lpignore="true"
                    autocomplete="off" required tabindex="6" />
                {{#if errors.smtp_auth_user}}
                <span class="ee-field-error">{{errors.smtp_auth_user}}</span>
                {{/if}}
            </div>

            <div class="ee-field">

                {{#unless values.appPassword_required}}

                <label class="ee-label" for="smtp_auth_pass">
                    {{_ "Password" templateLocale }}
                </label>

                {{else}}

                {{#if values.appPassword_warning}}

                <div class="ee-label-aside">
                    <span class="ee-tooltip">
                        <span class="ee-tooltip-trigger"><span
                                class="ee-icon ee-icon-alert-circle ee-error-text"></span></span>
                        <span class="ee-tooltip-content" role="tooltip">
                            <strong>{{_ 'Important' templateLocale }}</strong><br>
                            {{values.appPassword_warning}}
                        </span>
                    </span>
                </div>

                {{else}}

                <div class="ee-label-aside">
                    <span class="ee-tooltip">
                        <span class="ee-tooltip-trigger"><a target="_blank" rel="noopener noreferrer" class="ee-link"
                                href="{{values.appPassword_instructions}}" tabindex="-1">{{_ 'Instructions'
                                templateLocale }}</a></span>
                        <span class="ee-tooltip-content" role="tooltip">{{_
                            '%s accounts require an application password for %s.' templateLocale
                            values.appPassword_provider 'SMTP'}}</span>
                    </span>
                </div>

                {{/if}}

                <label class="ee-label" for="smtp_auth_pass">
                    {{_ "Application Password" templateLocale }}
                </label>

                {{/unless}}

                <input type="password" class="ee-input{{#if errors.smtp_auth_pass}} ee-invalid{{/if}}"
                    id="smtp_auth_pass" name="smtp_auth_pass" value="{{values.smtp_auth_pass}}" data-lpignore="true"
                    autocomplete="off" required tabindex="7" />
                {{#if errors.smtp_auth_pass}}
                <span class="ee-field-error">{{errors.smtp_auth_pass}}</span>
                {{/if}}
            </div>

            <div class="ee-field">
                <label class="ee-label" for="smtp_host">{{_ "Hostname" templateLocale }}</label>
                <input type="text" class="ee-input{{#if errors.smtp_host}} ee-invalid{{/if}}" data-lpignore="true"
                    autocomplete="off" id="smtp_host" name="smtp_host" value="{{values.smtp_host}}" required
                    tabindex="8" />
                {{#if errors.smtp_host}}
                <span class="ee-field-error">{{errors.smtp_host}}</span>
                {{/if}}
            </div>

            <div class="ee-field">
                <label class="ee-label" for="smtp_port">{{_ "Port" templateLocale }}</label>
                <input type="number" class="ee-input{{#if errors.smtp_port}} ee-invalid{{/if}}" data-lpignore="true"
                    autocomplete="off" id="smtp_port" name="smtp_port" value="{{values.smtp_port}}" required
                    tabindex="9" />
                {{#if errors.smtp_port}}
                <span class="ee-field-error">{{errors.smtp_port}}</span>
                {{/if}}
            </div>

            <div class="ee-field">
                <div class="ee-label-aside">
                    <span class="ee-tooltip">
                        <span class="ee-tooltip-trigger"><span
                                class="ee-icon ee-icon-help-circle ee-icon-muted"></span></span>
                        <span class="ee-tooltip-content" role="tooltip">
                            <strong>{{_ 'TLS for SMTP' templateLocale }}</strong><br>
                            {{_ 'TLS (also known as SSL) is usually only needed when using port 465. For other ports EmailEngine falls back to using STARTTLS based encryption.' templateLocale }}
                        </span>
                    </span>
                </div>
                <div class="ee-checkbox-row">
                    <input type="checkbox" class="ee-checkbox{{#if errors.smtp_secure}} ee-invalid{{/if}}"
                        id="smtp_secure" name="smtp_secure" {{#if values.smtp_secure}}checked{{/if}} tabindex="10" />
                    <label class="ee-label" for="smtp_secure">{{_ "Use TLS" templateLocale }}</label>
                </div>
                {{#if errors.smtp_secure}}
                <span class="ee-field-error">{{errors.smtp_secure}}</span>
                {{/if}}
            </div>
        </div>
    </div>

    <div class="ee-form-actions">

        <button type="button" id="test-settings-btn" class="ee-btn ee-btn-primary" tabindex="11">
            <span class="ee-icon ee-icon-help-circle" id="test-settings-btn-icon"></span>
            {{_ "Verify connection" templateLocale }}
        </button>

        <div class="ee-split">
            <button type="submit" id="submit-settings-btn" class="ee-btn ee-btn-neutral">
                <span class="ee-icon ee-icon-arrow-right"></span>
                {{_ "Save and continue" templateLocale }}
            </button>
            <details class="ee-dropdown">
                <summary id="submit-settings-btn-down" class="ee-btn ee-btn-neutral ee-dropdown-toggle"
                    aria-haspopup="menu">
                    <span class="ee-sr-only">Toggle Dropdown</span>
                    <span class="ee-icon ee-icon-chevron-down"></span>
                </summary>
                <ul class="ee-dropdown-menu" role="menu" aria-labelledby="submit-settings-btn-down">
                    <li role="none"><a class="ee-dropdown-item" role="menuitem" href="#" id="submit-wo-testing">{{_
                            "Skip verification" templateLocale }}</a></li>
                </ul>
            </details>
        </div>

    </div>
</form>

{{!-- autofocus on the dialog keeps showModal() from focusing (and drawing a
focus ring on) the corner close button --}}
<dialog id="testResponseModal" class="ee-modal ee-modal-wide" aria-labelledby="testResponseModalLabel" autofocus>
    <div class="ee-modal-header">
        <h3 class="ee-modal-title" id="testResponseModalLabel">{{_ "Connection test failed" templateLocale }}</h3>
        <button type="button" class="ee-modal-close" aria-label="Close" data-modal-close>
            <span class="ee-icon ee-icon-x"></span>
        </button>
    </div>
    <div class="ee-modal-body">
        <p>{{_ "We couldn't connect with these settings. Check the errors below." templateLocale}}</p>
        <dl class="ee-dl" id="test-errors-list"></dl>
    </div>
    <div class="ee-modal-footer">
        <button type="button" class="ee-btn ee-btn-neutral ee-btn-soft" data-modal-close>{{_ "Close" templateLocale
            }}</button>
    </div>
</dialog>

<input type="hidden" id="autoTest" value="{{#if autoTest}}true{{/if}}">

<script>
    document.addEventListener('DOMContentLoaded', () => {

        let formTested = false;
        let formTesting = false;

        let myForm = document.getElementById('settings-form');
        let btnElm = document.getElementById('test-settings-btn');
        let iconElm = document.getElementById('test-settings-btn-icon');
        let submitElm = document.getElementById('submit-settings-btn')
        let submitDownElm = document.getElementById('submit-settings-btn-down')
        let errorsListElm = document.getElementById('test-errors-list')

        // Cosmetic only: greys out the real submit <button> while a submit is in flight (the dropdown
        // toggle is a <summary> and the skip link an <a>, neither has disabled semantics). The actual
        // duplicate-submit guard is the formSubmitting latch in submitForm(), which every path routes
        // through.
        let setSubmitButtonsDisabled = (disabled) => {
            submitElm.disabled = disabled;
        };

        let formSubmitting = false;
        let submitRecoveryTimer = null;
        let resetSubmitGuard = () => {
            formSubmitting = false;
            if (submitRecoveryTimer) {
                clearTimeout(submitRecoveryTimer);
                submitRecoveryTimer = null;
            }
            setSubmitButtonsDisabled(false);
        };
        let submitForm = () => {
            // The server claims a single-use nonce, so a second POST from a double-click loses the race and
            // renders a 403 even though the first request created the account. Submit at most once and
            // disable the submit controls so a duplicate submission cannot fire.
            if (formSubmitting) {
                return;
            }
            // myForm.submit() below bypasses HTML5 constraint validation (unlike a real submit button), so
            // run it explicitly - otherwise a cleared required field round-trips to the server, 400s, and the
            // re-render wipes the password fields. Bail (without latching the guard) so the user can fix it.
            if (!myForm.reportValidity()) {
                return;
            }
            formSubmitting = true;
            setSubmitButtonsDisabled(true);
            // Recovery timer for an aborted submit: a successful submit navigates away (this page and the
            // timer are discarded) and a validation error reloads the page fresh, so this only fires when the
            // navigation never happened - the user cancelled it (Esc / Stop) while the page stayed alive. There
            // is no DOM event for an aborted navigation, so without this the one-shot guard would leave the form
            // permanently unsubmittable. Re-enabling is safe: the server's single-use nonce is the real
            // double-submit guard, so at worst a later duplicate POST is rejected server-side. The delay is a
            // generous upper bound on a create round trip so it never re-arms a genuinely in-flight submit.
            submitRecoveryTimer = setTimeout(resetSubmitGuard, 20 * 1000);
            myForm.submit();
        };

        // Reset the one-shot guard when the page is restored from the back-forward cache (Back after a
        // submit): bfcache keeps JS state, so without this the flag stays set and the buttons stay disabled,
        // permanently deadening the form.
        window.addEventListener('pageshow', e => {
            if (!e.persisted) {
                return;
            }
            resetSubmitGuard();
        });

        let appendLinkified = (parentElm, text) => {
            // Split on URLs and append text nodes + anchors via DOM APIs so server-provided text is
            // never parsed as HTML (avoids an innerHTML injection sink).
            let parts = String(text == null ? '' : text).split(/(https?:\/\/[^\s]+)/g);
            for (let part of parts) {
                if (/^https?:\/\//.test(part)) {
                    let a = document.createElement('a');
                    a.href = part;
                    a.target = '_blank';
                    a.rel = 'noopener noreferrer';
                    a.textContent = part;
                    parentElm.appendChild(a);
                } else if (part) {
                    parentElm.appendChild(document.createTextNode(part));
                }
            }
        }

        let addErrorRow = (type, text, extraLabel, extraText) => {
            let keyElm = document.createElement('dt');
            let valueContainerElm = document.createElement('dd');
            let valueElm = document.createElement('div');

            valueElm.classList.add('ee-error-text')

            keyElm.textContent = type;
            valueElm.textContent = text;

            valueContainerElm.append(valueElm);

            errorsListElm.appendChild(keyElm);
            errorsListElm.appendChild(valueContainerElm);

            if (extraLabel && extraText) {

                let extraLabelElm = document.createElement('div');
                extraLabelElm.textContent = extraLabel;

                let extraTextElm = document.createElement('small');
                appendLinkified(extraTextElm, extraText);

                valueContainerElm.appendChild(extraLabelElm);
                valueContainerElm.appendChild(extraTextElm);
            }
        }

        let showErrorPopup = (data) => {
            data = data || {}

            errorsListElm.innerHTML = '';

            if (data.error && !data.fields) {
                // A Hapi/Boom error body carries the human-readable text in data.message and only the
                // status name in data.error ('Forbidden', 'Too Many Requests'); the client-side catch
                // path passes { error: Error } instead, hence the fallbacks.
                addErrorRow(`{{_ "Error" templateLocale }}`, data.message || data.error.message || data.error)
            } else if (data.fields) {
                addErrorRow(`{{_ "Invalid settings" templateLocale }}`, data.message);
                for (let field of data.fields) {
                    addErrorRow('-', field.message);
                }
            } else {
                if (!data.imap || !data.imap.success) {
                    let error = data.imap && data.imap.error || `{{_ "Couldn't connect to IMAP server" templateLocale }}`
                    if (data.imap && data.imap.responseText) {
                        addErrorRow('IMAP', error, `{{_ "Server response:" templateLocale }}`, data.imap.responseText);
                    } else {
                        addErrorRow('IMAP', error);
                    }
                }

                if (!data.smtp || !data.smtp.success) {
                    let error = data.smtp && data.smtp.error || `{{_ "Couldn't connect to SMTP server" templateLocale }}`
                    if (data.smtp && data.smtp.responseText) {
                        addErrorRow('SMTP', error, `{{_ "Server response:" templateLocale }}`, data.smtp.responseText);
                    } else {
                        addErrorRow('SMTP', error);
                    }
                }
            }

            document.getElementById('testResponseModal').showModal();
        }

        let toggleSpinner = (enabled, success) => {

            // the submit split button turns primary once the connection test has passed
            if (enabled) {
                iconElm.classList.remove('ee-icon-loader', 'ee-spin', 'ee-icon-help-circle', 'ee-icon-circle-check', 'ee-icon-circle-x');
                iconElm.classList.add(success ? 'ee-icon-circle-check' : 'ee-icon-circle-x');
                btnElm.disabled = false;

                if (success) {
                    submitElm.classList.replace('ee-btn-neutral', 'ee-btn-primary');
                    submitDownElm.classList.replace('ee-btn-neutral', 'ee-btn-primary');
                } else {
                    submitElm.classList.replace('ee-btn-primary', 'ee-btn-neutral');
                    submitDownElm.classList.replace('ee-btn-primary', 'ee-btn-neutral');
                }
            } else {
                iconElm.classList.remove('ee-icon-circle-check', 'ee-icon-circle-x', 'ee-icon-help-circle');
                iconElm.classList.add('ee-icon-loader', 'ee-spin');
                btnElm.disabled = true;

                submitElm.classList.replace('ee-btn-primary', 'ee-btn-neutral');
                submitDownElm.classList.replace('ee-btn-primary', 'ee-btn-neutral');
            }
        }

        let testSettings = async () => {
            let formData = new FormData(myForm);
            let body = {}
            for (var pair of formData.entries()) {
                body[pair[0]] = pair[1];
            }

            const res = await fetch('/accounts/new/imap/test', {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify(body)
            });

            if (!res.ok) {
                try {
                    let errData = await res.json();
                    return errData
                } catch (err) {
                    // ignore
                    console.error(err)
                }

                throw new Error(`{{_ "Request failed." templateLocale}} status: ${res.status}`);
            }

            const data = await res.json();

            return data;
        }

        let runTest = (continueIfSuccessful) => {
            if (formTesting) {
                return;
            }
            formTesting = true;

            toggleSpinner(false);
            testSettings().then(data => {
                formTesting = false;

                if (data.imap && data.imap.success && data.smtp && data.smtp.success) {
                    toggleSpinner(true, true);
                    // everything checks out!
                    formTested = true;

                    if (continueIfSuccessful) {
                        // resubmit after paint
                        setTimeout(() => submitForm(), 10);
                    }

                } else {
                    toggleSpinner(true, false);
                    formTested = false;
                    showErrorPopup(data);
                }
            }).catch(err => {
                formTesting = false;
                toggleSpinner(true, false);
                formTested = false;
                showErrorPopup({ error: err });
            });
        }

        // (the containing dropdown closes on any menu item activation - static/js/public.js)
        document.getElementById('submit-wo-testing').addEventListener('click', e => {
            e.preventDefault();
            formTested = true;
            submitForm();
        });

        btnElm.addEventListener('click', () => {
            runTest();
        });

        myForm.addEventListener('submit', e => {
            submitElm.blur();
            e.preventDefault();
            if (formTested) {
                submitForm();
                return;
            }
            runTest(true);
        });

        const checkPort = (proto) => {
            let portNr = Number(document.getElementById(`${proto}_port`).value);
            switch (proto) {
                case 'imap':
                    if (portNr === 993) {
                        // enable TLS checkbox
                        document.getElementById(`${proto}_secure`).checked = true;
                    }
                    if (portNr === 110) {
                        // enable TLS checkbox
                        document.getElementById(`${proto}_secure`).checked = false;
                    }
                    break;
                case 'smtp':
                    if (portNr === 465) {
                        // enable TLS checkbox
                        document.getElementById(`${proto}_secure`).checked = true;
                    }
                    if (portNr === 25 || portNr === 587) {
                        // enable TLS checkbox
                        document.getElementById(`${proto}_secure`).checked = false;
                    }
                    break;
            }
        }

        let imapPortElm = document.getElementById('imap_port');
        let smtpPortElm = document.getElementById('smtp_port');

        try {
            if (typeof Intl !== 'undefined' && Intl && typeof Intl.DateTimeFormat === 'function') {
                let tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
                if (tz) {
                    document.getElementById('tz').value = tz;
                }
            }
        } catch (err) {
            // Intl probably not supported
        }

        imapPortElm.addEventListener('change', () => checkPort('imap'));
        imapPortElm.addEventListener('click', () => checkPort('imap'));
        imapPortElm.addEventListener('keyup', () => checkPort('imap'));
        smtpPortElm.addEventListener('change', () => checkPort('smtp'));
        smtpPortElm.addEventListener('click', () => checkPort('smtp'));
        smtpPortElm.addEventListener('keyup', () => checkPort('smtp'));

        if (document.getElementById('autoTest').value.trim() === 'true') {
            runTest();
        }

    })
</script>
