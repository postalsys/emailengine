{{!-- Hosted authentication form, step 1: the account provider chooser. Every
button POSTs the signed data/sig blob back to /accounts/new with the chosen
provider type. --}}

<div class="ee-center">
    <h1>{{_ "Choose your email account provider" templateLocale }}</h1>
</div>

<div class="ee-providers">

    <div class="ee-provider">
        <form method="post" action="/accounts/new">
            <input type="hidden" name="crumb" value="{{crumb}}">
            <input type="hidden" name="type" value="imap">
            <input type="hidden" name="data" value="{{values.data}}">
            <input type="hidden" name="sig" value="{{values.sig}}">

            <button type="submit" class="ee-btn ee-btn-primary ee-btn-block ee-btn-lg">
                <span class="ee-icon ee-icon-mail"></span> {{_ "Standard IMAP" templateLocale }}
            </button>
        </form>
    </div>

    {{#if oauth2apps}}

    {{#each oauth2apps}}

    {{!-- an app's optional display title (set in the OAuth2 app settings) renders
    above its button so several apps of the same provider can be told apart; the
    ee-provider-titled hover highlight ties the title and button visually together --}}
    <div class="ee-provider{{#if title}} ee-provider-titled{{/if}}">

        {{#if title}}
        <h5 class="ee-provider-title">{{title}}</h5>
        {{/if}}

        <form method="post" action="/accounts/new">
            <input type="hidden" name="crumb" value="{{../crumb}}">
            <input type="hidden" name="type" value="{{id}}">
            <input type="hidden" name="data" value="{{../values.data}}">
            <input type="hidden" name="sig" value="{{../values.sig}}">

            {{#if providerData.linkImage}}
            <input type="image" src="{{providerData.linkImage}}" class="ee-provider-image" alt="{{providerData.comment}}" />
            {{else}}

            <button type="submit" class="ee-btn ee-btn-primary ee-btn-block ee-btn-xl">
                <span class="ee-icon {{providerData.publicIcon}}"></span> {{providerData.comment}}
            </button>
            {{/if}}

        </form>
    </div>
    {{/each}}

    {{/if}}

</div>
