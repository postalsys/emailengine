{{> accounts_header}}

{{> ui/breadcrumb parentHref="/admin/accounts" parentLabel="Accounts" midHref=(concat "/admin/accounts/" account) midLabel=account current="Browse" class="mt-6 mb-6"}}

<div id="email-client"></div>

{{#> ui/modal id="confirmModal" title="Confirm" titleId="confirmModalLabel"}}
<div class="modal-body">
    <p id="confirm-text"></p>
</div>
<div class="modal-footer">
    <button type="button" id="confirm-cancel" class="btn btn-soft btn-neutral" data-overlay="#confirmModal">Close</button>
    <button type="button" id="confirm-ok" class="btn btn-primary">OK</button>
</div>
{{/ui/modal}}

{{#> ui/modal id="alertModal" title="Notice" titleId="alertModalLabel"}}
<div class="modal-body">
    <p id="alert-text"></p>
</div>
<div class="modal-footer">
    <button type="button" id="alert-ok" class="btn btn-primary">OK</button>
</div>
{{/ui/modal}}

<script type="module">
    import { EmailEngineClient } from '/static/js/ee-client.js';

    // the OK/Close buttons are wired once; each confirm() call resets
    // confirmResult and resolves through a {once:true} close.overlay listener
    let confirmResult = false;
    document.getElementById('confirm-ok').addEventListener('click', () => {
        confirmResult = true;
        uiModal.close('#confirmModal');
    });
    document.getElementById('alert-ok').addEventListener('click', () => {
        uiModal.close('#alertModal');
    });

    // Create client with UI container
    const client = new EmailEngineClient({
        apiUrl: window.location.origin,
        account: '{{account}}',
        accessToken: '{{sessionToken}}',
        container: document.getElementById('email-client'),
        confirmMethod: (message, title = 'Confirm', cancelText = 'Cancel', okText = 'OK') => {
            return new Promise((resolve) => {
                confirmResult = false;
                document.getElementById('confirm-text').textContent = message;
                document.getElementById('confirmModalLabel').textContent = title;
                document.getElementById('confirm-cancel').textContent = cancelText;
                document.getElementById('confirm-ok').textContent = okText;

                document.getElementById('confirmModal').addEventListener('close.overlay', () => {
                    resolve(confirmResult);
                }, { once: true });

                uiModal.open('#confirmModal');
            });
        },

        alertMethod: (message, title = 'Notice', cancelText = null, okText = 'OK') => {
            return new Promise((resolve) => {
                document.getElementById('alert-text').textContent = message;
                document.getElementById('alertModalLabel').textContent = title;
                document.getElementById('alert-ok').textContent = okText;

                document.getElementById('alertModal').addEventListener('close.overlay', () => {
                    resolve(true);
                }, { once: true });

                uiModal.open('#alertModal');
            });
        }
    });
</script>
