{{> accounts_header}}

{{> ui/breadcrumb parentHref="/admin/accounts" parentLabel="Accounts" midHref=(concat "/admin/accounts/" account) midLabel=account current="Edit" class="mt-6 mb-6"}}

<form method="post" action="/admin/accounts/{{account}}/edit">
    <input type="hidden" name="crumb" value="{{crumb}}">

    <div class="card bg-base-100 shadow-md mb-6">

        <div class="card-header">
            <h6 class="card-title text-primary">Account</h6>
        </div>

        <div class="card-body space-y-4">

            {{> ui/form-field id="name" label="Full name" value=values.name error=errors.name hint="Full name of the user"}}
            {{> ui/form-field id="email" type="email" label="Email" value=values.email error=errors.email hint="Email address of the user"}}

        </div>
    </div>

    {{#unless isApi}}

    {{#if values.imap}}
    <input type="hidden" name="imap" value="on">

    <div class="card bg-base-100 shadow-md mb-6">

        <div class="card-header">
            <h6 class="card-title text-primary">IMAP</h6>
        </div>

        <div class="card-body space-y-4">

            {{#unless values.imap_disabled}}
            {{#unless values.oauth2}}

            {{> ui/form-field id="imap_auth_user" label="Username" value=values.imap_auth_user error=errors.imap_auth_user lpignore=true required=true}}

            {{> ui/form-field id="imap_auth_pass" type="password" label="Password" value=values.imap_auth_pass error=errors.imap_auth_pass lpignore=true placeholder=(when hasIMAPPass "Password is set but not shown...") hint="Only set if you want to change the current IMAP password"}}

            {{> ui/form-field id="imap_host" label="Hostname" value=values.imap_host error=errors.imap_host lpignore=true required=true}}
            {{> ui/form-field id="imap_port" type="number" label="Port" value=values.imap_port error=errors.imap_port lpignore=true required=true}}

            {{> ui/checkbox id="imap_secure" label="Use TLS" checked=values.imap_secure error=errors.imap_secure dataTarget="header-list" tooltip="TLS (also known as SSL) is usually only needed when using port 993. For other ports EmailEngine falls back to using STARTTLS based encryption."}}

            {{/unless}}

            {{> ui/form-field id="imap_sentMailPath" label="Sent Mail folder" value=values.imap_sentMailPath error=errors.imap_sentMailPath lpignore=true placeholder='Folder path like "Sent Mail"' list="available-paths-list" hint='Copies of sent emails will be uploaded to this folder. Leave empty to use the default "Sent Mail" folder for this account.'}}

            {{> ui/form-field id="imap_resyncDelay" type="number" label="Resync delay" value=values.imap_resyncDelay error=errors.imap_resyncDelay lpignore=true hint="Keep empty for default"}}

            {{/unless}}

            {{> ui/checkbox id="imap_disabled" label="Disable IMAP" checked=values.imap_disabled error=errors.imap_disabled dataTarget="header-list" tooltip="Disable IMAP if you are using this email account only for sending emails."}}

        </div>
    </div>
    {{/if}}

    {{#if values.smtp}}
    <input type="hidden" name="smtp" value="on">

    <div class="card bg-base-100 shadow-md mb-6">

        <div class="card-header">
            <h6 class="card-title text-primary">SMTP</h6>
        </div>

        <div class="card-body space-y-4">

            {{> ui/form-field id="smtp_auth_user" label="Username" value=values.smtp_auth_user error=errors.smtp_auth_user lpignore=true required=true}}

            {{> ui/form-field id="smtp_auth_pass" type="password" label="Password" value=values.smtp_auth_pass error=errors.smtp_auth_pass lpignore=true placeholder=(when hasSMTPPass "Password is set but not shown...") hint="Only set if you want to change the current SMTP password"}}

            {{> ui/form-field id="smtp_host" label="Hostname" value=values.smtp_host error=errors.smtp_host lpignore=true required=true}}
            {{> ui/form-field id="smtp_port" type="number" label="Port" value=values.smtp_port error=errors.smtp_port lpignore=true required=true}}

            {{> ui/checkbox id="smtp_secure" label="Use TLS" checked=values.smtp_secure error=errors.smtp_secure dataTarget="header-list" tooltip="TLS (also known as SSL) is usually only needed when using port 465. For other ports EmailEngine falls back to using STARTTLS based encryption."}}

        </div>
    </div>
    {{/if}}

    {{/unless}}

    <div class="card bg-base-100 shadow-md mb-6">

        <div class="card-header">
            <h6 class="card-title text-primary">Advanced settings</h6>
        </div>

        <div class="card-body space-y-4">

            {{#> ui/form-field id="proxy" label="Proxy URL" error=errors.proxy hint="Fill this if you want to use a custom proxy for this account. Proxy URL must start with http://, https://, socks://, socks4:// or socks5://"}}
            <input type="text" class="input or-else-all{{#if errors.proxy}} is-invalid{{/if}}" id="proxy"
                placeholder="Connection URL like &quot;socks://localhost:1080&quot;&mldr;" value="{{values.proxy}}"
                name="proxy" data-target="proxy-status">
            {{/ui/form-field}}

            <div>
                {{> ui/setting-ref name="smtpEhloName"}}
                {{> ui/form-field id="smtpEhloName" label="SMTP Greeting Hostname" value=values.smtpEhloName error=errors.smtpEhloName placeholder='Proxy hostname like "my.proxy.tld"...'}}
                <span class="helper-text">Hostname to use for the SMTP EHLO/HELO greeting. Leave empty to use the
                    default <code>{{defaultSmtpEhloName}}</code>. If you are using a dedicated IP address, the hostname
                    of that IP is preferred over this value.</span>
            </div>

            {{> ui/form-field id="webhooks" label="Webhook URL" value=values.webhooks error=errors.webhooks placeholder='URL like "https://myservice.com/imap/webhooks"' hint="Account-specific webhook URL. If set and webhooks are enabled, EmailEngine will send webhook requests for events related to this account to this URL instead of the default webhook URL. Leave empty to clear."}}

            {{#> ui/form-field id="customHeaders" label="List of custom webhook request headers" error=errors.customHeaders hint="Keep one header per line. These headers will be added to the HTTP request when posting webhooks for this email account."}}
            <textarea class="textarea font-mono w-full{{#if errors.customHeaders}} is-invalid{{/if}}" id="customHeaders"
                name="customHeaders" rows="5" spellcheck="false" data-enable-grammarly="false"
                placeholder="Custom headers like &quot;Authorization: Bearer secret_token&quot;&mldr;">{{values.customHeaders}}</textarea>
            {{/ui/form-field}}

        </div>
    </div>

    <div class="mb-6">
        {{> ui/btn label="Update account" type="submit" icon="icon-[tabler--user]"}}
    </div>
</form>


<input type="hidden" id="availablePaths" value="{{availablePaths}}">

<script>
    document.addEventListener('DOMContentLoaded', () => {
        let availablePaths = JSON.parse(document.getElementById('availablePaths').value);
        // native datalist suggestions for the Sent Mail folder input (the
        // form-field markup references the list id directly)
        uiDatalist('available-paths-list', availablePaths);
    })
</script>
