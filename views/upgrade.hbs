{{> ui/page-header title="Upgrade instructions" icon="icon-[tabler--settings]" class="mb-1"}}

{{#unless isRender}}
{{#> ui/stat-card variant="info" icon="icon-[tabler--info-circle]" class="mt-6"}}

{{#if isDO}}
<p class="mb-2">To upgrade EmailEngine to the latest version, log in to your server and run the
    following command:<br />
    <kbd class="kbd">$ sudo /opt/upgrade-emailengine.sh</kbd>
</p>
{{/if}}

{{#if isScriptInstalled}}
<p class="mb-2">To upgrade EmailEngine to the latest version, log in to your server and run the
    following command:<br />
    <kbd class="kbd">$ sudo /opt/upgrade-emailengine.sh</kbd>
</p>
{{/if}}

{{#if isGeneral}}
<p class="mb-2">To upgrade EmailEngine to the latest version, download the latest version from the <a
        href="https://emailengine.app/#downloads" target="_blank" rel="noopener noreferrer"
        referrerpolicy="no-referrer" class="link link-animated">EmailEngine's homepage</a>, replace the binary and
    restart the application.</p>
{{/if}}

{{/ui/stat-card}}
{{/unless}}

{{#if isRender}}
<div class="card bg-base-100 shadow-md mt-6 mb-6">
    <div class="card-body">
        <p class="mb-6">To upgrade EmailEngine to the latest version, log in to your Render <a
                href="https://dashboard.render.com/" target="_blank" rel="noopener noreferrer"
                referrerpolicy="no-referrer" class="link link-animated">Dashboard</a>,
            select
            EmailEngine and run a manual deploy as shown on the screenshot below.
        </p>
        <p><img src="/static/preview/render.png"
                class="border-base-content/10 rounded-box max-w-full border p-1" alt="Render manual deploy"></p>
    </div>
</div>
{{/if}}
