{{#each pendingMessages}}
<div class="alert alert-{{#if type}}{{type}}{{else}}danger{{/if}} alert-soft flash-alert flex items-center justify-between gap-3 mb-6 transition-opacity duration-300"
    role="alert">
    <div class="grow text-center">
        {{#if title}}
        <strong>{{title}}</strong>
        {{/if}} {{message}}
    </div>
    <button type="button" class="flash-alert-close shrink-0 text-xl leading-none opacity-50 hover:opacity-100"
        aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
{{/each}} {{#if alert}}
<div class="alert alert-{{#if alert.type}}{{alert.type}}{{else}}danger{{/if}} alert-soft flash-alert flex items-center justify-between gap-3 mb-6 transition-opacity duration-300"
    role="alert">
    <div class="grow text-center">
        {{#if alert.title}}
        <strong>{{alert.title}}</strong>
        {{/if}} {{alert.message}}
    </div>
    <button type="button" class="flash-alert-close shrink-0 text-xl leading-none opacity-50 hover:opacity-100"
        aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
{{/if}}
{{!-- close/auto-dismiss behavior for .flash-alert lives in static/js/ui.js --}}
