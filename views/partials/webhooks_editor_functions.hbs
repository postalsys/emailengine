{{!-- Webhook routing editor script: the shared filter/map test machinery plus the
      webhooks-specific "send test payload" action (posts the mapped preview to the
      configured target URL). --}}
{{> filter_editor_js hasMap=true}}

<script>
    document.addEventListener('DOMContentLoaded', () => {

        const sendTestPayload = async () => {
            const webhooks = document.getElementById('inputTargetUrl').value.trim();
            {{!-- ace.edit() on an initialized element returns the live instance created
                  by filter_editor_js --}}
            const payload = ace.edit('editor-map-preview').getValue().trim();
            const customHeaders = document.getElementById('customHeaders').value.trim();

            return await uiPostJson('/admin/config/webhooks/test', { webhooks, customHeaders, payload });
        }

        const testSendBtn = document.getElementById('test-send-btn');
        testSendBtn.addEventListener('click', e => {
            e.preventDefault();
            sendTestPayload().then(data => {
                showToast(data.error ? data.error : (data.success ? 'Test payload sent' : 'Failed to send payload'), data.success ? 'check-circle' : 'alert-triangle');
            }).catch(err => {
                showToast('Request failed\n' + err.message, 'alert-triangle');
            })
        });
    });
</script>
