{{#if activeOutlook}}
{{#> ui/stat-card variant="info" icon="icon-[tabler--info-circle]" class="mb-6"}}
<strong>Delegated</strong> access means EmailEngine acts on behalf of a signed-in user. Each
mailbox owner must complete an interactive OAuth2 login. Use this when users manage their own
accounts or when you have access to the mailbox credentials.
{{#if providerData.tutorialUrl}}
Read about setting up {{providerData.comment}} OAuth2 project from <a href="{{providerData.tutorialUrl}}"
    target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">here</a>.
{{/if}}
{{/ui/stat-card}}
{{/if}}

{{#if activeGmailService}}
{{#> ui/stat-card variant="info" icon="icon-[tabler--info-circle]" class="mb-6"}}
<strong>Service accounts</strong> let EmailEngine access any mailbox in your Google Workspace
organization without an interactive user login. The service account must have domain-wide
delegation enabled in Workspace. Use this for automated integrations where you cannot perform
interactive logins.
<p class="mt-2 mb-0">
    Two authentication methods are supported: a downloaded <strong>service account key</strong>
    (classic) or <strong>Workload Identity Federation</strong> (keyless, for GKE, EKS, AKS, or
    any OIDC-emitting workload). Pick one below.
</p>
<p class="mt-2 mb-0">
    Accounts using service access can only be added via the
    <a href="/admin/swagger#/Account/postV1Account" class="link link-animated">REST API</a>, not through the hosted
    authentication form.{{#if providerData.tutorialUrl}} Read the
    <a href="{{providerData.tutorialUrl}}" target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer"
        class="link link-animated">setup guide</a> for both methods.{{/if}}
</p>
{{/ui/stat-card}}
{{/if}}

{{#if activeOutlookService}}
{{#> ui/stat-card variant="info" icon="icon-[tabler--info-circle]" class="mb-6"}}
<strong>Application</strong> access means EmailEngine authenticates as the app itself using
client credentials, with no interactive user login required. The Entra app registration must have
<strong>application permissions</strong> (not delegated) with admin consent. Use this for
service integrations, shared mailboxes, or when you cannot perform interactive logins.
Accounts using application access can only be added via the
<a href="/admin/swagger#/Account/postV1Account" class="link link-animated">REST API</a>,
not through the hosted authentication form.
{{#if providerData.tutorialUrl}}
Read about setting up {{providerData.comment}} from <a href="{{providerData.tutorialUrl}}" target="_blank"
    rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">here</a>.
{{/if}}
{{/ui/stat-card}}
{{/if}}

<div class="card bg-base-100 shadow-md mb-6">

    <div class="card-body space-y-4">

        <div>
            {{#> ui/form-field id="name" label="Application name" error=errors.name}}
            {{#if appData.legacy}}
            <input type="text" class="input{{#if errors.name}} is-invalid{{/if}}" id="name" value="{{appData.name}}"
                placeholder="Enter application name, eg. &quot;My App&quot;&mldr;" disabled />
            {{else}}
            <input type="text" class="input{{#if errors.name}} is-invalid{{/if}}" id="name" name="name"
                value="{{values.name}}" placeholder="Enter application name, eg. &quot;My App&quot;&mldr;" required />
            {{/if}}
            <span class="helper-text">Application name used when listing apps.</span>
            {{/ui/form-field}}
        </div>

        <div>
            {{#> ui/form-field id="description" label="Description" error=errors.description}}
            {{#if appData.legacy}}
            <input type="text" class="input{{#if errors.description}} is-invalid{{/if}}" id="description"
                value="{{appData.description}}" placeholder="" disabled />
            {{else}}
            <input type="text" class="input{{#if errors.description}} is-invalid{{/if}}" id="description"
                name="description" value="{{values.description}}" placeholder="" />
            {{/if}}
            <span class="helper-text">Optional application description or a comment.</span>
            {{/ui/form-field}}
        </div>

        {{#unless activeGmailService}}{{#unless activeOutlookService}}
        <div>
            {{#> ui/form-field id="title" label="Display title" error=errors.title}}
            {{#if appData.legacy}}
            <input type="text" class="input{{#if errors.title}} is-invalid{{/if}}" id="title" value="{{appData.title}}"
                placeholder="" disabled />
            {{else}}
            <input type="text" class="input{{#if errors.title}} is-invalid{{/if}}" id="title" name="title"
                value="{{values.title}}" placeholder="" />
            {{/if}}
            <span class="helper-text">Optional display title next to the application button on the account type
                selection page.</span>
            {{/ui/form-field}}
        </div>
        {{/unless}}{{/unless}}


        {{#if activeGmail}}
        <div>
            {{> ui/checkbox id="googleWorkspaceAccounts" name="googleWorkspaceAccounts"
            label="Show only Google Workspace accounts on the OAuth2 login page"
            checked=values.googleWorkspaceAccounts error=errors.googleWorkspaceAccounts
            hint="When enabled, only Google Workspace accounts will be available on the Gmail OAuth2 login screen."}}
        </div>
        {{/if}}

        {{#unless activeGmailService}}{{#unless activeOutlookService}}
        <div>
            {{> ui/checkbox id="enabled" name="enabled" label="Enable this app" checked=values.enabled
            error=errors.enabled
            hint="If enabled, then this OAuth2 app is shown as an account type option in the hosted authentication form."}}
        </div>
        {{/unless}}{{/unless}}

    </div>
</div>

<div class="card bg-base-100 shadow-md mb-6">

    <div class="card-header">
        <h6 class="card-title text-primary">OAuth2 Credentials</h6>
    </div>

    <div class="card-body space-y-4">

        {{#if activeGmailService}}

        <div>
            <label class="label-text block">Authentication method</label>
            <input type="hidden" name="authMethod" id="authMethod"
                value="{{#if authMethodIsExternalAccount}}externalAccount{{else}}serviceKey{{/if}}" />
            {{#if authMethodLocked}}
            <p class="mb-1">
                <strong>{{#if authMethodIsExternalAccount}}Workload Identity Federation (keyless){{else}}Service
                    account key{{/if}}</strong>
            </p>
            <span class="helper-text">The authentication method is fixed once the application has been created and
                cannot be changed.</span>
            {{else}}
            {{!-- custom tab behavior: the page script (new/edit) toggles the
                  active class and the auth-method sections; not a FlyonUI
                  data-tabs instance --}}
            <nav class="tabs tabs-bordered" id="auth-method-tabs" role="tablist" aria-label="Authentication method">
                <button type="button" class="tab auth-method-tab{{#if authMethodIsServiceKey}} active{{/if}}"
                    id="auth-method-tab-serviceKey" data-auth-method="serviceKey" role="tab"
                    aria-selected="{{#if authMethodIsServiceKey}}true{{else}}false{{/if}}">Service account key</button>
                <button type="button" class="tab auth-method-tab{{#if authMethodIsExternalAccount}} active{{/if}}"
                    id="auth-method-tab-externalAccount" data-auth-method="externalAccount" role="tab"
                    aria-selected="{{#if authMethodIsExternalAccount}}true{{else}}false{{/if}}">Workload Identity
                    Federation (keyless)</button>
            </nav>
            <span class="helper-text">"Service account key" expects a downloaded JSON key file.
                "Workload Identity Federation" authenticates without a long-lived key, using a credential issued
                by your runtime environment.</span>
            {{/if}}
        </div>

        <div class="auth-method-section auth-method-section-serviceKey{{#unless authMethodIsServiceKey}} hidden{{/unless}}">
            <div>
                {{> ui/btn label="Load configuration from the service key file…" variant="info" id="serviceFile"
                icon="icon-[tabler--cloud-upload]"}}
                <span class="helper-text">Select the JSON file you received after generating a new service key to
                    retrieve the service values.</span>
            </div>
        </div>

        <div class="auth-method-section auth-method-section-externalAccount{{#unless authMethodIsExternalAccount}} hidden{{/unless}}">
            <div>
                {{> ui/btn label="Load configuration from the external-account JSON file…" variant="info"
                id="externalAccountFile" icon="icon-[tabler--cloud-upload]"}}
                <span class="helper-text">Select the credential configuration file produced by
                    <code>gcloud iam workload-identity-pools create-cred-config</code>.</span>
            </div>
        </div>

        <div>
            {{#> ui/form-field id="googleProjectId" label="Google Cloud Project ID" error=errors.googleProjectId}}
            <input type="text" class="input{{#if errors.googleProjectId}} is-invalid{{/if}}" id="googleProjectId"
                name="googleProjectId" value="{{values.googleProjectId}}"
                placeholder="Enter the Google Cloud Project ID of the service, for example &quot;project-name-425411&quot;"
                required />
            <span class="helper-text">OAuth2 Service Project ID</span>
            {{/ui/form-field}}
        </div>

        <div>
            {{#> ui/form-field id="serviceClientEmail" label="Client Email" error=errors.serviceClientEmail}}
            <input type="email" class="input{{#if errors.serviceClientEmail}} is-invalid{{/if}}" id="serviceClientEmail"
                name="serviceClientEmail" value="{{values.serviceClientEmail}}"
                placeholder="Enter the principal of the service, for example &quot;name@project-123.iam.gserviceaccount.com&quot;"
                required />
            <span class="helper-text">OAuth2 Service Client Email</span>
            {{/ui/form-field}}
        </div>

        <div>
            {{#> ui/form-field id="serviceClient" label="Service client" error=errors.serviceClient}}
            <input type="text" class="input{{#if errors.serviceClient}} is-invalid{{/if}}" id="serviceClient"
                name="serviceClient" value="{{values.serviceClient}}" placeholder="Enter service client ID&mldr;"
                required />
            <span class="helper-text">OAuth2 Service Client ID</span>
            {{/ui/form-field}}
        </div>

        <div class="auth-method-section auth-method-section-serviceKey{{#unless authMethodIsServiceKey}} hidden{{/unless}}">
            <div>
                {{#> ui/form-field id="serviceKey" label="Secret service key" error=errors.serviceKey}}
                <textarea class="textarea w-full droptxt autoselect{{#if errors.serviceKey}} is-invalid{{/if}}"
                    id="serviceKey" name="serviceKey" rows="8" data-enable-grammarly="false" spellcheck="false" {{#if
                    hasServiceKey}}placeholder="Service key is set but not shown&mldr;" {{else}}
                    placeholder="Starts with &quot;-----BEGIN PRIVATE KEY-----&quot;&mldr;"
                    {{/if}}>{{values.serviceKey}}</textarea>
                {{/ui/form-field}}
            </div>
        </div>

        <div class="auth-method-section auth-method-section-externalAccount{{#unless authMethodIsExternalAccount}} hidden{{/unless}}">
            <div>
                {{#> ui/form-field id="externalAccount" label="External account configuration"
                error=errors.externalAccount}}
                <textarea
                    class="textarea w-full droptxt autoselect font-mono{{#if errors.externalAccount}} is-invalid{{/if}}"
                    id="externalAccount" name="externalAccount" rows="8" data-enable-grammarly="false"
                    spellcheck="false" {{#if
                    hasExternalAccount}}placeholder="External account configuration is set but not shown&mldr;"
                    {{else}}
                    placeholder="{&quot;type&quot;:&quot;external_account&quot;,&quot;audience&quot;:&quot;...&quot;,&quot;credential_source&quot;:{&quot;file&quot;:&quot;/var/run/secrets/...&quot;}}"
                    {{/if}}>{{values.externalAccount}}</textarea>
                <span class="helper-text">Paste the JSON produced by
                    <code>gcloud iam workload-identity-pools create-cred-config</code>. Only the
                    <code>file</code> and <code>url</code> credential sources are supported.</span>
                {{/ui/form-field}}
            </div>
        </div>

        {{else if activeOutlookService}}

        <div>
            {{#> ui/form-field id="clientId" label="Azure Application Id" error=errors.clientId}}
            <input type="text" class="input{{#if errors.clientId}} is-invalid{{/if}}" id="clientId" name="clientId"
                value="{{values.clientId}}" placeholder="Enter application (client) ID&mldr;" required />
            <span class="helper-text">The Application (client) ID from your Entra app registration.</span>
            {{/ui/form-field}}
        </div>

        <div>
            {{#> ui/form-field id="clientSecret" label="Client Secret" error=errors.clientSecret}}
            <input type="text" class="input{{#if errors.clientSecret}} is-invalid{{/if}}" id="clientSecret"
                name="clientSecret" value="{{values.clientSecret}}" {{#if hasClientSecret}}
                placeholder="Client secret is set but not shown&mldr;" {{else}} placeholder="Enter client
                secret&mldr;" {{/if}} {{#unless hasClientSecret}}required{{/unless}} />
            <span class="helper-text">Client secret value from Certificates &amp; secrets.</span>
            {{/ui/form-field}}
        </div>

        <div>
            {{#> ui/form-field id="cloud" label="Azure cloud environment" error=errors.cloud}}
            <select class="select select-sm max-w-md{{#if errors.cloud}} is-invalid{{/if}}" id="cloud" name="cloud"
                required>

                {{#each azureClouds}}
                <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}{{#if
                    description}} &mdash;
                    {{description}}{{/if}}</option>
                {{/each}}
            </select>
            <span class="helper-text">Accounts hosted in different cloud environments use different OAuth2
                endpoints.</span>
            {{/ui/form-field}}
        </div>

        <div>
            {{#> ui/form-field id="authority" label="Directory (tenant) ID" error=errors.authority}}
            <input type="text" class="input{{#if errors.authority}} is-invalid{{/if}}" id="authority" name="authority"
                value="{{values.authority}}"
                placeholder="Enter tenant ID, eg. &quot;f8cdef31-a31e-4b4a-93e4-5f571e91255a&quot;" required />
            <span class="helper-text">The Directory (tenant) ID from your Entra app registration. Client credentials
                flow requires a specific tenant ID.</span>
            {{/ui/form-field}}
        </div>

        {{else}}

        {{#if activeGmail}}

        <div>
            {{> ui/btn label="Load configuration from the JSON file…" variant="info" id="gmailConfigFile"
            icon="icon-[tabler--cloud-upload]"}}
            <span class="helper-text">Select the JSON file you can download when viewing client credential information
                in Google Cloud Console.</span>
        </div>

        <div>
            {{#> ui/form-field id="googleProjectId" label="Google Cloud Project ID" error=errors.googleProjectId}}
            <input type="text" class="input{{#if errors.googleProjectId}} is-invalid{{/if}}" id="googleProjectId"
                name="googleProjectId" value="{{values.googleProjectId}}"
                placeholder="Enter the Google Cloud Project ID of the service, for example &quot;project-name-425411&quot;" />
            <span class="helper-text">OAuth2 Project ID</span>
            {{/ui/form-field}}
        </div>

        {{/if}}

        <div>
            {{#> ui/form-field id="clientId" error=errors.clientId}}
            <label class="label-text" for="clientId">
                {{#if activeGmail}}
                Client Id
                {{/if}}

                {{#if activeMailRu}}
                Client Id
                {{/if}}

                {{#if activeOutlook}}
                Azure Application Id
                {{/if}}
            </label>
            <input type="text" class="input{{#if errors.clientId}} is-invalid{{/if}}" id="clientId" name="clientId"
                value="{{values.clientId}}" placeholder="Enter client ID&mldr;" required />
            <span class="helper-text">OAuth2 client id.</span>
            {{/ui/form-field}}
        </div>

        <div>
            {{#> ui/form-field id="clientSecret" label="Client Secret" error=errors.clientSecret}}
            <input type="text" class="input{{#if errors.clientSecret}} is-invalid{{/if}}" id="clientSecret"
                name="clientSecret" value="{{values.clientSecret}}" {{#if hasClientSecret}}
                placeholder="Client secret is set but not shown&mldr;" {{else}} placeholder="Enter client
                secret&mldr;" {{/if}} {{#unless hasClientSecret}}required{{/unless}} />
            <span class="helper-text">OAuth2 client secret.</span>
            {{/ui/form-field}}
        </div>

        {{#if activeOutlook}}

        <div>
            {{#> ui/form-field id="cloud" label="Azure cloud environment" error=errors.cloud}}
            <select class="select select-sm max-w-md{{#if errors.cloud}} is-invalid{{/if}}" id="cloud" name="cloud"
                required>

                {{#each azureClouds}}
                <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}{{#if
                    description}} &mdash;
                    {{description}}{{/if}}</option>
                {{/each}}
            </select>
            <span class="helper-text">Accounts hosted in different cloud environments use different OAuth2 endpoints
                and scopes.</span>
            {{/ui/form-field}}
        </div>

        {{/if}}

        {{#if activeOutlook}}

        <div>
            <label class="label-text block mb-2">Supported account types</label>

            <div class="space-y-2">
                <div class="flex items-start gap-2">
                    <input class="radio radio-sm mt-0.5 r-auth" type="radio" name="authority"
                        id="authorityOrganizations" value="organizations" {{#if
                        authorityOrganizations}}checked{{/if}}>
                    <label class="label-text p-0" for="authorityOrganizations">
                        Accounts in any organizational directory (Any Microsoft Entra ID tenant - Multitenant)
                    </label>
                </div>

                <div class="flex items-start gap-2">
                    <input class="radio radio-sm mt-0.5 r-auth" type="radio" name="authority" id="authorityCommon"
                        value="common" {{#if authorityCommon}}checked{{/if}}>
                    <label class="label-text p-0" for="authorityCommon">
                        Accounts in any organizational directory (Any Microsoft Entra ID tenant - Multitenant) and
                        personal Microsoft accounts (e.g. Skype, Xbox)
                    </label>
                </div>

                <div class="flex items-start gap-2">
                    <input class="radio radio-sm mt-0.5 r-auth" type="radio" name="authority" id="authorityConsumers"
                        value="consumers" {{#if authorityConsumers}}checked{{/if}}>
                    <label class="label-text p-0" for="authorityConsumers">
                        Personal Microsoft accounts only
                    </label>
                </div>

                <div class="flex items-start gap-2">
                    <input class="radio radio-sm mt-0.5 r-auth" type="radio" name="authority" id="authorityTenant"
                        value="tenant" {{#if authorityTenant}}checked{{/if}}>
                    <label class="label-text p-0" for="authorityTenant">
                        Accounts in the specified organizational directory only (Single tenant)
                    </label>
                </div>
            </div>
        </div>

        <div>
            {{#> ui/form-field id="tenant" label="Directory (tenant) ID" error=errors.tenant}}
            <input type="text" class="input{{#if errors.tenant}} is-invalid{{/if}}" id="tenant" name="tenant"
                value="{{values.tenant}}" />
            <span class="helper-text">Fill this value if you checked "Accounts in the specified organizational
                directory only" above. The Directory ID is a UUID value like
                "f8cdef31-a31e-4b4a-93e4-5f571e91255a"</span>
            {{/ui/form-field}}
        </div>
        {{/if}}



        <div>
            {{#> ui/form-field id="redirectUrl" label="Redirect URL" error=errors.redirectUrl}}
            <input type="url" class="input{{#if errors.redirectUrl}} is-invalid{{/if}}" id="redirectUrl"
                name="redirectUrl" value="{{values.redirectUrl}}" required />
            <span class="helper-text">Redirect URL for OAuth2. If you are using EmailEngine's OAuth2 flow, then set it
                to <code>{{defaultRedirectUrl}}</code></span>
            {{/ui/form-field}}
        </div>
        {{/if}}

    </div>
</div>

{{#if activeGmailService}}

<div class="card bg-base-100 shadow-md mb-6">

    <div class="card-header">
        <h6 class="card-title text-primary">Base scopes</h6>
    </div>

    <div class="overflow-x-auto">
        <table class="table">

            <thead>
                <tr>
                    <th>Type</th>
                    <th>Description</th>
                    <th>Requirements</th>

                </tr>

            </thead>
            <tbody>

                {{#if actionCreate}}
                <tr>
                    <td>
                        <div class="flex items-center gap-2">
                            <input class="radio radio-sm base-scopes-radio" type="radio" name="baseScopes"
                                id="baseScopesImap" value="imap" {{#if baseScopesImap}}checked{{/if}}>
                            <label class="label-text p-0" for="baseScopesImap">
                                IMAP and SMTP
                            </label>
                        </div>
                    </td>
                    <td>Regular email protocols</td>
                    <td><code>"https://mail.google.com/"</code> consent screen scope</td>

                </tr>
                <tr>
                    <td>
                        <div class="flex items-center gap-2">
                            <input class="radio radio-sm base-scopes-radio" type="radio" name="baseScopes"
                                id="baseScopesPubsub" value="pubsub" {{#if baseScopesPubsub}}checked{{/if}}>
                            <label class="label-text p-0" for="baseScopesPubsub">
                                Cloud Pub/Sub {{> ui/badge label="beta" variant="neutral"}}
                            </label>
                        </div>
                    </td>
                    <td>Webhook management</td>
                    <td><code>"Pub/Sub Admin"</code> service credentials role</td>

                </tr>

                {{else}}
                {{#if baseScopesImap}}
                <tr>
                    <td>
                        <strong>IMAP and SMTP</strong>
                    </td>
                    <td>Regular email protocols</td>
                    <td><code>"https://mail.google.com/"</code> consent screen scope</td>

                </tr>
                {{/if}}

                {{#if baseScopesPubsub}}
                <tr>
                    <td>
                        <strong>Cloud Pub/Sub</strong> {{> ui/badge label="beta" variant="neutral"}}
                    </td>
                    <td>Webhook management</td>
                    <td><code>"Pub/Sub Admin"</code> service credentials role</td>

                </tr>
                {{/if}}

                {{/if}}
            </tbody>

        </table>
    </div>

    <div id="select-pubsub-app"
        class="card-footer border-base-content/10 border-t px-6 py-[1rem]{{#unless baseScopesPubsub}} hidden{{/unless}}">

        {{#if actionCreate}}

        <div class="mb-[1rem]">
            {{#> ui/form-field id="googleTopicName" label="Google Pub/Sub Topic Name" error=errors.googleTopicName}}
            <input type="text" class="input{{#if errors.googleTopicName}} is-invalid{{/if}}" id="googleTopicName"
                name="googleTopicName" value="{{values.googleTopicName}}"
                placeholder="Enter the Topic Name for the Google Pub/Sub subscription, for example &quot;ee-pub-12345&quot;" />
            <span class="helper-text">OAuth2 Pub/Sub Topic Name. Automatically generated if not set.</span>
            {{/ui/form-field}}
        </div>

        <div>
            {{#> ui/form-field id="googleSubscriptionName" label="Google Pub/Sub Subscription Name"
            error=errors.googleSubscriptionName}}
            <input type="text" class="input{{#if errors.googleSubscriptionName}} is-invalid{{/if}}"
                id="googleSubscriptionName" name="googleSubscriptionName" value="{{values.googleSubscriptionName}}"
                placeholder="Enter the Subscription Name for the Google Pub/Sub subscription, for example &quot;ee-sub-12345&quot;" />
            <span class="helper-text">OAuth2 Pub/Sub Subscription Name. Automatically generated if not set.</span>
            {{/ui/form-field}}
        </div>

        {{else}}

        <dl class="ee-dl">

            <dt>Pub/Sub Topic</dt>
            <dd>
                {{#if appData.pubSubTopic}}

                <code>{{lastVal appData.pubSubTopic "/"}}</code>
                {{else}}
                Not initialized
                {{/if}}
            </dd>


            <dt>Pub/Sub Subscription</dt>
            <dd>
                {{#if appData.pubSubSubscription}}
                <code>{{lastVal appData.pubSubSubscription "/"}}</code>
                {{else}}
                Not initialized
                {{/if}}
            </dd>
        </dl>


        {{/if}}

    </div>

</div>
{{/if}}

{{#if activeGmail}}

