<ul class="accordion menu menu-sm w-full gap-1 p-3">

    {{> ui/menu-item href="/admin" label="Dashboard" icon="icon-[tabler--dashboard] size-4.5" active=menuDashboard}}

    <!-- Section heading -->
    <li class="text-base-content/50 mt-2 p-2 text-xs uppercase">System</li>

    {{> ui/menu-item href="/admin/swagger" label="API Reference" icon="icon-[tabler--file-code] size-4.5" active=menuSwagger}}
    {{> ui/menu-item href="/admin/accounts" label="Email Accounts" icon="icon-[tabler--users] size-4.5" active=menuAccounts}}
    {{> ui/menu-item href="/admin/gateways" label="Email Gateways" icon="icon-[tabler--send] size-4.5" active=menuGateways}}
    {{> ui/menu-item href="/admin/tokens" label="Access Tokens" icon="icon-[tabler--key] size-4.5" active=menuTokens}}
    {{> ui/menu-item href="/admin/templates" label="Email Templates" icon="icon-[tabler--template] size-4.5" active=menuTemplates}}
    {{> ui/menu-item href="/admin/webhooks" label="Webhook Routing" icon="icon-[tabler--webhook] size-4.5" active=menuWebhooks}}

    {{#> ui/menu-section id="menu-tools" label="Tools" icon="icon-[tabler--tools] size-4.5" active=menuTools}}
    {{> ui/menu-item href="/admin/bull-board" label="Job Queue" icon="icon-[tabler--stack-2] size-4" active=menuToolsArena}}
    {{> ui/menu-item href="/admin/internals" label="Workers" icon="icon-[tabler--cpu] size-4" active=menuToolsInternals}}
    {{/ui/menu-section}}

    {{#> ui/menu-section id="menu-config" label="Configuration" icon="icon-[tabler--settings] size-4.5" active=menuConfig}}
    {{> ui/menu-item href="/admin/config/service" label="General Settings" active=menuConfigService}}
    {{> ui/menu-item href="/admin/config/webhooks" label="Webhooks" active=menuConfigWebhooks}}
    {{> ui/menu-item href="/admin/config/ai" label="AI Processing" active=menuConfigAi}}
    {{> ui/menu-item href="/admin/config/oauth" label="OAuth2" active=menuConfigOauth}}
    {{> ui/menu-item href="/admin/config/logging" label="Logging" active=menuConfigLogging}}
    {{> ui/menu-item href="/admin/config/network" label="Network" active=menuConfigNetwork}}
    {{> ui/menu-item href="/admin/config/smtp" label="SMTP Interface" active=menuConfigSmtp}}
    {{> ui/menu-item href="/admin/config/imap-proxy" label="IMAP Proxy" active=menuConfigImapProxy}}

    {{#if showDocumentStore}}
    {{> ui/menu-item href="/admin/config/document-store" label="Document Store" active=menuConfigDocumentStore}}
    {{/if}}

    <li>
        <a class="inline-flex w-full items-center px-2{{#if menuConfigLicense}} menu-active{{/if}}"
            href="/admin/config/license">
            <span class="grow">License</span>
            {{#unless licenseInfo.active}}
            <span class="tooltip [--placement:top] inline-flex">
                <span class="tooltip-toggle icon-[tabler--alert-triangle] text-warning size-4 shrink-0"></span>
                <span class="tooltip-content tooltip-shown:opacity-100 tooltip-shown:visible" role="tooltip">
                    <span class="tooltip-body">License not activated</span>
                </span>
            </span>
            {{/unless}}
        </a>
    </li>
    {{/ui/menu-section}}

</ul>
