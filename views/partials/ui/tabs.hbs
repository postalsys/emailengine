{{!--
    ui/tabs - FlyonUI tab strip. Block form only; the block holds ui/tab items:
      {{#> ui/tabs label="Template content"}}
      {{> ui/tab target="html" label="HTML" active=true}}
      {{> ui/tab target="text" label="Plain text"}}
      {{/ui/tabs}}
    Params:
      label - aria-label describing the strip (required)
      id    - element id (optional)
      class - extra classes on the nav, e.g. "mb-4" (optional)
    Panels are the caller's responsibility: each ui/tab target must match a
    tabpanel element with that id (role="tabpanel" aria-labelledby="<target>-tab").
    The auth-method tabs in oauth_form.hbs intentionally do NOT use this partial -
    they run a custom script instead of the FlyonUI data-tabs plugin.
--}}
<nav class="tabs tabs-bordered{{#if class}} {{class}}{{/if}}" aria-label="{{label}}" role="tablist"{{#if id}} id="{{id}}"{{/if}} data-tabs>
    {{!-- own hash params neutralized against fallthrough into the block --}}
    {{> @partial-block label="" id="" class=""}}
</nav>
