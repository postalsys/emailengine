{{!--
    ui/badge - status badge.
    Params:
      label   - badge text (required unless block form is used)
      variant - FlyonUI color: primary|secondary|accent|neutral|info|success|warning|error
                (default neutral; the legacy "danger" normalizes to error via eeColor)
      soft    - true for the soft (tinted) style
      icon    - full iconify class (optional)
      id      - element id (optional)
      class   - extra classes, e.g. "state-info" hooks (optional)
--}}
<span {{#if id}}id="{{id}}" {{/if}}class="badge badge-{{eeColor variant}}{{#if soft}} badge-soft{{/if}}{{#if class}} {{class}}{{/if}}">
    {{~#if icon}}<span class="{{icon}} size-3.5 shrink-0"></span>{{/if~}}
    {{~#if label includeZero=true}}{{label}}{{else if @partial-block}}{{> @partial-block label="" variant="" soft="" icon="" id="" class=""}}{{/if~}}
</span>
