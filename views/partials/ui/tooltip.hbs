{{!--
    ui/tooltip - FlyonUI hover tooltip around arbitrary trigger content.
    Block form only; the block is the visible trigger:
      {{#> ui/tooltip text="Explanation shown on hover"}}<span>trigger</span>{{/ui/tooltip}}
    Compose interpolated bodies with the concat helper:
      {{#> ui/tooltip text=(concat "Up to " (formatInteger n locale) " lines")}}...{{/ui/tooltip}}
    Params:
      text      - tooltip body text; when empty the block renders bare, with
                  no tooltip chrome (no empty bubble on hover). NB: callers
                  whose page scripts locate the bubble via closest('.tooltip')
                  (e.g. the TLS cert labels) must guarantee non-empty text,
                  or the wrapper their script expects will not exist
      placement - top|bottom|left|right (default top; the [--placement:*]
                  classes are safelisted in app.tailwind.css)
      class     - extra classes on the wrapper (optional)
--}}
{{#if text}}
<span class="tooltip [--placement:{{#if placement}}{{placement}}{{else}}top{{/if}}] inline-flex{{#if class}} {{class}}{{/if}}">
    {{!-- own hash params neutralized against fallthrough into the block --}}
    <span class="tooltip-toggle cursor-default">{{> @partial-block text="" placement="" class=""}}</span>
    <span class="tooltip-content tooltip-shown:opacity-100 tooltip-shown:visible" role="tooltip">
        <span class="tooltip-body">{{text}}</span>
    </span>
</span>
{{else}}
{{> @partial-block text="" placement="" class=""}}
{{/if}}
