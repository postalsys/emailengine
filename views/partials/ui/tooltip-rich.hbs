{{!--
    ui/tooltip-rich - FlyonUI hover tooltip with a rich HTML body.
    Counterpart to ui/tooltip (which takes a plain-text body around an
    arbitrary trigger): here the block is the BODY markup and the trigger
    is an icon:
      {{#> ui/tooltip-rich icon="icon-[tabler--info-circle]"}}
      <ul class="popover-list">...</ul>
      {{/ui/tooltip-rich}}
    Params:
      icon      - full iconify class for the trigger icon (required unless
                  label is set)
      label     - underlined trigger text, used instead of an icon (optional)
      placement - top|bottom|left|right (default top; the [--placement:*]
                  classes are safelisted in app.tailwind.css)
      class     - extra classes on the wrapper (optional)
--}}
<span class="tooltip [--placement:{{#if placement}}{{placement}}{{else}}top{{/if}}] inline-flex{{#if class}} {{class}}{{/if}}">
    {{!-- muted trigger icon: same affordance color as ui/checkbox help icons --}}
    <span class="tooltip-toggle cursor-default">{{#if label}}<span class="underline">{{label}}</span>{{else}}<span
            class="{{icon}} size-4 align-text-bottom text-base-content/50"></span>{{/if}}</span>
    <span class="tooltip-content tooltip-shown:opacity-100 tooltip-shown:visible" role="tooltip">
        {{!-- own hash params neutralized against fallthrough into the block --}}
        {{!-- block display: the body may carry block content (lists, images);
              an inline span fragments its background around block children --}}
        <span class="tooltip-body text-start block">{{> @partial-block icon="" label="" placement="" class=""}}</span>
    </span>
</span>
