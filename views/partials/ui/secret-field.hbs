{{!--
    ui/secret-field - password input with a FlyonUI HSTogglePassword reveal
    button, rendered as a join group. The plugin toggles `active` on the
    button; the vendor password-active: variant swaps the eye/eye-off icons.
      {{> ui/secret-field id="smtpServerPassword" value=values.smtpServerPassword
          error=errors.smtpServerPassword toggleId="showPassword"}}
    Params:
      id          - input element id, also the reveal target (required; must be
                    a literal - the browser decodes HTML entities before the
                    plugin JSON.parses the data-toggle-password attribute, so
                    Handlebars escaping does not protect that context)
      name        - input name (defaults to id)
      value       - current value (optional)
      placeholder - input placeholder (optional; only shows while empty)
      error       - truthy adds is-invalid to the input
      inputClass  - extra classes on the input (optional)
      toggleId    - reveal button id (required; used by page scripts/tests)
      toggleLabel - reveal button aria-label (default "Show password")
--}}
<div class="join w-full">
    <input type="password"
        class="input join-item grow{{#if inputClass}} {{inputClass}}{{/if}}{{#if error}} is-invalid{{/if}}" id="{{id}}"
        name="{{#if name}}{{name}}{{else}}{{id}}{{/if}}" value="{{value}}"
        {{#if placeholder}}placeholder="{{placeholder}}" {{/if}}data-lpignore="true" autocomplete="off" />
    <button class="btn btn-outline btn-primary join-item" type="button" id="{{toggleId}}"
        data-toggle-password='{"target": "#{{id}}"}'
        aria-label="{{#if toggleLabel}}{{toggleLabel}}{{else}}Show password{{/if}}"><span
            class="icon-[tabler--eye] size-4 password-active:hidden"></span><span
            class="icon-[tabler--eye-off] size-4 hidden password-active:inline-block"></span></button>
</div>
