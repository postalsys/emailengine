{{!--
    ui/secret-field - password input with a FlyonUI HSTogglePassword reveal
    button and a copy-to-clipboard button, rendered as a join group. The plugin
    toggles `active` on the reveal button; the vendor password-active: variant
    swaps the eye/eye-off icons. Both buttons only act on a present value, so
    the input carries an or-else-all rule (static/js/app.js) that keeps them
    disabled while it is empty.
      {{> ui/secret-field id="smtpServerPassword" value=values.smtpServerPassword
          error=errors.smtpServerPassword toggleId="showPassword"}}
    Params:
      id          - input element id, also the reveal/copy target (required;
                    must be a literal - the browser decodes HTML entities before
                    the plugin JSON.parses the data-toggle-password attribute,
                    so Handlebars escaping does not protect that context)
      name        - input name (defaults to id)
      value       - current value (optional)
      placeholder - input placeholder (optional; only shows while empty)
      error       - truthy adds is-invalid to the input
      inputClass  - extra classes on the input (optional)
      toggleId    - reveal button id (required; used by page scripts/tests)
      toggleLabel - reveal button aria-label (default "Show password")
--}}
<div class="join w-full secret-field">
    <input type="password"
        class="input join-item grow or-else-all{{#if inputClass}} {{inputClass}}{{/if}}{{#if error}} is-invalid{{/if}}"
        id="{{id}}" data-target="secret-btns-{{id}}"
        name="{{#if name}}{{name}}{{else}}{{id}}{{/if}}" value="{{value}}"
        {{#if placeholder}}placeholder="{{placeholder}}" {{/if}}data-lpignore="true" autocomplete="off" />
    {{!-- solid primary: matches the attached copy button in ui/copy-field --}}
    <button class="btn btn-primary join-item secret-btns-{{id}}" type="button" id="{{toggleId}}"
        data-toggle-password='{"target": "#{{id}}"}'
        aria-label="{{#if toggleLabel}}{{toggleLabel}}{{else}}Show password{{/if}}"><span
            class="icon-[tabler--eye] size-4 password-active:hidden"></span><span
            class="icon-[tabler--eye-off] size-4 hidden password-active:inline-block"></span></button>
    {{> ui/copy-btn target=id join=true btnClass=(concat "secret-btns-" id)}}
</div>
