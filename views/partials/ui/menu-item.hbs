{{!--
    ui/menu-item - one sidebar menu link (an <li> inside a FlyonUI .menu list).
    Params:
      href     - link target (required)
      label    - link text (required)
      icon     - full iconify class incl. size, e.g. "icon-[tabler--users] size-4.5" (optional)
      active   - true to highlight as the current page
      warnText - when non-empty, renders a trailing warning icon whose tooltip
                 shows this text (optional)
--}}
<li>
    <a class="inline-flex w-full items-center px-2{{#if active}} menu-active{{/if}}" href="{{href}}">
        {{#if icon}}<span class="{{icon}}"></span>{{/if}}
        {{#if warnText}}
        <span class="grow">{{label}}</span>
        {{#> ui/tooltip text=warnText class="shrink-0"}}
        <span class="icon-[tabler--alert-triangle] text-warning size-4 shrink-0"></span>
        {{/ui/tooltip}}
        {{else}}
        <span>{{label}}</span>
        {{/if}}</a>
</li>
