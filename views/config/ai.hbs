{{> ui/page-header title="AI Processing" icon="icon-[tabler--robot]" class="mb-1"}}

<p class="mb-6">Process incoming emails with AI to extract insights and enrich your data. EmailEngine sends email
    content to OpenAI and adds the AI response to your webhooks.
</p>

<form method="post" id="settings-form" action="/admin/config/ai">
    {{!-- no id: the layout already renders the #crumb element the script reads --}}
    <input type="hidden" name="crumb" value="{{crumb}}" />
    <input type="hidden" id="fn-content-element" name="contentFnJson" value="{{values.contentFnJson}}">

    <div class="card bg-base-100 shadow-md mb-6" id="openai_settings">
        <div class="card-header">
            <h6 class="card-title text-primary">AI Configuration</h6>
        </div>

        {{#if openAiError}}
        <div class="card-body pb-0">
            {{!-- dismissable error alert: app.js binds the close button
                  directly and clears the stored error server-side --}}
            <div class="alert alert-soft alert-error clear-alert-btn block mb-0" data-clear-alert="open-ai">
                <button type="button" class="close float-right" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>

                <p><strong>OpenAI Error</strong></p>
                <p>The last API request failed:</p>
                <hr class="my-2">
                <p class="mb-0">
                    <code>{{openAiError.message}}{{#if openAiError.code}} ({{openAiError.code}}){{/if}}</code>
                </p>
            </div>
        </div>
        {{/if}}

        <div class="px-6 py-[1rem] border-b border-base-content/10 flex items-start justify-between gap-4">
            <div>
                <div class="flex items-center gap-2">
                    <input type="checkbox" class="checkbox checkbox-sm{{#if errors.generateEmailSummary}} is-invalid{{/if}}"
                        id="generateEmailSummary" name="generateEmailSummary" {{#if
                        values.generateEmailSummary}}checked{{/if}} />
                    <label class="label-text p-0" for="generateEmailSummary">Enable AI Email Processing</label>
                    {{#> ui/tooltip-rich icon="icon-[tabler--info-circle]"}}
                    <strong>Privacy Notice</strong><br>
                    Email text is sent to OpenAI's servers for processing. While OpenAI doesn't use this data for
                    training, ensure this aligns with your privacy policies and user agreements.
                    {{/ui/tooltip-rich}}
                </div>
                {{#if errors.generateEmailSummary}}
                <span class="helper-text text-error">{{errors.generateEmailSummary}}</span>
                {{/if}}
                <span class="helper-text">Process new emails with AI and include the results in
                    <code>messageNew</code> webhooks.</span>
            </div>

            <div class="text-end space-y-1">
                {{> ui/setting-ref name="generateEmailSummary" class="whitespace-nowrap"}}
                {{#if values.generateEmailSummary}}
                {{> ui/badge label="enabled" variant="success" pill=true}}
                {{else}}
                {{> ui/badge label="disabled" variant="warning" pill=true}}
                {{/if}}
            </div>
        </div>
        <div class="card-body space-y-4">


            <div>
                {{> ui/setting-ref name="openAiAPIKey"}}
                {{#> ui/form-field id="openAiAPIKey" label="API Key" error=errors.openAiAPIKey}}
                <input type="password" class="input{{#if errors.openAiAPIKey}} is-invalid{{/if}}" id="openAiAPIKey"
                    name="openAiAPIKey" value="{{values.openAiAPIKey}}" data-lpignore="true" autocomplete="off" {{#if
                    hasOpenAiAPIKey}} placeholder="Key is set (hidden for security)" {{/if}} />
                <span class="helper-text">Your OpenAI API key for authentication.</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="openAiModel"}}

                <div class="flex items-center gap-2">
                    <label class="label-text" for="settingsServiceOpenAiModel">AI Model</label>

                    {{> ui/btn label="Refresh Models" style="text" size="sm" id="reload-models-btn"
                    icon="icon-[tabler--refresh] reload-icon"}}
                </div>

                <select id="settingsServiceOpenAiModel" class="select select-sm max-w-md{{#if errors.openAiModel}} is-invalid{{/if}}"
                    name="openAiModel">
                    {{#each openAiModels}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                </select>
                {{#if errors.openAiModel}}
                <span class="helper-text text-error">{{errors.openAiModel}}</span>
                {{/if}}
                <span class="helper-text">Choose the AI model for processing. Ensure your API key has access to the
                    selected model.</span>
            </div>

            <div>
                {{> ui/setting-ref name="openAiAPIUrl"}}
                {{#> ui/form-field id="openAiAPIUrl" label="API Endpoint" error=errors.openAiAPIUrl}}
                <input type="url" class="input{{#if errors.openAiAPIUrl}} is-invalid{{/if}}" id="openAiAPIUrl"
                    name="openAiAPIUrl" value="{{values.openAiAPIUrl}}" placeholder="https://api.openai.com" />
                <span class="helper-text">Custom API endpoint. Leave empty for default OpenAI servers.</span>
                {{/ui/form-field}}
            </div>

        </div>
    </div>

    <div class="card bg-base-100 shadow-md mb-6" id="filtering_settings">
        <div class="card-header">
            <h6 class="card-title text-primary">Email Filtering</h6>
        </div>
        <div class="card-body">

            {{#if errorLog}}
            <nav class="tabs tabs-bordered mb-[1rem]" aria-label="Email filtering" role="tablist" id="myTab" data-tabs>
                <button type="button" class="tab active-tab:tab-active active" id="fn-tab" data-tab="#fn" role="tab" aria-controls="fn"
                    aria-selected="true">Filter Rules</button>
                <button type="button" class="tab active-tab:tab-active" id="errors-tab" data-tab="#errors" role="tab" aria-controls="errors"
                    aria-selected="false">Error Log</button>
            </nav>
            {{/if}}

            <div id="myTabContent">
                <div id="fn" role="tabpanel" aria-labelledby="fn-tab">

                    <div>
                        <div class="text-base-content/60 float-right code-link">[<a
                                href="https://emailengine.app/pre-processing-functions" target="_blank"
                                rel="noopener noreferrer" referrerpolicy="no-referrer"
                                class="link link-animated">documentation</a>]

                            [<a href="/admin/swagger#/Settings/postV1Settings" target="_blank" rel="noopener noreferrer"
                                referrerpolicy="no-referrer" class="link link-animated">openAiPreProcessingFn</a>]
                        </div>
                        <label class="label-text" for="editor-fn">Filter Function</label>
                        <div class="mb-2 leading-tight">
                            <small>JavaScript code to decide which emails to process. Return <code>true</code> to
                                process the email, <code>false</code> to skip. The email data is available as
                                <code>payload</code>.</small>
                        </div>
                        <div id="editor-fn" class="code-editor"></div>
                        <div class="editor-embed-block">
                            <div class="editor-embed-content editor-embed-content-left">
                                Email filter
                            </div>
                            <div class="editor-embed-content editor-embed-content-left editor-embed-content-right">
                                <a href="#" class="toggle-fullscreen" data-target="editor-fn">Toggle fullscreen</a>
                            </div>
                            <div class="editor-embed-content editor-embed-content-left editor-embed-content-right">
                                <a href="#" id="test-payload-btn">Test with sample data</a>
                            </div>

                            <div class="editor-embed-content editor-embed-content-right editor-embed-content-left">
                                Result:
                                <span id="filter-res" class="text-info">no match</span>
                            </div>

                            <div class="editor-embed-content editor-embed-content-right">
                                {{> editor_scope_info}}
                            </div>

                        </div>

                    </div>

                </div>


                {{#if errorLog}}
                <div id="errors" class="hidden" role="tabpanel" aria-labelledby="errors-tab">


                    <p class="mb-[1rem]">Recent errors from the filter function execution:</p>

                    <div class="overflow-x-auto">
                        <table class="table">

                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th width="40%">Error</th>
                                    <th width="40%">Email Data</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each errorLog}}

                                <tr>

                                    <td>
                                        <span class="relative-time" data-time="{{created}}"></span>
                                    </td>

                                    <td>
                                        <textarea class="error-log-field" readonly>{{error}}</textarea>
                                    </td>

                                    <td>
                                        <textarea class="error-log-field" readonly>{{json payload}}</textarea>
                                    </td>

                                </tr>

                                {{/each}}
                            </tbody>

                        </table>
                    </div>

                </div>
                {{/if}}

            </div>

        </div>
    </div>

    <div id="prompt_settings" class="card bg-base-100 shadow-md mb-6">
        <div class="card-header flex items-center justify-between">
            <h6 class="card-title text-primary">AI Instructions</h6>
            {{> ui/btn label="Reset to default" variant="neutral" style="soft" size="sm"
            icon="icon-[tabler--arrow-back-up]" id="prompt-reset-btn"}}
        </div>
        <div class="card-body space-y-4">

            <div>
                {{> ui/setting-ref name="openAiPrompt"}}

                <label class="label-text">AI Prompt</label>

                <input type="hidden" class="{{#if errors.openAiPromptElement}}is-invalid{{/if}}"
                    id="openAiPromptElement" name="openAiPrompt" value="{{values.openAiPrompt}}">

                <div id="editor-prompt" class="code-editor"></div>

                <div class="editor-embed-block">
                    <div class="editor-embed-content editor-embed-content-left">
                        System prompt
                    </div>
                    <div class="editor-embed-content editor-embed-content-left editor-embed-content-right">
                        <a href="#" class="toggle-fullscreen" data-target="editor-prompt">Toggle fullscreen</a>
                    </div>
                    <div class="editor-embed-content editor-embed-content-right">
                        <a href="#" id="prompt-try-btn">Test with email file</a>
                    </div>
                </div>

                {{#if errors.openAiPrompt}}
                <span class="helper-text text-error">{{errors.openAiPrompt}}</span>
                {{/if}}

                <span class="helper-text">Instructions for the AI. Must specify which JSON properties to return in the
                    response.</span>
            </div>

            <div>
                {{> ui/setting-ref name="openAiTemperature"}}
                {{#> ui/form-field id="settingsOpenAiTemperature" label="Temperature" error=errors.openAiTemperature}}
                <input type="number" class="input text-list{{#if errors.openAiTemperature}} is-invalid{{/if}}"
                    id="settingsOpenAiTemperature" step="0.001" min="0" max="2" name="openAiTemperature"
                    value="{{values.openAiTemperature}}" />
                <span class="helper-text">Controls randomness (0-2). Lower = more focused, higher = more creative. <a
                        href="https://platform.openai.com/docs/api-reference/chat/create#temperature" target="_blank"
                        rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">Learn
                        more</a></span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="openAiTopP"}}
                {{#> ui/form-field id="settingsOpenAiTopP" label="Top-p" error=errors.openAiTopP}}
                <input type="number" class="input text-list{{#if errors.openAiTopP}} is-invalid{{/if}}"
                    id="settingsOpenAiTopP" step="0.001" min="0" max="1" name="openAiTopP"
                    value="{{values.openAiTopP}}" />
                <span class="helper-text">Alternative to temperature (0-1). Controls diversity of word choices. <a
                        href="https://platform.openai.com/docs/api-reference/chat/create#top_p" target="_blank"
                        rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">Learn
                        more</a></span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="openAiMaxTokens"}}
                {{#> ui/form-field id="settingsOpenAiMaxTokens" label="Max Tokens" error=errors.openAiMaxTokens}}
                <input type="number" class="input text-list{{#if errors.openAiMaxTokens}} is-invalid{{/if}}"
                    id="settingsOpenAiMaxTokens" step="1" min="0" name="openAiMaxTokens"
                    value="{{values.openAiMaxTokens}}" />
                <span class="helper-text">Maximum tokens limit for OpenAI API requests. EmailEngine composes the full
                    prompt from: the user prompt text (above), system prompt describing the AI role, JSON schema
                    definition, and the structured email data. If the combined prompt exceeds this limit, EmailEngine
                    automatically shortens the email content until it fits. Defaults: GPT-5: 18000, GPT-4: 6500,
                    GPT-3.5: 3000.</span>
                {{/ui/form-field}}
            </div>

        </div>
    </div>

    <div class="mb-6">
        {{> ui/btn label="Save Changes" type="submit" icon="icon-[tabler--settings]"}}
    </div>

</form>

{{#> ui/modal id="testPromptModal" title="Test AI Processing" titleId="testPromptModalLabel" dialogClass="max-w-3xl"}}
<div class="modal-body">
    <p class="mb-2">
        Upload an email file (.eml) to test your AI configuration.
    </p>

    <div id="testPromptError" class="hidden">
        <div class="alert alert-soft alert-error"></div>
    </div>
    <div id="testPromptResponse" class="hidden">
        <pre
            class="content max-h-[350px] overflow-auto border border-base-300 rounded-field p-2 text-base-content/70"></pre>
    </div>

</div>
<div class="modal-footer">

    {{> ui/btn label="Close" variant="neutral" style="soft" overlay="#testPromptModal"}}
    <button type="button" id="prompt-test-btn" class="btn btn-primary">
        <span class="icon-[tabler--flask] size-4" id="prompt-test-btn-icon"></span>
        Choose File and Test
    </button>

</div>
{{/ui/modal}}

{{#> ui/modal id="setPayloadModal" title="Test Filter" titleId="setPayloadModalLabel" dialogClass="max-w-3xl"}}
<div class="modal-body">

    <div class="mb-2">Sample email data (JSON)</div>
    <div id="editor-json" class="code-editor h-40"></div>
    <span class="helper-text" id="inputToHelp">Edit the test data to see if your filter matches.</span>

</div>
<div class="modal-footer justify-between">
    <div>
        <select class="select select-sm" id="select-predefined-payload">
            <option>Load example...</option>
        </select>
    </div>
    {{> ui/btn label="Close" variant="neutral" style="soft" overlay="#setPayloadModal"}}
</div>
{{/ui/modal}}

<script src="/static/js/ace/ace.js"></script>

<input type="hidden" id="examplePayloadsJson" value="{{examplePayloadsJson}}">
<input type="hidden" id="scriptEnvJson" value="{{scriptEnvJson}}">
<input type="hidden" id="defaultPromptJson" value="{{defaultPromptJson}}">

<script>
    document.addEventListener('DOMContentLoaded', () => {

        let scriptEnv = JSON.parse(document.getElementById('scriptEnvJson').value);
        const evaluationWorker = new Worker('/static/js/evaluation-worker.js');

        const editors = new Map();

        const editorFn = ace.edit("editor-fn", {
            enableBasicAutocompletion: true,
            enableSnippets: true,
            enableLiveAutocompletion: true,
            useWorker: false
        });
        editors.set("editor-fn", editorFn);

        editorFn.setTheme("ace/theme/xcode");
        editorFn.session.setMode("ace/mode/javascript");
        editorFn.setValue(JSON.parse(document.getElementById('fn-content-element').value));

        editorFn.session.on('changeMode', function (e, session) {
            if ("ace/mode/javascript" === session.getMode().$id) {
                if (!!session.$worker) {
                    session.$worker.send("setOptions", [JSHINT_OPTS]);
                }
            }
        });

        const editorPrompt = ace.edit("editor-prompt", {
            enableBasicAutocompletion: true,
            enableSnippets: false,
            enableLiveAutocompletion: false,
            useWorker: true
        });
        editors.set("editor-prompt", editorPrompt);

        editorPrompt.setTheme("ace/theme/xcode");
        editorPrompt.session.setMode("ace/mode/markdown");
        editorPrompt.session.setValue(document.getElementById('openAiPromptElement').value);

        document.getElementById('settings-form').addEventListener('submit', () => {
            document.getElementById('fn-content-element').value = JSON.stringify(editorFn.getValue());
            document.getElementById('openAiPromptElement').value = editorPrompt.getValue();
        });

        uiEditorFullscreen(editors);

        document.getElementById('prompt-try-btn').addEventListener('click', e => {
            e.preventDefault()
            uiModal.open('#testPromptModal');
        })

        const testPayload = { content: { account: 'test', path: 'INBOX', subject: 'test email' }, error: null };

        const updateFilterResult = (err, result, opts) => {
            let resultElm = document.getElementById('filter-res');
            if (err) {
                // also drop the initial text-info placeholder: the layered
                // text-error utility sorts before text-info in the compiled
                // CSS, so a leftover text-info would win the cascade
                resultElm.classList.remove('text-info', 'text-warning', 'text-success');
                resultElm.classList.add('text-error');
                resultElm.textContent = `error: ${err.message}`
                return;
            }

            if (result) {
                resultElm.classList.remove('text-info', 'text-warning', 'text-error');
                resultElm.classList.add('text-success');
                resultElm.textContent = `match - will process`
            } else {
                resultElm.classList.remove('text-info', 'text-success', 'text-error');
                resultElm.classList.add('text-warning');

                let truthyWarning = opts && opts.truthyWarning;
                resultElm.textContent = `no match - will skip${truthyWarning ? ` (must return true, got ${typeof truthyWarning})` : ''} `
            }
        }

        const updateExampleResult = () => {
            const filterVal = editorFn.getValue();

            let filtered;
            let mapping;

            try {
                if (testPayload.error) {
                    throw testPayload.error;
                }
                evaluationWorker.postMessage({
                    type: 'filter', code: filterVal, payload: testPayload.content, env: scriptEnv
                });
            } catch (err) {
                updateFilterResult(err);
            }
        }

        let testPromptBtn = document.getElementById('prompt-test-btn');

        let showError = message => {
            document.getElementById('testPromptError').classList.remove('hidden');
            document.getElementById('testPromptResponse').classList.add('hidden');

            document.querySelector('#testPromptError .alert').textContent = message;
        }

        let showResponse = value => {
            document.getElementById('testPromptError').classList.add('hidden');
            document.getElementById('testPromptResponse').classList.remove('hidden');

            document.querySelector('#testPromptResponse .content').textContent = value;
        }

        let clearResponses = () => {
            document.getElementById('testPromptError').classList.add('hidden');
            document.getElementById('testPromptResponse').classList.add('hidden');
        }

        async function testPromptFn() {
            let emailFile;

            clearResponses();

            try {
                emailFile = await browseFileContents('base64');
            } catch (err) {
                return showError(err.message)
            }

            let payload = {
                emailFile,
                openAiPrompt: editorPrompt.getValue(),
                openAiModel: document.getElementById('settingsServiceOpenAiModel').value,
                openAiAPIUrl: document.getElementById('openAiAPIUrl').value,
                openAiAPIKey: document.getElementById('openAiAPIKey').value,
                openAiTemperature: document.getElementById('settingsOpenAiTemperature').value,
                openAiTopP: document.getElementById('settingsOpenAiTopP').value
            };

            let res;
            try {
                res = await fetch('/admin/config/ai/test-prompt', {
                    method: 'post',
                    headers: { 'content-type': 'application/json' },
                    body: JSON.stringify({
                        crumb: document.getElementById('crumb').value,
                        ...payload
                    })
                });
            } catch (err) {
                return showError(err.message)
            }

            if (!res.ok) {
                return showError(`HTTP error! status: ${res.status}`)
            }

            const data = await res.json();
            if (!data.success) {
                return showError(data.error || 'Request failed')
            }

            showResponse(JSON.stringify(data.response, false, 2));
        }

        let iconElm = document.getElementById('prompt-test-btn-icon');
        let toggleSpinner = (enabled) => {
            if (enabled) {
                iconElm.classList.remove('icon-[tabler--loader-2]', 'animate-spin');
                iconElm.classList.add('icon-[tabler--flask]');
                testPromptBtn.disabled = false;
            } else {
                iconElm.classList.remove('icon-[tabler--flask]');
                iconElm.classList.add('icon-[tabler--loader-2]', 'animate-spin');
                testPromptBtn.disabled = true;
            }
        }

        document.getElementById('prompt-reset-btn').addEventListener('click', e => {
            e.preventDefault()

            editorPrompt.setValue(JSON.parse(document.getElementById('defaultPromptJson').value).prompt);
        });

        let runFileTest = () => {
            toggleSpinner(false)
            testPromptFn().then(() => { }).catch(err = {}).finally(() => {
                toggleSpinner(true)
            });
        }

        testPromptBtn.addEventListener('click', e => {
            e.preventDefault();
            runFileTest();
        });


        evaluationWorker.onmessage = e => {
            const { type, result, error } = e && e.data || {};

            switch (type) {
                case 'filter':
                    if (!error) {
                        updateFilterResult(null, result === true, { truthyWarning: result && result !== true ? result : false });
                    } else {
                        updateFilterResult(new Error(error));
                    }
                    break;

                case 'log': {
                    console.log(`[Worker Log] ${result.level.toUpperCase()}`, result.msg);
                    break;
                }
            }
        }

        let validateTimer = false;
        editorFn.session.on('change', function () {
            clearTimeout(validateTimer);
            validateTimer = setTimeout(updateExampleResult, 100);
        });
        editorFn.clearSelection(1);

        updateExampleResult();


        const testPayloadBtn = document.getElementById('test-payload-btn');
        testPayloadBtn.addEventListener('click', e => {
            e.preventDefault();
            uiModal.open('#setPayloadModal');
        });

        const editorJson = ace.edit("editor-json");
        editorJson.setTheme("ace/theme/xcode");
        editorJson.session.setMode("ace/mode/json");
        editorJson.session.setValue(JSON.stringify(testPayload.content, false, 4));

        editorJson.session.on('change', function (delta) {
            // delta.start, delta.end, delta.lines, delta.action
            let curval = editorJson.getValue().trim();
            try {
                if (curval) {
                    let parsed = JSON.parse(curval);
                    if (parsed && typeof parsed !== 'object') {
                        throw new Error('Not an object')
                    }
                    testPayload.content = parsed;
                }
                testPayload.error = null;
                clearTimeout(validateTimer);
                validateTimer = setTimeout(updateExampleResult, 10);
            } catch (err) {
                console.error(err);
                testPayload.error = err;
                clearTimeout(validateTimer);
                validateTimer = setTimeout(updateExampleResult, 10);
            }
        });

        let examplePayloads = JSON.parse(document.getElementById('examplePayloadsJson').value || '[]');
        const payloadSelectElm = document.getElementById('select-predefined-payload');

        try {
            if (examplePayloads && Array.isArray(examplePayloads)) {

                examplePayloads.forEach(example => {
                    let optionElm = document.createElement('option');
                    optionElm.textContent = example.name;
                    optionElm.dataset.exampleKey = example.key
                    payloadSelectElm.appendChild(optionElm)
                });
            }
        } catch (err) {
            console.error(err)
        }

        payloadSelectElm.addEventListener('change', e => {
            if (!payloadSelectElm.selectedIndex) {
                return
            }
            let key = payloadSelectElm.options[payloadSelectElm.selectedIndex].dataset.exampleKey;
            if (key) {
                let example = examplePayloads.find(data => data.key === key);
                if (example) {
                    editorJson.session.setValue(JSON.stringify(example.content, false, 4))
                }
            }
            payloadSelectElm.selectedIndex = 0;
        });

        function redrawModelList(models) {
            let selectElm = document.getElementById('settingsServiceOpenAiModel');
            let selected = selectElm.value;

            selectElm.innerHTML = '';

            for (let model of models) {
                let elm = document.createElement('option');
                elm.setAttribute('value', model.id);
                elm.textContent = model.name;
                if (model.id === selected) {
                    elm.selected = true
                }
                selectElm.appendChild(elm);
            }
        }

        let reloadBtn = document.getElementById('reload-models-btn');
        let reloadBtnIcon = document.querySelector('#reload-models-btn .reload-icon');

        const requestReload = async () => {
            const res = await fetch('/admin/config/ai/reload-models', {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value,
                    openAiAPIUrl: document.getElementById('openAiAPIUrl').value,
                    openAiAPIKey: document.getElementById('openAiAPIKey').value,
                })
            });
            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }
            const data = await res.json();

            return data;
        }

        let loading = false;
        let reloadModels = () => {
            if (loading) {
                return
            }
            loading = true
            reloadBtnIcon.classList.add('animate-spin');
            reloadBtn.disabled = true;

            requestReload().then(data => {
                loading = false
                reloadBtnIcon.classList.remove('animate-spin');
                reloadBtn.disabled = false;
                if (data.error) {
                    showToast('Failed to send payload', 'alert-triangle')
                    return;
                }

                if (data.models) {
                    redrawModelList(data.models);
                }

            }).catch(err => {
                loading = false
                reloadBtnIcon.classList.remove('animate-spin');
                reloadBtn.disabled = false;
                showToast('Request failed\n' + err.message, 'alert-triangle');
            });
        }

        reloadBtn.addEventListener('click', reloadModels);
    });


</script>
