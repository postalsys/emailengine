{{> oauth_config_header}}

{{> oauth_tabs}}

{{#if apps}}
<div class="card bg-base-100 shadow-md mb-6">
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Project ID</th>
                    <th>Topic</th>
                    <th>Subscription</th>
                    <th>Expiration</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                {{#each apps}}
                <tr class="hover:bg-base-200/60">
                    <td class="relative">
                        <a href="/admin/config/oauth/app/{{id}}" class="absolute inset-0"
                            aria-label="Open OAuth2 app"></a><strong>{{name}}</strong>
                    </td>

                    <td class="relative">
                        <a href="/admin/config/oauth/app/{{id}}" class="absolute inset-0" tabindex="-1"
                            aria-hidden="true"></a>{{googleProjectId}}
                    </td>

                    <td class="relative">
                        <a href="/admin/config/oauth/app/{{id}}" class="absolute inset-0" tabindex="-1"
                            aria-hidden="true"></a>
                        {{#if pubSubTopic}}
                        {{> ui/badge label="Created" variant="success"}}
                        {{else}}
                        {{> ui/badge label="Not set" variant="warning"}}
                        {{/if}}
                    </td>

                    <td class="relative">
                        <a href="/admin/config/oauth/app/{{id}}" class="absolute inset-0" tabindex="-1"
                            aria-hidden="true"></a>
                        {{#if pubSubSubscription}}
                        {{> ui/badge label="Created" variant="success"}}
                        {{else}}
                        {{> ui/badge label="Not set" variant="warning"}}
                        {{/if}}
                    </td>

                    <td class="relative">
                        <a href="/admin/config/oauth/app/{{id}}" class="absolute inset-0" tabindex="-1"
                            aria-hidden="true"></a>
                        {{#if expirationLabel}}
                        {{expirationLabel}}
                        {{else}}
                        <span class="text-base-content/60">-</span>
                        {{/if}}
                    </td>

                    <td class="relative">
                        <a href="/admin/config/oauth/app/{{id}}" class="absolute inset-0" tabindex="-1"
                            aria-hidden="true"></a>
                        {{!-- z-[1] lifts the badge above the row-overlay link so
                              the title tooltip is hoverable --}}
                        {{#if meta.pubSubFlag}}
                        <span class="badge badge-error relative z-[1] cursor-default"
                            title="{{meta.pubSubFlag.message}}">Error</span>
                        {{else if meta.authFlag}}
                        <span class="badge badge-warning relative z-[1] cursor-default"
                            title="{{meta.authFlag.message}}">Setup Failed</span>
                        {{else if meta.ttlWarning}}
                        <span class="badge badge-warning relative z-[1] cursor-default"
                            title="{{meta.ttlWarning.message}}">TTL Update Failed</span>
                        {{else if pubSubSubscription}}
                        {{> ui/badge label="OK" variant="success"}}
                        {{else}}
                        {{> ui/badge label="Pending" variant="warning"}}
                        {{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    {{#if showPaging}}
    <div class="card-footer border-base-content/10 border-t px-6 py-4">
        {{> ui/pagination prevPage=prevPage nextPage=nextPage pageLinks=pageLinks}}
    </div>
    {{/if}}
</div>
{{else}}
<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-body">
        <p>
            {{#if firstPage}}
            No Gmail Pub/Sub apps have been registered yet.
            {{else}}
            No Gmail Pub/Sub apps found.
            {{/if}}
        </p>
    </div>
</div>
{{/if}}

<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-header">
        <h6 class="card-title text-primary">Subscription Settings</h6>
    </div>
    <div class="card-body">
        <form method="post" action="/admin/config/oauth/subscriptions" class="space-y-4">
            <input type="hidden" name="crumb" value="{{crumb}}" />
            {{#> ui/form-field id="gmailSubscriptionTtl" label="Subscription TTL"}}
            <input type="number" class="input" id="gmailSubscriptionTtl" name="gmailSubscriptionTtl"
                value="{{values.gmailSubscriptionTtl}}" placeholder="31" min="0" max="365" />
            <span class="helper-text">
                Inactivity expiration in days. Leave empty for Google's default (31 days). Set to 0 to disable
                expiration.
            </span>
            {{/ui/form-field}}
            {{> ui/btn label="Update" type="submit" icon="icon-[tabler--device-floppy]"}}
        </form>

        <div class="alert alert-soft alert-info mt-4 mb-0 block">
            <strong>Note:</strong> Google automatically deletes Pub/Sub subscriptions that receive no activity
            for a set period. This setting controls that period for both new and existing subscriptions.
            Changes take effect the next time an OAuth app is created, updated, or its subscription is recovered.
            If a subscription does expire, EmailEngine detects this and recreates it automatically.
            No messages are lost during the gap because EmailEngine also polls the Gmail API every 10 minutes
            and uses the History API to catch up on any missed changes.
        </div>
    </div>
</div>
