{{> ui/page-header title="Webhooks" icon="icon-[tabler--webhook]"
badgeLabel=(when values.webhooksEnabled "enabled" "disabled")
badgeVariant=(when values.webhooksEnabled "success" "warning")
class="mb-1"}}

<p class="mb-6">Get real-time notifications when email events occur. Webhooks send HTTP POST requests to your server
    whenever events happen in connected accounts.</p>

{{#if values.webhooksEnabled}}
{{#if webhookErrorFlag}}
{{#> ui/clear-alert alert="webhook-default" class="mb-6"}}

    <p><strong>Webhook Error</strong></p>
    <p>The last webhook attempt failed with:</p>
    <hr class="my-2">
    <p class="mb-0">
        <code>

{{#if webhookErrorFlag.statusCode}}HTTP response: {{ webhookErrorFlag.statusCode}}{{/if}}
{{#if webhookErrorFlag.code}}[{{ webhookErrorFlag.code}}]{{/if}}
<br>
{{webhookErrorFlag.message}}

        </code>
    </p>
{{/ui/clear-alert}}
{{/if}}
{{/if}}

<form method="post" id="settings-form" action="/admin/config/webhooks">
    {{!-- no id: the layout already renders the #crumb element the script reads --}}
    <input type="hidden" name="crumb" value="{{crumb}}" />

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Webhook Processing</h6>
        </div>

        <div class="px-6 py-4 flex items-start justify-between gap-4">
            {{> ui/checkbox id="webhooks_enabled" name="webhooksEnabled" label="Enable Webhooks"
            checked=values.webhooksEnabled error=errors.webhooksEnabled
            hint="Turn on webhook notifications for email events."}}

            <div class="text-end">
                {{> ui/setting-ref name="webhooksEnabled" class="whitespace-nowrap"}}
            </div>
        </div>
    </div>

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header flex items-center justify-between">
            <h6 class="card-title text-primary">Default Webhook</h6>
            {{!-- keeps the webhooks-status hook: the or-else-all rule on the
                  URL input disables this button while the URL is empty --}}
            {{> ui/btn label="Send test webhook" variant="info" style="soft" size="sm"
            icon="icon-[tabler--cloud-upload]" id="test-payload-btn" class="webhooks-status"}}
        </div>

        <div class="card-body space-y-4">
            <div>
                {{> ui/setting-ref name="webhooks"}}
                {{#> ui/form-field id="settingsWebhooks" label="Webhook URL" error=errors.webhooks}}
                <input type="url" class="input or-else-all{{#if errors.webhooks}} is-invalid{{/if}}"
                    data-target="webhooks-status" id="settingsWebhooks" name="webhooks"
                    placeholder="https://example.com/webhooks/emailengine" value="{{values.webhooks}}" />
                <span class="helper-text">The default destination for all webhook events. Individual accounts can
                    override this with their own webhook URLs.</span>
                {{/ui/form-field}}
            </div>

            <p><strong>Event Types</strong><br>
                <small>Choose which events trigger webhooks. Be selective when managing many accounts to avoid memory
                    issues.</small>
            </p>

            <div>
                {{> ui/setting-ref name="webhookEvents" suffix='="*"'}}
                {{> ui/checkbox id="notifyAll" name="notifyAll" label="All events" class="or-else-all"
                dataTarget="event-type" checked=values.notifyAll error=errors.notifyAll}}
            </div>

            <div class="space-y-2">
                {{#each notificationTypes}}
                <div>
                    {{> ui/setting-ref name="webhookEvents" suffix=(concat '="' name '"')}}
                    {{> ui/checkbox id=(concat "notify_" name) name=(concat "notify_" name) label=description
                    labelTitle=name class="event-type" checked=checked error=error}}
                </div>

                {{#if isMessageNew}}

                <div class="ps-6">
                    {{> ui/setting-ref name="inboxNewOnly"}}
                    {{> ui/checkbox id="inboxNewOnly" name="inboxNewOnly"
                    label="Only trigger for incoming emails (skip sent/drafts)" checked=../values.inboxNewOnly
                    error=../errors.inboxNewOnly}}
                </div>

                {{/if}}
                {{/each}}
            </div>
        </div>
    </div>

    {{#> ui/details summary="Custom Headers" summarySmall="(Default webhook only)"
    class="card bg-base-100 shadow-md mb-6" open=values.customHeaders}}

    <p class="mb-4">Add authentication tokens or other headers to webhook requests.</p>

    <div>
        {{> ui/setting-ref name="webhooksCustomHeaders"}}
        {{#> ui/form-field id="customHeaders" label="HTTP Headers" error=errors.customHeaders}}
        <textarea class="textarea w-full font-mono{{#if errors.customHeaders}} is-invalid{{/if}}" id="customHeaders"
            name="customHeaders" rows="5" spellcheck="false" data-enable-grammarly="false"
            placeholder="Authorization: Bearer your-secret-token&#10;X-Custom-Header: value">{{values.customHeaders}}</textarea>
        <span class="helper-text">One header per line. Format: <code>Header-Name: value</code></span>
        {{/ui/form-field}}
    </div>

    {{/ui/details}}

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Email Headers
                <small class="text-base-content/60 font-normal">(All webhooks)</small>
            </h6>
        </div>
        <div class="card-body space-y-4">

            <p>Include specific email headers in webhook payloads. Basic headers (From, To, Message-ID) are always
                included.</p>

            <div>
                {{> ui/setting-ref name="notifyHeaders" suffix='="*"'}}
                {{> ui/checkbox id="headers_all" name="headersAll" label="Include all headers" class="or-else-all"
                dataTarget="header-list" checked=values.headersAll error=errors.headersAll}}
            </div>

            <div>
                {{> ui/setting-ref name="notifyHeaders"}}
                {{#> ui/form-field id="settingsNotifyHeaders" label="Specific Headers" error=errors.notifyHeaders}}
                <textarea class="textarea w-full header-list{{#if errors.notifyHeaders}} is-invalid{{/if}}"
                    id="settingsNotifyHeaders" name="notifyHeaders" rows="3" data-enable-grammarly="false"
                    spellcheck="false"
                    placeholder="X-Priority&#10;Reply-To&#10;List-Unsubscribe">{{values.notifyHeaders}}</textarea>
                <span class="helper-text">One header name per line.</span>
                {{/ui/form-field}}
            </div>
        </div>
    </div>

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Email Content <small class="text-base-content/60 font-normal">(All
                    webhooks)</small>
            </h6>
        </div>
        <div class="card-body space-y-4">

            <p>Include email body content in webhook payloads.</p>

            <div>
                {{> ui/setting-ref name="notifyText"}}
                {{> ui/checkbox id="settingsNotifyText" name="notifyText" label="Include email text and HTML"
                class="or-else-all" dataTarget="text-list" dataReverse=true checked=values.notifyText
                error=errors.notifyText}}
            </div>

            <div>
                {{> ui/setting-ref name="notifyWebSafeHtml"}}
                {{> ui/checkbox id="settingsNotifyWebSafeHtml" name="notifyWebSafeHtml"
                label="Sanitize HTML for web display" class="text-list" checked=values.notifyWebSafeHtml
                error=errors.notifyWebSafeHtml
                hint="Makes HTML safe for direct web page display. Converts plain text emails to HTML when needed."}}
            </div>

            <div>
                {{> ui/setting-ref name="notifyTextSize"}}
                {{#> ui/form-field id="settingsNotifyTextSize" label="Content Size Limit" error=errors.notifyTextSize}}
                <input type="text" class="input text-list{{#if errors.notifyTextSize}} is-invalid{{/if}}"
                    id="settingsNotifyTextSize" min="0" name="notifyTextSize" value="{{values.notifyTextSize}}"
                    placeholder="1MB" />
                <span class="helper-text">Maximum size per content type (text and HTML). Larger content will be
                    truncated.</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="notifyCalendarEvents"}}
                {{> ui/checkbox id="settingsnotifyCalendarEvents" name="notifyCalendarEvents"
                label="Extract calendar invites" checked=values.notifyCalendarEvents
                error=errors.notifyCalendarEvents
                hint="Detects and includes calendar event data from ICS files in webhook payloads."}}
            </div>

        </div>
    </div>

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">
                Attachments
                <small class="text-base-content/60 font-normal">(All webhooks)</small>
            </h6>
        </div>
        <div class="card-body space-y-4">
            <p>Include file attachments in webhook payloads.</p>

            <div>
                {{> ui/setting-ref name="notifyAttachments"}}
                {{> ui/checkbox id="settingsNotifyAttachments" name="notifyAttachments"
                label="Include attachments (base64-encoded)" class="or-else-all" dataTarget="attachment-list"
                dataReverse=true checked=values.notifyAttachments error=errors.notifyAttachments}}
            </div>

            <div>
                {{> ui/setting-ref name="notifyAttachmentSize"}}
                {{#> ui/form-field id="settingsNotifyAttachmentSize" label="Attachment Size Limit"
                error=errors.notifyAttachmentSize}}
                <input type="text" class="input attachment-list{{#if errors.notifyAttachmentSize}} is-invalid{{/if}}"
                    id="settingsNotifyAttachmentSize" min="0" name="notifyAttachmentSize"
                    value="{{values.notifyAttachmentSize}}" placeholder="2MB" />
                <span class="helper-text">Skip attachments larger than this size. Large attachments in webhook queues
                    can consume Redis memory quickly.</span>
                {{/ui/form-field}}
            </div>
        </div>
    </div>


    {{#> ui/card title="Webhook Scripts" id="script_settings" bodyClass="space-y-4"}}


            <p>Global settings for filter and map functions in <a href="/admin/webhooks"
                    class="link link-animated">webhook routes</a>.</p>

            <div id="scriptEnv">

                {{> ui/setting-ref name="scriptEnv"}}

                <label class="label-text">Script Variables (JSON)</label>

                <input type="hidden" class="{{#if errors.scriptEnv}}is-invalid{{/if}}" id="scriptEnvElement"
                    name="scriptEnv" value="{{values.scriptEnv}}">

                {{> ui/code-editor id="editor-env" title="Global variables"}}

                {{#if errors.scriptEnv}}
                <span class="helper-text text-error">{{errors.scriptEnv}}</span>
                {{/if}}

                <span class="helper-text">JSON object available as <code>env</code> variable in all filter and map
                    functions. Use for shared secrets like API keys, access tokens, or configuration values. For
                    example, if set to <code>{"token":"secret123"}</code>, then <code>env.token</code> in your scripts
                    returns <code>"secret123"</code>.</span>
            </div>


    {{/ui/card}}

    <div class="mb-6">
        {{> ui/btn label="Save Changes" type="submit" icon="icon-[tabler--settings]"}}
    </div>

</form>

<script src="/static/js/ace/ace.js"></script>
<script src="/static/js/ace/ext-language_tools.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', () => {

        const sendTestPayload = async () => {
            const webhooks = document.getElementById('settingsWebhooks').value.trim();
            const customHeaders = document.getElementById('customHeaders').value.trim();

            const data = await uiPostJson('/admin/config/webhooks/test', {
                webhooks,
                customHeaders
            });

            return data;
        }

        document.getElementById('test-payload-btn').addEventListener('click', e => {
            e.preventDefault()
            sendTestPayload().then(data => {
                showToast(data.error ? data.error : (data.success ? 'Test payload sent' : 'Failed to send payload'), data.success ? 'check-circle' : 'alert-triangle');
            }).catch(err => {
                showToast('Request failed\n' + err.message, 'alert-triangle');
            })
        });

        const editors = new Map();

        const editorEnv = uiAceEditor("editor-env", "json", document.getElementById('scriptEnvElement').value, {
            enableBasicAutocompletion: true,
            enableSnippets: false,
            enableLiveAutocompletion: false,
            useWorker: true
        });
        editors.set("editor-env", editorEnv);

        document.getElementById('settings-form').addEventListener('submit', () => {
            document.getElementById('scriptEnvElement').value = editorEnv.getValue();
        });

        uiEditorFullscreen(editors);
    })
</script>
