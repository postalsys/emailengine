{{> ui/page-header title="General Settings" icon="icon-[tabler--settings]" class="mb-1"}}

<p class="mb-6">Configure core settings for your EmailEngine instance.</p>

<form method="post" id="settings-form" action="/admin/config/service">
    {{!-- no id: the layout already renders the #crumb element the script reads --}}
    <input type="hidden" name="crumb" value="{{crumb}}" />

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">System Configuration</h6>
        </div>
        <div class="card-body space-y-4">

            <div>
                {{> ui/setting-ref name="serviceUrl"}}
                {{#> ui/form-field id="settingsServiceUrl" label="Service URL" error=errors.serviceUrl}}
                <input type="url" class="input{{#if errors.serviceUrl}} is-invalid{{/if}}" id="settingsServiceUrl"
                    name="serviceUrl" value="{{values.serviceUrl}}" data-lpignore="true" autocomplete="off" />
                <span class="helper-text">Base URL where EmailEngine is accessible (without any path).</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="enableApiProxy"}}
                {{> ui/checkbox id="enableApiProxy" name="enableApiProxy" label="Behind Reverse Proxy"
                checked=values.enableApiProxy error=errors.enableApiProxy}}
                <span class="helper-text">Enable if using Nginx, Caddy, or similar. Uses
                    <code>X-Forwarded-For</code> headers to identify client IPs.</span>
            </div>


            <div>
                {{> ui/setting-ref name="timezone"}}
                {{#> ui/form-field id="settingsServiceTimezone" label="Timezone" error=errors.timezone}}
                <select id="settingsServiceTimezone" class="select select-sm max-w-md{{#if errors.timezone}} is-invalid{{/if}}"
                    name="timezone">
                    {{#each timezones}}
                    <option value="{{timezone}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                </select>
                {{/ui/form-field}}
            </div>
        </div>
    </div>

    <div class="card bg-base-100 shadow-md mb-6" id="language">
        <div class="card-header">
            <h6 class="card-title text-primary">Language</h6>
        </div>
        <div class="card-body space-y-4">
            <div>
                {{> ui/setting-ref name="locale"}}
                {{#> ui/form-field id="settingsServiceLocale" label="Default Language" error=errors.locale}}
                <select id="settingsServiceLocale" class="select select-sm max-w-md{{#if errors.locale}} is-invalid{{/if}}"
                    name="locale">
                    {{#each locales}}
                    <option value="{{locale}}" {{#if selected}}selected{{/if}}>{{name}} ({{locale}})</option>
                    {{/each}}
                </select>
                <span class="helper-text">
                    Default language for UI and API responses.
                </span>
                {{/ui/form-field}}

                <details id="languageDetails" class="group mt-2">
                    <summary
                        class="cursor-pointer text-sm text-base-content/60 list-none [&::-webkit-details-marker]:hidden inline-flex items-center gap-1">
                        <span class="link link-animated">How to override</span>
                        <span
                            class="icon-[tabler--chevron-down] size-3.5 transition-transform duration-200 group-open:rotate-180"></span>
                    </summary>
                    <div class="alert alert-soft alert-info mt-2 block">
                        <h6 class="font-bold mb-2">Override Language Settings</h6>
                        <p class="mb-2">Set language per request (highest to lowest priority):</p>
                        <ol class="list-decimal ps-6 mb-[1rem] space-y-1">
                            <li><strong>URL parameter:</strong> <code>?locale=xx</code></li>
                            <li><strong>Custom header:</strong> <code>X-EE-Locale: xx</code> (API only)</li>
                            <li><strong>Browser preference:</strong> <code>Accept-Language</code> header</li>
                            <li><strong>Default:</strong> Language selected above</li>
                        </ol>

                        <strong>Examples:</strong>
                        <ul class="list-disc ps-6 mb-0 space-y-1">
                            <li>Web: <code>/accounts/new?locale=et</code></li>
                            <li>API: <code>GET /v1/accounts?locale=nl</code></li>
                            <li>Header: <code>X-EE-Locale: de</code></li>
                        </ul>
                    </div>
                </details>
            </div>

            <p class="mb-0">
                <a href="https://github.com/postalsys/emailengine/blob/master/translations/README.md" target="_blank"
                    rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">
                    <span class="icon-[tabler--external-link] size-4 align-text-bottom"></span> Help us translate
                    EmailEngine
                </a>
            </p>
        </div>
    </div>

    <div class="card bg-base-100 shadow-md mb-6" id="security">
        <div class="card-header">
            <h6 class="card-title text-primary">Security</h6>
        </div>
        <div class="card-body space-y-4">

            <div>
                {{> ui/setting-ref name="serviceSecret"}}
                {{#> ui/form-field id="settingsServiceSecret" label="Service Secret" error=errors.serviceSecret}}
                {{> ui/secret-field id="settingsServiceSecret" name="serviceSecret" value=values.serviceSecret
                error=errors.serviceSecret toggleId="showServiceSecret" toggleLabel="Show secret"}}
                <span class="helper-text">HMAC key for signing public requests. Changing this invalidates all existing
                    tracking links.</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="EENGINE_REQUIRE_API_AUTH" plain=true}}

                <div class="flex items-center gap-2">
                    <input type="checkbox" class="checkbox checkbox-sm{{#if errors.enableTokens}} is-invalid{{/if}}"
                        id="enableTokens" name="enableTokens" {{#if values.enableTokens}}checked{{/if}} />
                    <label class="label-text p-0" for="enableTokens">Require API Authentication

                        <span class="badge badge-{{#if values.enableTokens}}success{{else}}error{{/if}}">{{#if
                            values.enableTokens}}enabled{{else}}disabled{{/if}}</span>
                    </label>
                </div>
                {{#if errors.enableTokens}}
                <span class="helper-text text-error">{{errors.enableTokens}}</span>
                {{/if}}
                <span class="helper-text">Disable for development only. Always enable in production for secure API
                    access. Set <code>EENGINE_REQUIRE_API_AUTH=false</code> at startup to disable by default (not
                    recommended).</span>
            </div>

            <div>
                {{> ui/setting-ref name="EENGINE_SECRET" href="https://docs.emailengine.app/enabling-secret-encryption/"}}

                <div class="flex items-center gap-2">
                    <input type="checkbox" class="checkbox checkbox-sm" id="encryption" {{#if encryption}}checked{{/if}}
                        disabled />
                    <label class="label-text p-0" for="encryption">Data Encryption

                        <span class="badge badge-{{#if encryption}}success{{else}}error{{/if}}">{{#if
                            encryption}}enabled{{else}}disabled{{/if}}</span>

                    </label>
                </div>
                <span class="helper-text">Set <code>EENGINE_SECRET</code> environment variable at startup to enable. <a
                        href="https://docs.emailengine.app/enabling-secret-encryption/" target="_blank"
                        rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">Learn
                        more</a></span>
            </div>


            <div>
                {{> ui/setting-ref name="EENGINE_ADMIN_ACCESS_ADDRESSES" plain=true}}

                <div class="flex items-center gap-2">
                    <input type="checkbox" class="checkbox checkbox-sm" id="adminAccessLimit" {{#if
                        adminAccessLimit}}checked{{/if}} disabled />
                    <label class="label-text p-0" for="adminAccessLimit">Admin IP Restrictions

                        <span class="badge badge-{{#if adminAccessLimit}}success{{else}}error{{/if}}">{{#if
                            adminAccessLimit}}enabled{{else}}disabled{{/if}}</span>

                    </label>
                </div>
                <span class="helper-text">Set <code>EENGINE_ADMIN_ACCESS_ADDRESSES</code> at startup with
                    comma-separated IP addresses or CIDR ranges (e.g., "192.168.1.1,10.0.0.0/24").</span>
            </div>


            <div>
                {{> ui/setting-ref name="EENGINE_ENABLE_OAUTH_TOKENS_API" plain=true}}
                {{> ui/checkbox id="enableOAuthTokensApi" name="enableOAuthTokensApi"
                label="Allow OAuth2 Token Access via API" checked=values.enableOAuthTokensApi
                error=errors.enableOAuthTokensApi}}
                <span class="helper-text">Enable <a href="/admin/swagger#/Account/getV1AccountAccountOauthtoken"
                        target="_blank" rel="noopener noreferrer" class="link link-animated">API endpoint</a> to
                    retrieve OAuth2 tokens. Set <code>EENGINE_ENABLE_OAUTH_TOKENS_API=true</code> at startup to enable
                    by default.</span>
            </div>


            <div>
                {{> ui/setting-ref name="ignoreMailCertErrors"}}

                <div class="flex items-center gap-2">
                    <input type="checkbox"
                        class="checkbox checkbox-sm{{#if errors.ignoreMailCertErrors}} is-invalid{{/if}}"
                        id="ignoreMailCertErrors" name="ignoreMailCertErrors" {{#if
                        values.ignoreMailCertErrors}}checked{{/if}} />
                    <label class="label-text p-0" for="ignoreMailCertErrors">Allow Insecure Email Certificates

                        <span class="badge badge-{{#if values.ignoreMailCertErrors}}error{{else}}success{{/if}}">{{#if
                            values.ignoreMailCertErrors}}enabled{{else}}disabled{{/if}}</span>

                    </label>
                </div>
                {{#if errors.ignoreMailCertErrors}}
                <span class="helper-text text-error">{{errors.ignoreMailCertErrors}}</span>
                {{/if}}
                <span class="helper-text">Accept self-signed or expired certificates for IMAP/SMTP connections. Not
                    recommended.</span>
            </div>

        </div>
    </div>

    <div id="queue_settings" class="card bg-base-100 shadow-md mb-6">
        <div class="card-header flex items-center justify-between">
            <h6 class="card-title text-primary">Queue Management</h6>
            {{> ui/btn label="Clear completed jobs" variant="neutral" style="soft" size="sm" id="clean-queues-btn"
            icon="icon-[tabler--trash] clean-icon"}}
        </div>

        <div class="card-body">
            <div>
                {{> ui/setting-ref name="queueKeep"}}
                {{#> ui/form-field id="settingsQueueKeep" label="Job History Limit" error=errors.queueKeep}}
                <input type="number" min="0" class="input{{#if errors.queueKeep}} is-invalid{{/if}}"
                    id="settingsQueueKeep" name="queueKeep" value="{{values.queueKeep}}" data-lpignore="true"
                    autocomplete="off" />
                <span class="helper-text">Number of completed/failed jobs to keep in <a href="/admin/bull-board"
                        target="_blank" rel="noopener noreferrer" class="link link-animated">Bull Board</a>. Set to 0 to
                    disable history.</span>
                {{/ui/form-field}}
            </div>

        </div>
    </div>

    <div id="submission_settings" class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Email Delivery</h6>
        </div>
        <div class="card-body">
            <div>
                {{> ui/setting-ref name="deliveryAttempts"}}
                {{#> ui/form-field id="settingsDeliveryAttempts" label="Retry Attempts" error=errors.deliveryAttempts}}
                <input type="number" min="0" class="input{{#if errors.deliveryAttempts}} is-invalid{{/if}}"
                    id="settingsDeliveryAttempts" name="deliveryAttempts" value="{{values.deliveryAttempts}}"
                    data-lpignore="true" autocomplete="off" />
                <span class="helper-text">How many times to retry failed email deliveries.</span>
                {{/ui/form-field}}
            </div>

        </div>
    </div>

    <div id="imap_settings" class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">IMAP Processing</h6>
        </div>
        <div class="card-body">
            <div>
                {{> ui/setting-ref name="imapIndexer"}}
                {{#> ui/form-field id="settingsImapIndexer" label="Indexing Method" error=errors.imapIndexer}}
                <select id="settingsImapIndexer" class="select select-sm max-w-md{{#if errors.imapIndexer}} is-invalid{{/if}}"
                    name="imapIndexer">
                    {{#each imapIndexers}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                </select>
                <span class="helper-text"><strong>Full:</strong> Track all changes (new, deleted, updated emails).
                    <strong>Fast:</strong> Track only new emails. Applies to new accounts only. To change existing
                    accounts, perform an <a href="/admin/swagger#/Account/putV1AccountAccountFlush"
                        class="link link-animated">account flush</a>.</span>
                {{/ui/form-field}}
            </div>

        </div>
    </div>

    <div id="export_settings" class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Export Settings</h6>
        </div>
        <div class="card-body space-y-4">
            <p>Configure batch sizes for bulk message export operations.</p>

            <div>
                {{> ui/setting-ref name="gmailExportBatchSize"}}
                {{#> ui/form-field id="settingsGmailExportBatchSize" label="Gmail Export Batch Size"
                error=errors.gmailExportBatchSize}}
                <input type="number" min="1" max="50" class="input{{#if errors.gmailExportBatchSize}} is-invalid{{/if}}"
                    id="settingsGmailExportBatchSize" name="gmailExportBatchSize"
                    value="{{values.gmailExportBatchSize}}" data-lpignore="true" autocomplete="off" />
                <span class="helper-text">Number of parallel requests when fetching Gmail messages for export (1-50,
                    default: 10).</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="outlookExportBatchSize"}}
                {{#> ui/form-field id="settingsOutlookExportBatchSize" label="Outlook Export Batch Size"
                error=errors.outlookExportBatchSize}}
                <input type="number" min="1" max="20"
                    class="input{{#if errors.outlookExportBatchSize}} is-invalid{{/if}}"
                    id="settingsOutlookExportBatchSize" name="outlookExportBatchSize"
                    value="{{values.outlookExportBatchSize}}" data-lpignore="true" autocomplete="off" />
                <span class="helper-text">Messages per batch request for Outlook exports (1-20, default: 20). Limited by
                    Microsoft Graph API.</span>
                {{/ui/form-field}}
            </div>
        </div>
    </div>

    <div id="templates_settings" class="card bg-base-100 shadow-md mb-6">
        <div class="card-header flex items-center justify-between">
            <h6 class="card-title text-primary">Public Page Customization</h6>
            {{> ui/btn label="Preview" variant="neutral" style="soft" size="sm" icon="icon-[tabler--eye]"
            id="preview-header-btn"}}
        </div>
        <div class="card-body space-y-4">

            <p>Customize public pages like authentication forms, error pages, and unsubscribe pages.</p>

            <div>
                {{> ui/setting-ref name="pageBrandName"}}
                {{#> ui/form-field id="settingsPageBrandName" label="Brand Name" error=errors.pageBrandName}}
                <input type="text" class="input{{#if errors.pageBrandName}} is-invalid{{/if}}"
                    id="settingsPageBrandName" name="pageBrandName" value="{{values.pageBrandName}}"
                    data-lpignore="true" autocomplete="off" placeholder="EmailEngine" />
                <span class="helper-text">Appears in browser title bar</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="templateHeader"}}

                <label class="label-text">Page Header HTML</label>

                <input type="hidden" class="{{#if errors.templateHeader}}is-invalid{{/if}}" id="templateHeaderElement"
                    name="templateHeader" value="{{values.templateHeader}}">

                <div id="editor-html" class="code-editor"></div>
                <div class="editor-embed-block">
                    <div class="editor-embed-content editor-embed-title editor-embed-content-left">
                        Header template
                    </div>
                    <div class="editor-embed-content editor-embed-content-right">
                        <a href="#" class="toggle-fullscreen" data-target="editor-html">Toggle fullscreen</a>
                    </div>
                </div>

                {{#if errors.templateHeader}}
                <span class="helper-text text-error">{{errors.templateHeader}}</span>
                {{/if}}

                <span class="helper-text">HTML shown at the {{#> ui/tooltip-rich label="top of public pages"}}<img
                        src="/static/preview/header-template.png" alt="Header template preview">{{/ui/tooltip-rich}}</span>
            </div>

            <div>
                {{> ui/setting-ref name="templateHtmlHead"}}

                <label class="label-text">Custom &lt;head&gt; HTML</label>

                <input type="hidden" class="{{#if errors.templateHtmlHead}}is-invalid{{/if}}"
                    id="templateHtmlHeadElement" name="templateHtmlHead" value="{{values.templateHtmlHead}}">

                <div id="editor-html-head" class="code-editor"></div>
                <div class="editor-embed-block">
                    <div class="editor-embed-content editor-embed-title editor-embed-content-left">
                        Head content
                    </div>
                    <div class="editor-embed-content editor-embed-content-right">
                        <a href="#" class="toggle-fullscreen" data-target="editor-html-head">Toggle fullscreen</a>
                    </div>
                </div>

                {{#if errors.templateHtmlHead}}
                <span class="helper-text text-error">{{errors.templateHtmlHead}}</span>
                {{/if}}

                <span class="helper-text">Add custom CSS, fonts, or analytics scripts</span>
            </div>

        </div>
    </div>

    <div id="script_settings" class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Webhook Scripts</h6>
        </div>
        <div class="card-body space-y-4">


            <p>Global settings for filter and map functions in <a href="/admin/webhooks"
                    class="link link-animated">webhook routes</a>.</p>

            <div id="scriptEnv">

                {{> ui/setting-ref name="scriptEnv"}}

                <label class="label-text">Script Variables (JSON)</label>

                <input type="hidden" class="{{#if errors.scriptEnv}}is-invalid{{/if}}" id="scriptEnvElement"
                    name="scriptEnv" value="{{values.scriptEnv}}">

                <div id="editor-env" class="code-editor"></div>
                <div class="editor-embed-block">
                    <div class="editor-embed-content editor-embed-title editor-embed-content-left">
                        Global variables
                    </div>
                    <div class="editor-embed-content editor-embed-content-right">
                        <a href="#" class="toggle-fullscreen" data-target="editor-env">Toggle fullscreen</a>
                    </div>
                </div>

                {{#if errors.scriptEnv}}
                <span class="helper-text text-error">{{errors.scriptEnv}}</span>
                {{/if}}

                <span class="helper-text">JSON object available as <code>env</code> variable in all filter and map
                    functions. Use for shared secrets like API keys, access tokens, or configuration values. For
                    example, if set to <code>{"token":"secret123"}</code>, then <code>env.token</code> in your scripts
                    returns <code>"secret123"</code>.</span>
            </div>

        </div>
    </div>

    <div id="labs"></div>

    <div class="card bg-base-100 shadow-md mb-6" id="tracking">
        <div class="card-header">
            <h6 class="card-title text-primary">Email Tracking</h6>
        </div>
        <div class="card-body space-y-4">

            <div>
                {{> ui/setting-ref name="trackClicks"}}
                {{> ui/checkbox id="trackClicks" name="trackClicks" label="Track Link Clicks"
                checked=values.trackClicks error=errors.trackClicks
                hint="Rewrite links to track when recipients click them."}}
            </div>

            <div>
                {{> ui/setting-ref name="trackOpens"}}
                {{> ui/checkbox id="trackOpens" name="trackOpens" label="Track Email Opens" checked=values.trackOpens
                error=errors.trackOpens hint="Add a tracking pixel to detect when emails are opened."}}
            </div>
        </div>

        <div class="card-footer border-base-content/10 border-t px-6 py-[1rem]">
            <strong>Important:</strong> <a href="{{values.serviceUrl}}" target="_blank" rel="noopener noreferrer"
                class="link link-animated">{{values.serviceUrl}}</a> must be publicly accessible for tracking to work.
            See <a href="https://emailengine.app/sending-emails#tracking" target="_blank" rel="noopener noreferrer"
                referrerpolicy="no-referrer" class="link link-animated">documentation</a> for per-message overrides.

        </div>
    </div>

    <div class="card bg-base-100 shadow-md mb-6" id="gmail">
        <div class="card-header">
            <h6 class="card-title text-primary">Gmail Features</h6>
        </div>
        <div class="card-body">

            <div>
                {{> ui/setting-ref name="resolveGmailCategories"}}
                {{> ui/checkbox id="resolveGmailCategories" name="resolveGmailCategories"
                label="Detect Gmail Categories (IMAP)" checked=values.resolveGmailCategories
                error=errors.resolveGmailCategories}}
                <span class="helper-text">Identify which Gmail tab (Primary, Social, Promotions, Updates, Forums) new
                    emails belong to. Available in <code>messageNew</code> webhook as <code>category</code> property.
                    Gmail API accounts get this automatically.</span>
            </div>

        </div>
    </div>

    <div class="mb-6">
        {{> ui/btn label="Save Changes" type="submit" icon="icon-[tabler--settings]"}}
    </div>

</form>

<form id="preview-form" method="post" action="/admin/config/service/preview">
    <input type="hidden" name="crumb" value="{{crumb}}" />
    <input type="hidden" name="templateHeader" id="preview-header-elm">
    <input type="hidden" name="templateHtmlHead" id="preview-head-elm">
    <input type="hidden" name="pageBrandName" id="preview-brand-name-elm">
</form>


<script src="/static/js/ace/ace.js"></script>
<script src="/static/js/ace/ext-language_tools.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', () => {

        const sendCleanPayload = async () => {

            const res = await fetch('/admin/config/service/clean', {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value
                })
            })
            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }
            const data = await res.json();

            return data;
        }

        let sendingCleanRequest = false;
        document.getElementById('clean-queues-btn').addEventListener('click', e => {
            e.preventDefault();
            if (sendingCleanRequest) {
                e.stopPropagation();
                return
            }
            sendingCleanRequest = true;

            let cleanIconElm = document.querySelector('#clean-queues-btn .clean-icon');
            cleanIconElm.classList.remove('icon-[tabler--trash]');
            cleanIconElm.classList.add('icon-[tabler--loader-2]', 'animate-spin');

            sendCleanPayload().then(data => {
                sendingCleanRequest = false;
                cleanIconElm.classList.add('icon-[tabler--trash]');
                cleanIconElm.classList.remove('icon-[tabler--loader-2]', 'animate-spin');

                showToast(data.error ? data.error : (data.success ? 'Cleanup request sent' : 'Failed to send payload'), data.success ? 'check-circle' : 'alert-triangle');
            }).catch(err => {
                sendingCleanRequest = false;
                cleanIconElm.classList.add('icon-[tabler--trash]');
                cleanIconElm.classList.remove('icon-[tabler--loader-2]', 'animate-spin');

                showToast('Request failed\n' + err.message, 'alert-triangle');
            })
        });





        const editors = new Map();

        const editorHtml = ace.edit("editor-html", {
            enableBasicAutocompletion: true,
            enableSnippets: false,
            enableLiveAutocompletion: false,
            useWorker: true
        });
        editors.set("editor-html", editorHtml);

        editorHtml.setTheme("ace/theme/xcode");
        editorHtml.session.setMode("ace/mode/handlebars");
        editorHtml.session.setValue(document.getElementById('templateHeaderElement').value);

        const editorEnv = ace.edit("editor-env", {
            enableBasicAutocompletion: true,
            enableSnippets: false,
            enableLiveAutocompletion: false,
            useWorker: true
        });
        editors.set("editor-env", editorEnv);

        editorEnv.setTheme("ace/theme/xcode");
        editorEnv.session.setMode("ace/mode/json");
        editorEnv.session.setValue(document.getElementById('scriptEnvElement').value);

        const editorHtmlHead = ace.edit("editor-html-head", {
            enableBasicAutocompletion: true,
            enableSnippets: false,
            enableLiveAutocompletion: false,
            useWorker: true
        });
        editors.set("editor-html-head", editorHtmlHead);

        editorHtmlHead.setTheme("ace/theme/xcode");
        editorHtmlHead.session.setMode("ace/mode/handlebars");
        editorHtmlHead.session.setValue(document.getElementById('templateHtmlHeadElement').value);


        document.getElementById('preview-header-btn').addEventListener('click', e => {
            e.preventDefault();
            let previewWindow = window.open('about:blank', 'preview-window', '');
            let previewForm = document.getElementById('preview-form');
            previewForm.target = 'preview-window';

            document.getElementById('preview-brand-name-elm').value = document.getElementById('settingsPageBrandName').value;
            document.getElementById('preview-header-elm').value = editorHtml.getValue();
            document.getElementById('preview-head-elm').value = editorHtmlHead.getValue();

            previewForm.submit();
        });

        document.getElementById('settings-form').addEventListener('submit', () => {
            document.getElementById('templateHeaderElement').value = editorHtml.getValue();
            document.getElementById('scriptEnvElement').value = editorEnv.getValue();
            document.getElementById('templateHtmlHeadElement').value = editorHtmlHead.getValue();
        });

        uiEditorFullscreen(editors);

