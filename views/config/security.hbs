{{> ui/page-header title="Security" icon="icon-[tabler--shield-lock]" class="mb-1"}}

<p class="mb-6">Control API authentication, secrets, and connection security for this EmailEngine instance.</p>

<form method="post" action="/admin/config/security">
    {{!-- no id: the layout already renders the #crumb element the script reads --}}
    <input type="hidden" name="crumb" value="{{crumb}}" />

    {{#> ui/card title="Access Control" id="access" bodyClass="space-y-4"}}

            <div>
                {{> ui/setting-ref name="EENGINE_REQUIRE_API_AUTH" plain=true}}

                {{#> ui/checkbox id="enableTokens" label="Require API Authentication" checked=values.enableTokens
                error=errors.enableTokens}}
                {{> ui/badge label=(when values.enableTokens "enabled" "disabled") variant=(when values.enableTokens "success" "error")}}
                {{/ui/checkbox}}
                <span class="helper-text">Disable for development only. Always enable in production for secure API
                    access. Set <code>EENGINE_REQUIRE_API_AUTH=false</code> at startup to disable by default (not
                    recommended).</span>
            </div>

            <div>
                {{> ui/setting-ref name="EENGINE_ADMIN_ACCESS_ADDRESSES" plain=true}}

                {{#> ui/checkbox id="adminAccessLimit" label="Admin IP Restrictions" checked=adminAccessLimit
                disabled=true}}
                {{> ui/badge label=(when adminAccessLimit "enabled" "disabled") variant=(when adminAccessLimit "success" "error")}}
                {{/ui/checkbox}}
                <span class="helper-text">Set <code>EENGINE_ADMIN_ACCESS_ADDRESSES</code> at startup with
                    comma-separated IP addresses or CIDR ranges (e.g., "192.168.1.1,10.0.0.0/24").</span>
            </div>

            <div>
                {{> ui/setting-ref name="EENGINE_ENABLE_OAUTH_TOKENS_API" plain=true}}
                {{> ui/checkbox id="enableOAuthTokensApi" name="enableOAuthTokensApi"
                label="Allow OAuth2 Token Access via API" checked=values.enableOAuthTokensApi
                error=errors.enableOAuthTokensApi}}
                <span class="helper-text">Enable <a href="/admin/swagger#/Account/getV1AccountAccountOauthtoken"
                        target="_blank" rel="noopener noreferrer" class="link link-animated">API endpoint</a> to
                    retrieve OAuth2 tokens. Set <code>EENGINE_ENABLE_OAUTH_TOKENS_API=true</code> at startup to enable
                    by default.</span>
            </div>

    {{/ui/card}}

    {{#> ui/card title="Secrets and Encryption" id="secrets" bodyClass="space-y-4"}}

            <div>
                {{> ui/setting-ref name="serviceSecret"}}
                {{#> ui/form-field id="settingsServiceSecret" label="Service Secret" error=errors.serviceSecret}}
                {{> ui/secret-field id="settingsServiceSecret" name="serviceSecret" value=values.serviceSecret
                error=errors.serviceSecret toggleId="showServiceSecret" toggleLabel="Show secret"}}
                <span class="helper-text">HMAC key for signing public requests. Changing this invalidates all existing
                    tracking links.</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="EENGINE_SECRET" href="https://docs.emailengine.app/enabling-secret-encryption/"}}

                {{#> ui/checkbox id="encryption" label="Data Encryption" checked=encryption disabled=true}}
                {{> ui/badge label=(when encryption "enabled" "disabled") variant=(when encryption "success" "error")}}
                {{/ui/checkbox}}
                <span class="helper-text">Set <code>EENGINE_SECRET</code> environment variable at startup to enable. <a
                        href="https://docs.emailengine.app/enabling-secret-encryption/" target="_blank"
                        rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">Learn
                        more</a></span>
            </div>

    {{/ui/card}}

    {{#> ui/card title="Connection Security" id="connections" bodyClass="space-y-4"}}

            <div>
                {{> ui/setting-ref name="ignoreMailCertErrors"}}

                {{#> ui/checkbox id="ignoreMailCertErrors" label="Allow Insecure Email Certificates"
                checked=values.ignoreMailCertErrors error=errors.ignoreMailCertErrors}}
                {{> ui/badge label=(when values.ignoreMailCertErrors "enabled" "disabled") variant=(when values.ignoreMailCertErrors "error" "success")}}
                {{/ui/checkbox}}
                <span class="helper-text">Accept self-signed or expired certificates for IMAP/SMTP connections. Not
                    recommended.</span>
            </div>

    {{/ui/card}}

    <div class="mb-6">
        {{> ui/btn label="Save Changes" type="submit" icon="icon-[tabler--settings]"}}
    </div>

</form>
