<div class="flex flex-wrap items-center justify-between gap-3 mb-1">
    <h1 class="flex items-center gap-2 text-2xl font-semibold text-base-content">
        <span class="icon-[tabler--server] size-6 text-base-content/60"></span>
        IMAP Proxy
        {{!-- live state badge: app.js updates the badge-{type} class and
              text through the /admin/changes SSE feed (targets
              .state-info[data-type]); the hover popover runs through the
              residual shim in bootstrap-compat.js --}}
        <span class="badge badge-{{serverState.label.type}} state-info" data-type="imapProxy">
            {{#if serverState.label.spinner}}
            <span class="icon-[tabler--loader-2] animate-spin size-3.5 align-text-bottom"></span>
            {{/if}}

            {{serverState.label.name}}</span>
    </h1>
</div>

<p>Access any EmailEngine-managed account through standard IMAP clients. The proxy handles authentication with the real
    email server, so your IMAP client only needs an access token-no actual credentials or OAuth2 setup required.</p>

<div class="alert alert-soft alert-info mb-6">
    <span class="icon-[tabler--info-circle] size-5 shrink-0"></span>
    <span><strong>Compatibility Note:</strong> IMAP proxy only works with accounts that
        connect via IMAP protocol. This includes Gmail and Microsoft 365 accounts using OAuth2 authentication with IMAP
        access. Accounts using MS Graph API or Gmail API as their mail backend are not supported through the
        proxy.</span>
</div>

<p class="mb-6">Configure your IMAP proxy server below.</p>

<form method="post" action="/admin/config/imap-proxy">
    {{!-- no id: the layout already renders the #crumb element the script reads --}}
    <input type="hidden" name="crumb" value="{{crumb}}" />

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Server Configuration</h6>
        </div>

        <div class="px-6 py-[1rem] border-b border-base-content/10 flex items-start justify-between gap-4">
            {{> ui/checkbox id="imapProxyServerEnabled" name="imapProxyServerEnabled" label="Enable IMAP Proxy"
            checked=values.imapProxyServerEnabled error=errors.imapProxyServerEnabled}}

            <div class="text-end">
                {{> ui/setting-ref name="imapProxyServerEnabled" class="whitespace-nowrap"}}
            </div>
        </div>

        <div class="card-body space-y-4">
            <div>
                {{> ui/setting-ref name="imapProxyServerPort"}}
                {{#> ui/form-field id="imapProxyServerPort" label="Port" error=errors.imapProxyServerPort}}
                <input type="number"
                    class="input trigger-example-render{{#if errors.imapProxyServerPort}} is-invalid{{/if}}"
                    id="imapProxyServerPort" name="imapProxyServerPort" value="{{values.imapProxyServerPort}}" />
                <span class="helper-text">TCP port for IMAP connections. Ports below 1024 may require elevated
                    privileges.</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="imapProxyServerHost"}}
                {{#> ui/form-field id="imapProxyServerHost" label="Listen Address" error=errors.imapProxyServerHost}}
                <input type="text"
                    class="input basicAutoComplete trigger-example-render{{#if errors.imapProxyServerHost}} is-invalid{{/if}}"
                    id="imapProxyServerHost" name="imapProxyServerHost" value="{{values.imapProxyServerHost}}"
                    data-lpignore="true" autocomplete="off" />
                <span class="helper-text">IP address to bind to. Use "0.0.0.0" or leave empty to accept connections from
                    anywhere.</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="imapProxyServerProxy"}}
                {{> ui/checkbox id="imapProxyServerProxy" name="imapProxyServerProxy" label="Enable PROXY Protocol"
                checked=values.imapProxyServerProxy error=errors.imapProxyServerProxy}}
                <span class="helper-text">Required when using HAProxy with <code>send-proxy</code>.</span>
            </div>
        </div>
    </div>

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Authentication</h6>
        </div>
        <div class="card-body">

            <div>
                {{> ui/setting-ref name="imapProxyServerPassword"}}
                {{#> ui/form-field id="imapProxyServerPassword" label="Global Password"
                error=errors.imapProxyServerPassword}}
                {{> ui/secret-field id="imapProxyServerPassword" value=values.imapProxyServerPassword
                error=errors.imapProxyServerPassword placeholder="No global password set"
                inputClass="trigger-example-render" toggleId="showPassword"}}
                <span class="helper-text">Optional shared password for all accounts. Leave empty to use only access
                    tokens.</span>
                {{/ui/form-field}}
            </div>
        </div>

        <div class="card-footer border-base-content/10 border-t px-6 py-[1rem]">
            <small class="text-base-content/60">
                <span class="icon-[tabler--info-circle] size-4 align-text-bottom"></span>

                <strong>How to connect:</strong> Use account IDs as usernames. For passwords, use either the global
                password above or <a href="/admin/tokens" class="link link-animated">access tokens</a> with IMAP Proxy
                scope.
            </small>
        </div>

    </div>

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Security (TLS)</h6>
        </div>
        <div class="card-body">
            <div>
                {{> ui/setting-ref name="imapProxyServerTLSEnabled"}}

                {{!-- hand-rolled checkbox: the label carries the #tls-label
                      badge whose badge-{type} class and tooltip body are
                      repainted by paintCertData() from ui.js --}}
                <div class="flex items-center gap-2">
                    <input type="checkbox"
                        class="checkbox checkbox-sm trigger-example-render{{#if errors.imapProxyServerTLSEnabled}} is-invalid{{/if}}"
                        id="imapProxyServerTLSEnabled" {{#if
                        certificateData}}data-certificate="{{certificateData.fingerprint}}" {{/if}}
                        data-domain="{{serviceDomain}}" name="imapProxyServerTLSEnabled" {{#if
                        values.imapProxyServerTLSEnabled}}checked{{/if}} />

                    <label class="label-text p-0" for="imapProxyServerTLSEnabled">Enable TLS Encryption

                        {{#if certificateData.label}}
                        {{#> ui/tooltip text=certificateData.label.title}}
                        <span id="tls-label" class="badge badge-{{certificateData.label.type}}"
                            data-labeltype="{{certificateData.label.type}}">{{certificateData.label.text}}</span>
                        {{/ui/tooltip}}
                        {{/if}}

                    </label>
                </div>

                {{#if errors.imapProxyServerTLSEnabled}}
                <span class="helper-text text-error">{{errors.imapProxyServerTLSEnabled}}</span>
                {{/if}}

                <span class="helper-text">
                    {{#if serviceDomain}}

                    Certificates will be provisioned for <em>{{serviceDomain}}</em>. Change the domain in <a
                        href="/admin/config/service#settingsServiceUrl" class="link link-animated">Service URL
                        settings</a>.

                    {{else}}

                    Set a domain name in <a href="/admin/config/service#settingsServiceUrl"
                        class="link link-animated">Service URL settings</a> to enable automatic TLS certificates.

                    {{/if}}

                </span>
            </div>

        </div>

        {{#if serviceDomain}}
        <div class="card-footer border-base-content/10 border-t px-6 py-[1rem]">
            <small class="text-base-content/60">
                <span class="icon-[tabler--info-circle] size-4 align-text-bottom"></span>
                EmailEngine must be publicly accessible at <em><a href="{{serviceUrl}}" target="_blank"
                        rel="noopener noreferrer" class="link link-animated">{{serviceUrl}}</a></em> for automatic
                certificates. Otherwise, a self-signed certificate will be used.
            </small>
        </div>
        {{/if}}

    </div>

    {{#> ui/details summary="Client Configuration Examples" class="card bg-base-100 shadow-md mb-6"}}

    <p class="mb-[1rem]">Connect to the proxy using the account ID as your IMAP username.</p>

    <nav class="tabs tabs-bordered" aria-label="Client configuration examples" role="tablist" id="code-examples"
        data-tabs>
        <button type="button" class="tab active-tab:tab-active active" id="example-node-imap-tab" data-tab="#example-node-imap" role="tab"
            aria-controls="example-node-imap" aria-selected="true">Node.js (node-imap)</button>
        <button type="button" class="tab active-tab:tab-active" id="example-php-imap-tab" data-tab="#example-php-imap" role="tab"
            aria-controls="example-php-imap" aria-selected="false">PHP (php-imap)</button>
    </nav>

    <div class="mt-[1rem] mb-[1rem]">
        <div id="example-node-imap" role="tabpanel" aria-labelledby="example-node-imap-tab">

            <pre class="overflow-x-auto"><code id="example-node-imap-code"></code></pre>

        </div>

        <div id="example-php-imap" class="hidden" role="tabpanel" aria-labelledby="example-php-imap-tab">

            <pre class="overflow-x-auto"><code id="example-php-imap-code"></code></pre>

        </div>
    </div>

    <div>
        {{> ui/checkbox id="exampleShowPassword" label="Show password in examples" class="trigger-example-render"}}
    </div>

    {{/ui/details}}

    <div class="mb-6">
        {{> ui/btn label="Save Changes" type="submit" icon="icon-[tabler--settings]"}}
    </div>

</form>

{{#> ui/modal id="tlsModal" hideClose=true dialogClass="max-w-3xl"}}
<div class="modal-body">
    <h3 class="modal-title modal-show-default mb-[1rem]">Provisioning Certificate <span
            class="loading loading-spinner loading-sm align-middle"></span></h3>
    <h3 class="modal-title modal-show-error hidden mb-[1rem]">Certificate Request Failed</h3>

    <div class="modal-show-default">
        Setting up TLS certificate for <em class="show-service-domain">{{serviceDomain}}</em>. This may take a
        moment...
    </div>
    <div class="modal-show-error hidden">
        <p class="mb-2">Unable to provision certificate:</p>

        <div class="font-mono error-content alert alert-soft alert-error"></div>
    </div>
</div>
<div class="modal-footer modal-show-error hidden">
    {{> ui/btn label="Close" variant="neutral" style="soft" overlay="#tlsModal"}}
</div>
{{/ui/modal}}

<input type="hidden" id="availableAddresses" value="{{availableAddresses}}">

<script>
    document.addEventListener('DOMContentLoaded', () => {

        let availableAddresses = document.getElementById('availableAddresses').value.split(',').map(e => e.trim()).filter(e => e);
        // native datalist suggestions (replaces the bootstrap-autocomplete plugin)
        let addressListElm = document.createElement('datalist');
        addressListElm.id = 'available-addresses-list';
        for (let addr of availableAddresses) {
            let optionElm = document.createElement('option');
            optionElm.value = addr;
            addressListElm.appendChild(optionElm);
        }
        document.body.appendChild(addressListElm);
        for (let inputElm of document.querySelectorAll('.basicAutoComplete')) {
            inputElm.setAttribute('list', addressListElm.id);
        }


        let codeTemplates = {
            nodeImap: {
                lang: 'javascript',
                codeAuth: `const imap = new Imap({
  user: 'USERNAME',
  password: 'PASSWORD',
  host: 'HOST',
  port: PORT,
  tls: USE_TLS
});`},
            phpImap: {
                lang: 'php',
                codeAuth: `// https://www.php-imap.com/configuration/account/account
$client = $cm->make([
    'host' => 'HOST',
    'port' => PORT,
    'encryption' => PHPIMAP_TLS,
    'username' => 'USERNAME',
    'password' => 'PASSWORD',
    'protocol' => 'imap'
]);`}
        };

        let renderTemplate = (templateKey) => {
            let template = codeTemplates[templateKey]['codeAuth'];

            template = `// Replace "USERNAME" with the account id of a registered user you want to connect as.
// Replace "HOST" with the hostname or IP address of the IMAP proxy interface.
// NB! Make sure that firewall settings allow accessing the IMAP proxy interface.

` + template;

            let password = !document.getElementById('imapProxyServerPassword').value ? '<imap-proxy-access-token>' : (document.getElementById('exampleShowPassword').checked ? document.getElementById('imapProxyServerPassword').value : '******')

            let code = template.
                replace(/HOST/g, window.location.hostname).
                replace(/PORT/g, Number(document.getElementById('imapProxyServerPort').value) || 0).
                replace(/USE_TLS/g, document.getElementById('imapProxyServerTLSEnabled').checked ? 'true' : 'false').
                replace(/PHPIMAP_TLS/g, document.getElementById('imapProxyServerTLSEnabled').checked ? "'ssl'" : 'false').
                replace(/USERNAME/g, 'account_id').
                replace(/PASSWORD/g, password);

            return hljs.highlight(code, { language: codeTemplates[templateKey].lang }).value;
        }

        let renderExamples = () => {
            document.getElementById('example-node-imap-code').innerHTML = renderTemplate('nodeImap');
            document.getElementById('example-php-imap-code').innerHTML = renderTemplate('phpImap');

            document.getElementById('exampleShowPassword').disabled = !document.getElementById('imapProxyServerPassword').value;
        }

        for (let elm of document.querySelectorAll('.trigger-example-render')) {
            elm.addEventListener('change', renderExamples);
        }

        renderExamples();

        let loadingCertData = false;
        let loadedCertData = false;

        function loadCertData() {
            loadingCertData = true;

            for (let elm of document.querySelectorAll('#tlsModal .modal-show-error')) {
                elm.classList.add('hidden')
            }

            for (let elm of document.querySelectorAll('#tlsModal .modal-show-default')) {
                elm.classList.remove('hidden')
            }

            uiModal.open('#tlsModal');

            fetch('/admin/config/smtp/certificate', {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({
                    crumb: document.getElementById('crumb').value
                })
            }).then(res => {
                if (!res.ok) {
                    throw new Error(`HTTP error! status: ${res.status}`);
                }
                return res.json()
            }).then(data => {
                if (!data || !data.success) {
                    throw new Error(data && data.error || 'Request failed')
                }
                console.log(data)
                uiModal.close('#tlsModal');
                loadingCertData = false;
                loadedCertData = true;
                document.getElementById('imapProxyServerTLSEnabled').dataset.certificate = data.fingerprint

                paintCertData(data);
            }).catch(err => {
                console.error(err)
                loadingCertData = false;

                document.getElementById('imapProxyServerTLSEnabled').checked = false;
                renderExamples();

                for (let elm of document.querySelectorAll('#tlsModal .modal-show-error')) {
                    elm.classList.remove('hidden')
                }

                for (let elm of document.querySelectorAll('#tlsModal .modal-show-default')) {
                    elm.classList.add('hidden')
                }

                document.querySelector('#tlsModal .error-content').textContent = err.message;
            });
        }

        function checkLoadCerts() {
            if (document.getElementById('imapProxyServerTLSEnabled').checked &&
                !loadingCertData && !loadedCertData &&
                document.getElementById('imapProxyServerTLSEnabled').dataset.domain) {

                loadCertData();
            }
        }

        document.getElementById('imapProxyServerTLSEnabled').addEventListener('click', checkLoadCerts);
        document.getElementById('imapProxyServerTLSEnabled').addEventListener('change', checkLoadCerts);
    });
</script>
