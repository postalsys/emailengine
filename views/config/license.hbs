{{#if licenseInfo.details.trial}}
{{> ui/page-header title="License" icon="icon-[tabler--settings]" badgeLabel="trial" badgeVariant="warning"
class="mb-1"}}
{{else}}
{{#if licenseInfo.active}}
{{> ui/page-header title="License" icon="icon-[tabler--settings]" badgeLabel="active" badgeVariant="success"
class="mb-1"}}
{{else}}
{{> ui/page-header title="License" icon="icon-[tabler--settings]" badgeLabel="not activated" badgeVariant="error"
class="mb-1"}}
{{/if}}
{{/if}}

<p class="mb-6">
    EmailEngine requires a valid license key after the free trial period. Licensed under the <a href="/license.html"
        target="_blank" rel="noopener noreferrer" class="link link-animated">EmailEngine License</a>.
</p>

{{#if subexp}}
{{#> ui/stat-card variant="error" title="License Issue" icon="icon-[tabler--alert-triangle]" class="mb-6"}}

<p class="mb-2">
    Your license key is registered but the associated subscription appears to be inactive or the key has
    been invalidated.
</p>

<p class="mb-2">
    You can continue using EmailEngine for <strong>{{ngettext '%d day' '%d days' expiresDays}}</strong>.
    After that, you'll need a new license key.
</p>

<div>
    {{> ui/btn href="https://postalsys.com/plans" external=true label="Renew Subscription"
    icon="icon-[tabler--arrow-right]"}}
</div>

{{/ui/stat-card}}
{{/if}}

{{#unless licenseInfo.active}}

<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-body">
        <div class="float-right ms-4">
            {{> ui/btn href="https://postalsys.com/licenses" external=true label="Get a License"
            icon="icon-[tabler--arrow-right]"}}
        </div>
        <p>
            Purchase and manage license keys at <a href="https://postalsys.com/licenses" target="_blank"
                rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">Postal Systems License
                Central</a> (subscription required).
        </p>

    </div>
</div>

{{/unless}}

{{#if licenseInfo.active}}
<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-header flex items-center justify-between">
        <h6 class="card-title text-primary">Current License</h6>
        {{> ui/btn label="Remove License" variant="error" style="soft" size="sm" icon="icon-[tabler--trash]"
        id="unregister-license-link" overlay="#deleteLicense"}}
    </div>
    <div class="card-body">

        <dl class="ee-dl">

            <dt>License Key</dt>
            <dd>{{licenseInfo.details.key}} ({{licenseInfo.type}})</dd>

            <dt>Licensed To</dt>
            <dd>{{licenseInfo.details.licensedTo}}</dd>

            <dt>Environment</dt>
            <dd>{{licenseInfo.details.hostname}}</dd>

            {{#if licenseDetails.expires}}
            <dt>Expires</dt>
            <dd>In {{licenseDetails.expiresDays}} days</dd>
            {{/if}}

            {{#if licenseDetails.lt}}
            <dt>Expiration</dt>
            <dd>Never expires</dd>
            {{/if}}

        </dl>

    </div>
</div>

{{/if}}



{{#> ui/details summary="Add License Key" class="card bg-base-100 shadow-md mb-6" open=showLicenseText}}

{{#if licenseInfo.active}}<p class="mb-4">Replace your existing license with a new one. Get license keys from <a
        href="https://postalsys.com/licenses" target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer"
        class="link link-animated">Postal Systems License Central</a>.</p>{{/if}}

<form method="post" id="licenseForm" action="/admin/config/license">
    {{!-- no id: the layout already renders the #crumb element scripts read --}}
    <input type="hidden" name="crumb" value="{{crumb}}" />

    <div class="mb-6">
        {{> ui/btn label="Upload License File" variant="info" id="licenseFile" icon="icon-[tabler--file-import]"}}
    </div>

    <div class="mb-6">
        {{> ui/setting-ref name="license" href="/admin/swagger#/license/postV1License"}}
        {{#> ui/form-field id="licenseTextElement" label="Or paste license key here" error=errors.license}}
        <textarea class="textarea w-full droptxt autoselect{{#if errors.license}} is-invalid{{/if}}"
            id="licenseTextElement" name="license" rows="9" data-enable-grammarly="false" spellcheck="false"
            placeholder="-----BEGIN LICENSE-----" required>{{values.license}}</textarea>
        <span class="helper-text">Drag and drop or paste your license key</span>
        {{/ui/form-field}}
    </div>

    <div class="mb-2">
        {{> ui/btn label="Activate License" type="submit" icon="icon-[tabler--key]"}}
    </div>

</form>
{{/ui/details}}

{{#> ui/modal id="deleteLicense" title="Remove License"}}
<div class="modal-body">
    Remove the current license key from this EmailEngine instance?
</div>
<div class="modal-footer">
    <form method="post" action="/admin/config/license/delete" class="flex gap-2">
        <input type="hidden" name="crumb" value="{{crumb}}">
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#deleteLicense"}}
        {{> ui/btn label="Remove License" variant="error" type="submit"}}
    </form>
</div>
{{/ui/modal}}

<script>
    document.addEventListener('DOMContentLoaded', () => {
        let licenseTextElm = document.getElementById('licenseTextElement')
        let fileSelectElm = document.getElementById('licenseFile');
        fileSelectElm.addEventListener('click', (e) => {
            e.preventDefault();
            browseFileContents('text').then(licenseFileTxt => {
                if (licenseFileTxt) {
                    licenseFileTxt = (licenseFileTxt || '').toString().trim().substring(0, 10 * 1024)
                    licenseTextElm.value = licenseFileTxt;
                    if (licenseFileTxt.indexOf('BEGIN LICENSE') >= 0) {
                        document.getElementById('licenseForm').submit();
                    } else {
                        licenseTextElm.focus();
                        licenseTextElm.select();
                    }
                }
            }).catch(err => {
                console.error(err);
                if (err.code === 'NoFileSelected') {
                    return
                }
                showToast('Failed to read license key file\n' + err.message, 'alert-triangle');
            })
        });
    });
</script>
