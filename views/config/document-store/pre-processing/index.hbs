{{> document_store_header}}

<form method="post" action="/admin/config/document-store/pre-processing" id="edit-form">
    {{!-- no id: the layout already renders the #crumb element scripts read --}}
    <input type="hidden" name="crumb" value="{{crumb}}" />

    <input type="hidden" id="fn-content-element" name="contentFnJson" value="{{values.contentFnJson}}">
    <input type="hidden" id="map-content-element" name="contentMapJson" value="{{values.contentMapJson}}">

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="px-6 py-4 border-b border-base-content/10 flex items-start justify-between gap-4">
            <div>
                {{> ui/checkbox id="enabled" name="enabled" label="Enable pre-processing."
                checked=values.enabled error=errors.enabled
                hint="The Document Store Pre-processing feature lets you edit emails before saving them. Additionally, you can exclude certain emails from being stored altogether."}}
            </div>

            <div class="text-end space-y-1">
                {{> ui/setting-ref name="documentStorePreProcessingEnabled" class="whitespace-nowrap"}}

                {{#if values.enabled}}
                {{> ui/badge label="enabled" variant="success"}}
                {{else}}
                {{> ui/badge label="disabled" variant="warning"}}
                {{/if}}
            </div>
        </div>
        <div class="card-body space-y-4">



            <div>
                <div class="text-base-content/60 float-right code-link">[<a
                        href="https://emailengine.app/pre-processing-functions" target="_blank"
                        rel="noopener noreferrer" referrerpolicy="no-referrer"
                        class="link link-animated">documentation</a>]

                    [<a href="/admin/swagger#/Settings/postV1Settings" target="_blank" rel="noopener noreferrer"
                        referrerpolicy="no-referrer" class="link link-animated">documentStorePreProcessingFn</a>]
                </div>
                <label class="label-text" for="editor-fn">Filter function</label>
                <div class="mb-2 leading-tight">
                    <small>JavaScript code to determine if the email should be stored. If the code evaluates to
                        <code>true</code> then the email is synced to the document store, otherwise it is skipped. The
                        script includes <code>payload</code> as a global variable that contains the email data.
                        Use <code>env</code> to access <a href="/admin/config/webhooks#scriptEnv"
                            class="link link-animated">script variables</a>.</small>
                </div>
                {{#> ui/code-editor id="editor-fn" title="Filter function"}}
                <div class="editor-embed-content editor-embed-content-left editor-embed-content-right">
                    <a href="#" id="test-payload-btn">Set test payload</a>
                </div>

                <div class="editor-embed-content editor-embed-content-right editor-embed-content-left">
                    Evaluation result:
                    <span id="filter-res" class="text-info">no match</span>
                </div>

                <div class="editor-embed-content editor-embed-content-right">
                    {{> editor_scope_info}}
                </div>

                
                {{/ui/code-editor}}

            </div>


            <div>
                {{> ui/setting-ref name="documentStorePreProcessingMap"}}
                <label class="label-text" for="editor-map">Map function</label>
                <div class="mb-2 leading-tight">
                    <small>JavaScript code to modify email payload structure. Protected fields <code>id</code>,
                        <code>account</code>, <code>path</code>, <code>uid</code>, <code>specialUse</code>, and
                        <code>messageId</code> cannot be modified.
                        Use <code>env</code> to access <a href="/admin/config/webhooks#scriptEnv"
                            class="link link-animated">script variables</a>.</small>
                </div>

                <div class="grid grid-cols-1 gap-4 sm:grid-cols-12">
                    <div class="sm:col-span-7">
                        {{#> ui/code-editor id="editor-map" title="Mapping function"}}
                        <div class="editor-embed-content editor-embed-content-right">
                            {{> editor_scope_info}}
                        </div>
                        
                        {{/ui/code-editor}}
                    </div>
                    <div class="sm:col-span-5">
                        {{> ui/code-editor id="editor-map-preview" title="Mapping preview"}}
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="mb-6">
        {{> ui/btn label="Update settings" type="submit" icon="icon-[tabler--settings]"}}
    </div>
</form>

{{> filter_editor_js hasMap=true defaultTestPayload='{"account":"test","path":"INBOX","subject":"test email"}'}}
