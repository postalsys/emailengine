{{> ui/page-header title="Logging" icon="icon-[tabler--settings]" class="mb-1"}}

<p class="mb-6">
    Track API requests for debugging and monitoring. EmailEngine can log IMAP, SMTP, Gmail API, and MS Graph API
    activity (credentials and message content are never logged). Download logs anytime for troubleshooting.
</p>

<form method="post" action="/admin/config/logging">
    {{!-- no id: the layout already renders the #crumb element scripts read --}}
    <input type="hidden" name="crumb" value="{{crumb}}" />

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-body space-y-4">
            <div>
                {{> ui/setting-ref name="logs.all"}}
                {{> ui/checkbox id="settingsLogsAll" name="all" label="Enable Logging for All Accounts"
                checked=values.all error=errors.all}}
                <span class="helper-text">Turn on logging for every connected account. Use with caution-this can impact
                    performance with many accounts.<br>
                    <strong>Restart required</strong> after changing this setting.</span>
            </div>

            <div>
                {{> ui/setting-ref name="logs.maxLogLines"}}
                {{#> ui/form-field id="settingsLogsMaxLogLines" label="Log Storage Limit (per account)"
                error=errors.maxLogLines}}
                <input type="number" class="input{{#if errors.maxLogLines}} is-invalid{{/if}}"
                    id="settingsLogsMaxLogLines" min="0" max="10000000" name="maxLogLines"
                    value="{{values.maxLogLines}}" />
                <span class="helper-text">Maximum log entries to keep per account. Logs are stored in memory (Redis), so
                    choose wisely to avoid running out of RAM.</span>
                {{/ui/form-field}}
            </div>
        </div>
    </div>

    <div class="card bg-base-100 shadow-md mb-6">
        <div class="card-header">
            <h6 class="card-title text-primary">Error Reporting</h6>
        </div>
        <div class="card-body space-y-4">

            {{#if sentryEnvManaged}}
            <div class="alert alert-soft alert-info">Error reporting is currently managed by the
                <code>SENTRY_DSN</code> environment variable. The settings below are ignored until that variable is
                removed.</div>
            {{/if}}

            <div>
                {{> ui/setting-ref name="sentryEnabled"}}
                {{> ui/checkbox id="settingsSentryEnabled" name="sentryEnabled"
                label="Report Unhandled Errors to Sentry" checked=values.sentryEnabled error=errors.sentryEnabled
                disabled=sentryEnvManaged
                hint="Send unhandled errors to a Sentry server. Reports include stack traces, account IDs, and error details, but never credentials or message content. Changes apply within a minute - no restart needed."}}
            </div>

            <div>
                {{> ui/setting-ref name="sentryDsn"}}
                {{#> ui/form-field id="settingsSentryDsn" label="Sentry DSN" error=errors.sentryDsn}}
                <input type="text" class="input{{#if errors.sentryDsn}} is-invalid{{/if}}" id="settingsSentryDsn"
                    name="sentryDsn" placeholder="https://public-key@sentry.example.com/1" value="{{values.sentryDsn}}"
                    {{#if sentryEnvManaged}}disabled{{/if}} />
                <span class="helper-text">Leave empty to send reports to the Sentry instance run by the EmailEngine
                    developers (sentry.emailengine.dev). Enabling this temporarily during a support case helps to debug
                    problems with your installation. Set your own DSN to keep reports in-house.</span>
                {{/ui/form-field}}
            </div>
        </div>
    </div>

    <div class="mb-6">
        {{> ui/btn label="Save Changes" type="submit" icon="icon-[tabler--settings]"}}
    </div>

</form>
