{{> ui/page-header title="OAuth2" icon="icon-[tabler--settings]" class="mb-1"}}

<p class="mb-6">Configure OAuth2 settings for supported services.</p>

<nav class="tabs tabs-boxed mb-6 inline-flex" aria-label="OAuth2 providers">
    <a class="tab{{#if activeGmail}} tab-active{{/if}}" href="/admin/config/oauth-legacy">Gmail</a>
    <a class="tab{{#if activeOutlook}} tab-active{{/if}}" href="/admin/config/oauth-legacy/outlook">Outlook</a>
    <a class="tab{{#if activeGmailService}} tab-active{{/if}}" href="/admin/config/oauth-legacy/gmailService">Gmail
        Service Accounts</a>
    <a class="tab{{#if activeMailRu}} tab-active{{/if}}" href="/admin/config/oauth-legacy/mailRu">Mail.ru</a>
</nav>

{{#> ui/stat-card variant="info" icon="icon-[tabler--info-circle]" class="mb-6"}}

{{#if activeGmail}}
<div>Your OAuth2 project <strong>must</strong> have the following scopes enabled:</div>
<ul class="list-disc ps-6 my-2">
    <li><code>"https://mail.google.com/"</code> when using IMAP and SMTP
    <li><code>"https://www.googleapis.com/auth/gmail.modify"</code> when using Gmail API
</ul>
<div>Read about setting up the OAuth2 project in Google Cloud for <a href="https://emailengine.app/gmail-over-imap"
        target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">IMAP
        and SMTP</a> or for <a href="https://emailengine.app/gmail-api" target="_blank" rel="noopener noreferrer"
        referrerpolicy="no-referrer" class="link link-animated">Gmail API</a>.
</div>
{{/if}}

{{#if activeGmailService}}
<div>Your OAuth2 project <strong>must</strong> have the following scopes enabled:</div>
<ul class="list-disc ps-6 my-2">
    <li><code>"https://mail.google.com/"</code>
</ul>
<div>Read about setting up Google service accounts from <a href="https://emailengine.app/google-service-accounts/"
        target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">here</a>.

</div>
{{/if}}

{{#if activeOutlook}}
<div>Your OAuth2 project <strong>must</strong> have the following scopes enabled:</div>
<ul class="list-disc ps-6 my-2">
    <li><code>"IMAP.AccessAsUser.All"</code>
    <li><code>"SMTP.Send"</code>
    <li><code>"offline_access"</code>
</ul>
<div>
    Read about setting up the OAuth2 project in Azure Active Directory from <a
        href="https://emailengine.app/outlook-and-ms-365" target="_blank" rel="noopener noreferrer"
        referrerpolicy="no-referrer" class="link link-animated">here</a>.
</div>
{{/if}}

{{#if activeMailRu}}
<div>Your OAuth2 project <strong>must</strong> have the following scopes enabled:</div>
<ul class="list-disc ps-6 my-2">
    <li><code>"userinfo"</code>
    <li><code>"mail.imap"</code>
</ul>

<div class="alert alert-soft alert-info"><span><strong>NB!</strong> The required "mail.imap" scope might not be
        available for your <a href="https://oauth.mail.ru/app/" target="_blank" rel="noopener noreferrer"
            referrerpolicy="no-referrer" class="link link-animated">OAuth2 apps</a> by default.</span></div>
{{/if}}

{{/ui/stat-card}}

<form method="post" action="/admin/config/oauth-legacy">
    <input type="hidden" name="crumb" value="{{crumb}}" />
    <input type="hidden" name="provider" value="{{values.provider}}">

    <div class="card bg-base-100 shadow-md mb-6">

        <div class="card-body space-y-4">

            <p>Setting up OAuth2 credentials enables automatic refreshing of expired access tokens.</p>

            {{#if activeGmailService}}

            <div>
                {{> ui/btn label="Select service key file…" variant="info" id="serviceFile"
                icon="icon-[tabler--file-import]"}}
                <span class="helper-text">Select the JSON file you received after generating a new service key to
                    retrieve the service values.</span>
            </div>

            <div>
                {{> ui/setting-ref name="serviceClient"}}
                {{#> ui/form-field id="serviceClient" label="Service client" error=errors.serviceClient}}
                <input type="text" class="input{{#if errors.serviceClient}} is-invalid{{/if}}" id="serviceClient"
                    name="serviceClient" value="{{values.serviceClient}}" placeholder="Enter service client ID&mldr;" />
                <span class="helper-text">OAuth2 Service Client ID</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name="serviceKey"}}
                {{#> ui/form-field id="serviceKey" label="Secret service key" error=errors.serviceKey}}
                <textarea class="textarea w-full droptxt autoselect{{#if errors.serviceKey}} is-invalid{{/if}}"
                    id="serviceKey" name="serviceKey" rows="4" data-enable-grammarly="false" spellcheck="false" {{#if
                    hasServiceKey}}placeholder="Service key is set but not shown&mldr;" {{else}}
                    placeholder="Starts with &quot;-----BEGIN PRIVATE KEY-----&quot;&mldr;"
                    {{/if}}>{{values.serviceKey}}</textarea>
                {{/ui/form-field}}
            </div>

            {{else}}
            <div>
                {{> ui/setting-ref name=(concat values.provider "Enabled")}}
                {{> ui/checkbox id="oauth2Enabled" name="oauth2Enabled" label=(concat "Enable OAuth2 support for "
                providerName) checked=values.oauth2Enabled error=errors.oauth2Enabled}}
                <span class="helper-text">If enabled, <em>"{{providerName}}"</em> will appear as an account type option
                    when adding accounts through the hosted authentication form.</span>
            </div>

            <div>
                {{> ui/setting-ref name=(concat values.provider "ClientId")}}
                {{#> ui/form-field id="clientId" error=errors.clientId}}
                <label class="label-text" for="clientId">
                    {{#if activeGmail}}
                    Client Id
                    {{/if}}

                    {{#if activeMailRu}}
                    Client Id
                    {{/if}}

                    {{#if activeOutlook}}
                    Application Id
                    {{/if}}
                </label>
                <input type="text" class="input{{#if errors.clientId}} is-invalid{{/if}}" id="clientId" name="clientId"
                    value="{{values.clientId}}" placeholder="Enter client ID&mldr;" />
                <span class="helper-text">OAuth2 client id.</span>
                {{/ui/form-field}}
            </div>

            <div>
                {{> ui/setting-ref name=(concat values.provider "ClientSecret")}}
                {{#> ui/form-field id="clientSecret" label="Client Secret" error=errors.clientSecret}}
                <input type="text" class="input{{#if errors.clientSecret}} is-invalid{{/if}}" id="clientSecret"
                    name="clientSecret" value="{{values.clientSecret}}" {{#if hasClientSecret}}
                    placeholder="Client secret is set but not shown&mldr;" {{else}} placeholder="Enter client
                    secret&mldr;" {{/if}} />
                <span class="helper-text">OAuth2 client secret.</span>
                {{/ui/form-field}}
            </div>

            {{#if activeOutlook}}
            <div>
                {{> ui/setting-ref name=(concat values.provider "Authority")}}
                {{#> ui/form-field id="authority" label="Supported account types" error=errors.authority}}
                <input type="text" class="input{{#if errors.authority}} is-invalid{{/if}}" id="authority"
                    name="authority" value="{{values.authority}}" />
                <span class="helper-text">Supported account types. Usually "consumers" for Microsoft accounts,
                    "organizations" for Organisation accounts only and "common" for both type of accounts.</span>
                {{/ui/form-field}}
            </div>
            {{/if}}

            <div>
                {{> ui/setting-ref name=(concat values.provider "RedirectUrl")}}
                {{#> ui/form-field id="redirectUrl" label="Redirect URL" error=errors.redirectUrl}}
                <input type="url" class="input{{#if errors.redirectUrl}} is-invalid{{/if}}" id="redirectUrl"
                    name="redirectUrl" value="{{values.redirectUrl}}" />
                <span class="helper-text">Redirect URL for OAuth2. If you are using EmailEngine's OAuth2 flow, set this
                    to <code>{{defaultRedirectUrl}}</code></span>
                {{/ui/form-field}}
            </div>
            {{/if}}

        </div>
    </div>

    {{#> ui/details summary="Additional scopes" class="card bg-base-100 shadow-md mb-6" open=values.extraScopes}}

    <p class="mb-[1rem]">Here you can list additional OAuth2 scopes that EmailEngine should ask for. This is mainly
        needed when you want to re-use the access tokens generated by EmailEngine in other parts of your application.
    </p>

    {{#if activeGmail}}
    <div class="alert alert-soft alert-info mb-[1rem]"><span>When adding new scopes, ensure that related APIs are
            enabled for your OAuth2 app (look for <em>Enabled APIs & services</em> in <a
                href="https://console.cloud.google.com/apis/dashboard" target="_blank" rel="noopener noreferrer"
                referrerpolicy="no-referrer" class="link link-animated">Google Cloud Console</a>)
            before registering accounts with these permissions. Otherwise, token generations will fail.</span>
    </div>
    {{/if}}

    {{#if activeGmailService}}
    <div class="alert alert-soft alert-info mb-[1rem]"><span>When adding new scopes, ensure that related APIs are
            enabled for your OAuth2 app (look for <em>Enabled APIs & services</em> in <a
                href="https://console.cloud.google.com/apis/dashboard" target="_blank" rel="noopener noreferrer"
                referrerpolicy="no-referrer" class="link link-animated">Google Cloud Console</a>)
            before registering accounts with these permissions. Otherwise, token generations will fail.</span>
    </div>
    {{/if}}

    <div>
        {{> ui/setting-ref name=(concat values.provider "ExtraScopes")}}
        {{#> ui/form-field id="extraScopes" label="List of OAuth2 scopes" error=errors.extraScopes}}
        <textarea class="textarea w-full{{#if errors.extraScopes}} is-invalid{{/if}}" id="extraScopes"
            name="extraScopes" rows="5" spellcheck="false" data-enable-grammarly="false"
            placeholder="Scope identifiers like &quot;https://mail.google.com/&quot;&mldr;">{{values.extraScopes}}</textarea>
        <span class="helper-text">Keep one scope per line</span>
        {{/ui/form-field}}
    </div>


    {{/ui/details}}

    <div class="mb-6">
        {{> ui/btn label="Update settings" type="submit" icon="icon-[tabler--settings]"}}
    </div>
</form>

<script>

    document.addEventListener('DOMContentLoaded', () => {

        let serviceFileElm = document.getElementById('serviceFile');
        if (serviceFileElm) {
            serviceFileElm.addEventListener('click', e => {
                e.preventDefault();
                browseFileContents('text').then(jsonStr => {
                    if (!jsonStr) {
                        return
                    }

                    let data;
                    try {
                        data = JSON.parse(jsonStr);
                    } catch (err) {
                        return showToast('Selected file is not JSON formatted', 'alert-triangle');
                    }

                    if (data.type !== 'service_account') {
                        return showToast('Selected file is not in a service key format', 'alert-triangle');
                    }

                    if (!data.client_id || !data.private_key) {
                        return showToast('Selected file does not contain required values', 'alert-triangle');
                    }

                    document.getElementById('serviceClient').value = data.client_id;
                    document.getElementById('serviceKey').value = data.private_key;

                    return showToast('Loaded service values from file', 'check-circle');

                }).catch(err => {
                    console.error(err);
                    return showToast('Failed to load service key file', 'alert-triangle');
                });
            });
        }

    });

</script>
