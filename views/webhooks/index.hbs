{{#> ui/page-header title="Webhook Routing" icon="icon-[tabler--webhook]" class="mb-6"}}
{{> ui/btn href=newLink label="Create webhook route" icon="icon-[tabler--plus]"}}
{{/ui/page-header}}


{{#unless webhooksEnabled}}
<div class="alert alert-soft alert-warning mb-6"><span><strong>Note:</strong> Webhook processing is currently disabled
        for EmailEngine.
        <a href="/admin/config/webhooks" class="link link-animated">Enable webhooks in configuration
            settings</a>.</span></div>
{{/unless}}

<p class="mb-6">Webhook routing allows you to define custom conditions that trigger webhooks to specific targets.</p>

{{#> ui/stat-card variant="info" icon="icon-[tabler--info-circle]" class="mb-6" title=""}}
<p class="mb-2">
    EmailEngine tests all events against <em>filter functions</em> of webhook routes. When
    a filter matches, EmailEngine sends a webhook to the target URL of that route. If
    the webhook target requires a specific payload format, you can define a <em>mapping
        function</em> to modify the payload before sending.
</p>
<p><a href="https://docs.emailengine.app/low-code-integrations/" target="_blank" rel="noopener noreferrer"
        referrerpolicy="no-referrer" class="link link-animated">Learn more about webhook routes</a>.</p>
{{/ui/stat-card}}

{{#if webhooks}}
<div class="card bg-base-100 shadow-md mb-6">
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Triggered</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                {{#each webhooks}}
                <tr class="hover:bg-base-200/60">
                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/webhooks/webhook/" id) label="Open webhook route"}}<strong>{{name}}</strong>
                    </td>

                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/webhooks/webhook/" id)}}{{description}}
                    </td>

                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/webhooks/webhook/" id)}}{{tcount}}
                    </td>

                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/webhooks/webhook/" id)}}
                        {{#if enabled}}

                        {{#if webhookErrorFlag.message}}
                        {{> ui/badge label="Failing" variant="error"}}
                        {{else}}
                        {{> ui/badge label="Enabled" variant="success"}}
                        {{/if}}
                        {{else}}
                        {{> ui/badge label="Disabled" variant="warning"}}
                        {{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    {{> ui/pagination showPaging=showPaging prevPage=prevPage nextPage=nextPage pageLinks=pageLinks}}
</div>
{{else}}
{{#> ui/card}}
        <p>
            {{#if firstPage}}
            No webhook routes have been created yet.
            {{else}}
            No webhook routes found.
            {{/if}}
        </p>
    
{{/ui/card}}
{{/if}}
