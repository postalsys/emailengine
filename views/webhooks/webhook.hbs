{{> webhooks_header}}

{{> ui/breadcrumb parentHref="/admin/webhooks" parentLabel="Webhook Routing" current=webhook.name class="mt-6 mb-6"}}

<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-body">

        <div class="mb-6 flex flex-wrap gap-2" role="toolbar" aria-label="Webhook route actions">

            {{#> ui/tooltip text="Edit Webhook Route contents"}}
            <a class="btn btn-soft btn-sm" href="/admin/webhooks/webhook/{{webhook.id}}/edit">
                <span class="icon-[tabler--file-pencil] size-4"></span> Edit route
            </a>
            {{/ui/tooltip}}

            {{#> ui/tooltip text="Delete this Webhook Route"}}
            <button type="button" class="btn btn-soft btn-sm" data-overlay="#deleteModal" id="delete-btn">
                <span class="icon-[tabler--trash] size-4"></span> Delete route
            </button>
            {{/ui/tooltip}}
        </div>

        {{#if webhook.description}}
        <h5 class="card-title">{{webhook.name}}</h5>
        <h6 class="mb-6 text-base-content/60">{{webhook.description}}</h6>
        {{else}}
        <h5 class="card-title mb-6">{{webhook.name}}</h5>
        {{/if}}

        {{#if webhook.webhookErrorFlag.message}}
        {{!-- dismissable error alert: app.js binds the close button directly
              and clears the stored error server-side --}}
        <div class="alert alert-soft alert-error clear-alert-btn mb-6 block" data-clear-alert="webhook-route"
            data-clear-entry="{{webhook.id}}">
            <button type="button" class="close float-right" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>

            <p><strong>Warning:</strong> The last attempted webhook failed with the response below.</p>
            <hr class="my-2">
            <p class="mb-0">
                <code>
            {{webhook.webhookErrorFlag.message}}
        </code>
            </p>
        </div>
        {{/if}}


        <dl class="ee-dl">

            {{#if webhook.targetUrlShort}}
            <dt>Webhook Target</dt>
            <dd>
                {{#> ui/tooltip text=webhook.targetUrl}}<em>{{webhook.targetUrlShort}}</em>{{/ui/tooltip}}
            </dd>
            {{/if}}

            <dt>Trigger count</dt>
            <dd>
                {{#> ui/tooltip text="How many times this route has been triggered"}}
                {{> ui/badge label=webhook.tcount variant="neutral" soft=true pill=true}}
                {{/ui/tooltip}}
            </dd>

            {{#if webhook.customHeaders}}
            <dt>Custom request headers</dt>
            <dd>
                {{#each webhook.customHeaders as |header|}}
                {{#> ui/tooltip text=(concat header.key ": " header.value)}}
                {{#> ui/badge soft=true}}<span class="font-mono">{{header.key}}</span>{{/ui/badge}}
                {{/ui/tooltip}}
                {{/each}}
            </dd>
            {{/if}}

            <dt>Status</dt>
            <dd>
                {{#if webhook.enabled}}
                {{> ui/badge label="Enabled" variant="success"}}
                {{else}}
                {{> ui/badge label="Disabled" variant="warning"}}
                {{/if}}
            </dd>

        </dl>

        <div class="mt-6">
            <nav class="tabs tabs-bordered" aria-label="Webhook route functions" role="tablist" data-tabs>
                <button type="button" class="tab active" id="fn-tab" data-tab="#fn" role="tab" aria-controls="fn"
                    aria-selected="true">Filter function</button>

                <button type="button" class="tab" id="map-tab" data-tab="#map" role="tab" aria-controls="map"
                    aria-selected="false">Map function</button>

                {{#if errorLog}}
                <button type="button" class="tab" id="errors-tab" data-tab="#errors" role="tab" aria-controls="errors"
                    aria-selected="false">Error log</button>
                {{/if}}

            </nav>
            <div class="mt-[1rem]">
                <div id="fn" role="tabpanel" aria-labelledby="fn-tab">

                    <div id="fn-preview" class="code-editor">{{webhook.content.fn}}</div>

                </div>
                <div id="map" class="hidden" role="tabpanel" aria-labelledby="map-tab">

                    <div id="map-preview" class="code-editor">{{webhook.content.map}}</div>

                </div>


                {{#if errorLog}}
                <div id="errors" class="hidden" role="tabpanel" aria-labelledby="errors-tab">


                    <p class="mb-[1rem]">The following errors were thrown when executing the functions for this route.
                        Only the most recent errors are shown.</p>

                    <div class="overflow-x-auto">
                        <table class="table">

                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Function</th>
                                    <th width="40%">Error</th>
                                    <th width="40%">Payload</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each errorLog}}

                                <tr>

                                    <td>
                                        <span class="relative-time" data-time="{{created}}"></span>
                                    </td>

                                    <td>
                                        <strong>{{type}}</strong>
                                    </td>

                                    <td>
                                        <textarea class="error-log-field" readonly>{{error}}</textarea>
                                    </td>

                                    <td>
                                        <textarea class="error-log-field" readonly>{{json payload}}</textarea>
                                    </td>

                                </tr>

                                {{/each}}
                            </tbody>

                        </table>
                    </div>

                </div>
                {{/if}}

            </div>
        </div>
    </div>
</div>

{{#> ui/modal id="deleteModal" title="Delete Webhook Route"}}
<div class="modal-body">
    <p>Are you sure you want to delete <strong>{{webhook.name}}</strong>? This action cannot be
        undone.</p>
</div>
<div class="modal-footer">
    <form method="post" action="/admin/webhooks/delete" class="flex gap-2">
        <input type="hidden" name="crumb" value="{{crumb}}" />
        <input type="hidden" name="webhook" value="{{webhook.id}}" />
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#deleteModal"}}
        {{> ui/btn label="Delete route" variant="error" type="submit"}}
    </form>
</div>
{{/ui/modal}}

<script src="/static/js/ace/ace.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', () => {

        const JSHINT_OPTS = {
            esversion: 11,
            module: true,
            globals: ['payload', 'URL', 'logger', 'fetch']
        }

        const editorFn = ace.edit("fn-preview", {
            showGutter: true,
            useWorker: false
        });

        const editorMap = ace.edit("map-preview", {
            showGutter: true,
            useWorker: false
        });

        editorFn.setReadOnly(true);
        editorFn.setShowPrintMargin(false);
        editorFn.setHighlightActiveLine(false);

        editorMap.setReadOnly(true);
        editorMap.setShowPrintMargin(false);
        editorMap.setHighlightActiveLine(false);

        editorFn.setTheme("ace/theme/kuroir");
        editorFn.session.setMode("ace/mode/javascript");

        editorMap.setTheme("ace/theme/kuroir");
        editorMap.session.setMode("ace/mode/javascript");

        editorFn.session.on('changeMode', function (e, session) {
            if ("ace/mode/javascript" === session.getMode().$id) {
                if (!!session.$worker) {
                    session.$worker.send("setOptions", [JSHINT_OPTS]);
                }
            }
        });

        editorMap.session.on('changeMode', function (e, session) {
            if ("ace/mode/javascript" === session.getMode().$id) {
                if (!!session.$worker) {
                    session.$worker.send("setOptions", [JSHINT_OPTS]);
                }
            }
        });

        let errorFields = document.querySelectorAll('.error-log-field');
        for (let i = 0; i < errorFields.length; i++) {
            let errorField = errorFields[i];
            errorField.addEventListener('focus', e => {
                errorField.select();
            });
        }

    })
</script>
