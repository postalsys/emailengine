{{!-- BullMQ queue stat card. Param names deliberately avoid title/class/
      variant/icon/value/id, which would fall through into the nested ui/*
      partials (hash values mask context inside partial blocks). --}}
{{#*inline "queueCard"}}
<div class="relative">
    {{#if queue.isPaused}}
    <div class="absolute end-4 top-2 z-[1]">
        {{#> ui/tooltip text="EmailEngine is not processing entries in this queue"}}
        {{> ui/badge label="paused" variant="warning"}}
        {{/ui/tooltip}}
    </div>
    {{/if}}
    {{#> ui/stat-card variant="primary" icon="icon-[tabler--refresh]" title=""}}
    <div class="text-sm font-medium text-base-content/60 mb-1">
        {{#> ui/tooltip text=tooltip}}
        <a href="{{href}}" class="link link-animated">{{label}}</a>
        {{/ui/tooltip}}
    </div>
    <div class="text-xl font-semibold text-base-content">
        {{#> ui/tooltip text="Queue entries total"}}{{formatInteger queue.total userLocale}}{{/ui/tooltip}} /
        {{#> ui/tooltip text=delayedTooltip}}{{formatInteger queue.delayed userLocale}}{{/ui/tooltip}}
    </div>
    {{/ui/stat-card}}
</div>
{{/inline}}

{{!-- Activity counter card: success value with an optional failure sub-line that turns
      red when non-zero. Param names avoid title/icon/variant/value/id/class, which would
      fall through into the nested ui/* partials. --}}
{{#*inline "activityCard"}}
{{#> ui/stat-card variant="primary" icon=cardIcon}}
<div class="text-sm font-medium text-base-content/60 mb-1">
    {{#> ui/tooltip text=cardTip}}{{cardLabel}}{{/ui/tooltip}}
</div>
<div class="text-xl font-semibold text-base-content">{{formatInteger okValue userLocale}}</div>
{{#if failLabel}}
<div class="mt-1 text-xs font-medium{{#if failValue}} text-error{{else}} text-base-content/50{{/if}}">
    {{formatInteger failValue userLocale}} {{failLabel}}</div>
{{/if}}
{{/ui/stat-card}}
{{/inline}}

<div class="mx-auto max-w-7xl">

    {{#> ui/page-header title="Dashboard" icon="icon-[tabler--dashboard]" class="mb-1"}}
    {{> ui/btn label="Add account" icon="icon-[tabler--user-plus]" overlay="#addAccount"}}
    {{/ui/page-header}}

    {{#each redisWarnings}}
    {{#> ui/stat-card variant=(eeColor color) title=title icon="icon-[tabler--alert-circle]" class="mt-6"}}
    {{#each details}}
    <p class="mb-4">{{this}}</p>
    {{/each}}
    {{/ui/stat-card}}
    {{/each}}

    {{#if documentStoreUnavailable}}
    {{#> ui/stat-card variant="error" title="Document Store unavailable" icon="icon-[tabler--database]" class="mt-6"}}
    <p class="mb-0">The Document Store is enabled in the EmailEngine settings, but the feature is not
        available because EmailEngine was not started with the Document Store enabled. The deprecated
        Document Store only runs when started with the <code>--documentStore.enabled</code> command line
        flag or the <code>EENGINE_DOCUMENT_STORE_ENABLED=true</code> environment variable. Until then the
        document store worker is not running and all Document Store API and configuration endpoints
        return 404. Either restart EmailEngine with the flag, or disable the <code>documentStoreEnabled</code>
        setting to clear this warning.</p>
    {{/ui/stat-card}}
    {{/if}}

    {{#unless hasAccounts}}
    {{#> ui/stat-card variant="success" title="Welcome to EmailEngine!" icon="icon-[tabler--info-circle]" class="mt-6"}}
    <p class="mb-2">Get started by connecting your first email account. Once connected, you can send
        and receive emails through the <a href="/admin/swagger" class="link link-animated">API</a>.
    </p>
    <p class="mb-4 text-sm text-base-content/60">You can also add accounts programmatically via the <a
            href="https://learn.emailengine.app/docs/api/post-v-1-account" target="_blank" rel="noopener noreferrer"
            referrerpolicy="no-referrer" class="link link-animated">API endpoint</a>.
    </p>
    <div>
        {{> ui/btn label="Connect your first account" icon="icon-[tabler--user-plus]" overlay="#addAccount"}}
    </div>
    {{/ui/stat-card}}
    {{/unless}}

    {{> ui/section-title label="Accounts" class="mt-6 mb-3"}}

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">

        {{#> ui/stat-card variant="primary" icon="icon-[tabler--users]"}}
        <div class="text-sm font-medium text-base-content/60 mb-1">
            {{#> ui/tooltip text="The number of accounts registered with EmailEngine"}}
            <a href="/admin/accounts" class="link link-animated">Total accounts</a>
            {{/ui/tooltip}}
        </div>
        <div class="text-xl font-semibold text-base-content">{{formatInteger stats.accounts userLocale}}</div>
        {{/ui/stat-card}}

        {{#> ui/stat-card variant="success" icon="icon-[tabler--circle-check]"}}
        <div class="text-sm font-medium text-base-content/60 mb-1">
            {{#> ui/tooltip text="Accounts currently connected or syncing"}}
            <a href="/admin/accounts?state=connected" class="link link-animated">Connected</a>
            {{/ui/tooltip}}
        </div>
        <div class="text-xl font-semibold text-base-content">{{formatInteger stats.connectedAccounts userLocale}}</div>
        {{/ui/stat-card}}

        {{#> ui/stat-card variant=(when attentionCount "error" "success") icon="icon-[tabler--alert-triangle]"}}
        <div class="text-sm font-medium text-base-content/60 mb-1">
            {{#> ui/tooltip text="Accounts with authentication or connection failures"}}
            <a href="/admin/accounts?state=errors" class="link link-animated">Needs attention</a>
            {{/ui/tooltip}}
        </div>
        <div class="text-xl font-semibold text-base-content">{{formatInteger attentionCount userLocale}}</div>
        {{/ui/stat-card}}

    </div>

    {{#if stateChips}}
    <div class="mt-3 flex flex-wrap gap-2">
        {{#each stateChips}}
        <a href="/admin/accounts?state={{state}}" class="badge badge-soft badge-{{variant}}">{{label}}:
            {{formatInteger count ../userLocale}}</a>
        {{/each}}
    </div>
    {{/if}}

    {{#> ui/section-title label="Activity" class="mt-8 mb-3"}}
    <div class="join">
        {{#each activityWindows}}
        <a href="{{url}}" class="btn btn-xs join-item{{#if active}} btn-primary{{else}} btn-soft{{/if}}">{{label}}</a>
        {{/each}}
    </div>
    {{/ui/section-title}}

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">

        {{> activityCard cardIcon="icon-[tabler--mail]" cardTip="Detected new emails in synced mailboxes"
        cardLabel="New emails" okValue=activity.messageNew}}

        {{> activityCard cardIcon="icon-[tabler--mail-forward]" cardTip="Emails accepted by MTA servers for delivery"
        cardLabel="Emails sent" okValue=activity.submitSuccess failValue=activity.submitFail failLabel="rejected"}}

        {{> activityCard cardIcon="icon-[tabler--webhook]" cardTip="Successfully delivered webhook notifications"
        cardLabel="Webhooks delivered" okValue=activity.webhooksSuccess failValue=activity.webhooksFail
        failLabel="failed"}}

        {{> activityCard cardIcon="icon-[tabler--file-code]" cardTip="API calls with successful responses"
        cardLabel="API calls" okValue=activity.apiSuccess failValue=activity.apiFail failLabel="failed"}}

    </div>

    {{> ui/section-title label="System" class="mt-8 mb-3"}}

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">

        {{> queueCard queue=stats.queues.notify href="/admin/bull-board/queue/Webhooks%20Queue%20-%20notify" label="Webhooks queue" tooltip="This queue processes webhook notifications" delayedTooltip="Delayed queue entries"}}

        {{> queueCard queue=stats.queues.submit href="/admin/bull-board/queue/Submission%20Queue%20-%20submit" label="Submission queue" tooltip="This queue processes emails to be sent via SMTP" delayedTooltip="Delayed queue entries, including emails scheduled to be sent later"}}

        {{#if showDocumentStore}}
        {{> queueCard queue=stats.queues.documents href="/admin/bull-board/queue/Document%20Queue%20-%20documents" label="Documents queue" tooltip="This queue indexes mailbox changes to Elasticsearch" delayedTooltip="Delayed queue entries"}}
        {{/if}}

        {{#> ui/stat-card variant=(eeColor redisPing.color) icon=redisPing.icon}}
        <div class="text-sm font-medium text-base-content/60 mb-1">
            {{#if redisPing.comment}}
            {{#> ui/tooltip text=redisPing.comment}}{{redisPing.title}}{{/ui/tooltip}}
            {{else}}
            {{redisPing.title}}
            {{/if}}
        </div>
        <div class="text-xl font-semibold text-base-content">{{redisPing.value}}</div>
        {{/ui/stat-card}}

    </div>

    {{#> ui/details summary="Software versions" class="card bg-base-100 shadow-md mt-6 mb-6"}}
    <div>
            <ul class="divide-y divide-base-content/10">
                <li class="py-2"><a href="https://emailengine.app/" target="_blank" rel="noopener noreferrer"
                        referrerpolicy="no-referrer" class="link link-animated">EmailEngine</a>
                    v{{packageData.version}}</li>
                <li class="py-2"><a href="https://nodejs.org/en/" target="_blank" rel="noopener noreferrer"
                        referrerpolicy="no-referrer" class="link link-animated">Node.js</a> v{{stats.node}}
                    ({{stats.arch}})</li>
                <li class="py-2"><a href="https://redis.io/" target="_blank" rel="noopener noreferrer"
                        referrerpolicy="no-referrer" class="link link-animated">Redis</a> v{{stats.redis}}</li>
                <li class="py-2"><a href="https://imapflow.com/" target="_blank" rel="noopener noreferrer"
                        referrerpolicy="no-referrer" class="link link-animated">ImapFlow</a> v{{stats.imapflow}}</li>
                <li class="py-2"><a href="https://docs.bullmq.io/" target="_blank" rel="noopener noreferrer"
                        referrerpolicy="no-referrer" class="link link-animated">BullMQ</a> v{{stats.bullmq}}</li>
                {{#if stats.build.commit}}
                <li class="py-2">Code version: <a
                        href="https://github.com/postalsys/emailengine/tree/{{stats.build.commit}}" target="_blank"
                        rel="noopener noreferrer" referrerpolicy="no-referrer"
                        class="link link-animated">{{stats.build.commit}}</a>
                </li>
                {{/if}}
            </ul>
    </div>
    {{/ui/details}}
</div>

{{!-- no #crumb input: the layout already renders the element scripts read --}}

{{>add_account_modal}}
