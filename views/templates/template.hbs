{{> templates_header}}

{{#if account}}
{{> ui/breadcrumb parentHref="/admin/templates" parentLabel="Templates" midHref=accountTemplatesLink midLabel=account.name current=template.name class="mt-6 mb-6"}}
{{else}}
{{> ui/breadcrumb parentHref="/admin/templates" parentLabel="Templates" current=template.name class="mt-6 mb-6"}}
{{/if}}


<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-body">

        <div class="mb-6 flex flex-wrap gap-2" role="toolbar" aria-label="Template actions">

            {{#> ui/tooltip text="Edit template contents"}}
            <a class="btn btn-soft btn-sm" href="/admin/templates/template/{{template.id}}/edit">
                <span class="icon-[tabler--file-pencil] size-4"></span> Edit template
            </a>
            {{/ui/tooltip}}

            {{#> ui/tooltip text="Delete this template"}}
            <button type="button" class="btn btn-soft btn-sm" data-overlay="#deleteModal" id="delete-btn">
                <span class="icon-[tabler--trash] size-4"></span> Delete template
            </button>
            {{/ui/tooltip}}

            {{#> ui/tooltip text="Send test email using this template"}}
            <button type="button" class="btn btn-soft btn-sm" data-overlay="#sendTestModal" id="test-btn">
                <span class="icon-[tabler--mail-forward] size-4"></span> Send test email
            </button>
            {{/ui/tooltip}}

        </div>

        {{#if template.description}}
        <h5 class="card-title">{{template.name}}</h5>
        <h6 class="card-subtitle mb-6 text-base-content/60">{{template.description}}</h6>
        {{else}}
        <h5 class="card-title mb-6">{{template.name}}</h5>
        {{/if}}

        <dl class="ee-dl">

            <dt>Template ID</dt>
            <dd>
                <div class="flex max-w-md gap-2">
                    <input type="text" id="templateIdValue" class="input input-sm grow font-mono" aria-label="ID"
                        value="{{template.id}}" readonly>
                    {{#> ui/tooltip text="Copy to clipboard"}}
                    <button class="btn btn-primary btn-sm copy-btn" type="button" data-clipboard-action="copy"
                        data-clipboard-target="#templateIdValue" aria-label="Copy to clipboard">
                        <span class="icon-[tabler--copy] size-4"></span>
                    </button>
                    {{/ui/tooltip}}
                </div>
                <span class="helper-text">Use this ID value as the <em>"template"</em>
                    property when sending email.</span>
            </dd>

            {{#if account}}

            <dt>Account</dt>
            <dd><a href="/admin/accounts/{{account.account}}" class="link link-animated">{{account.name}}</a></dd>

            {{/if}}

            {{#if template.content.subject}}
            <dt>Subject</dt>
            <dd><strong>{{template.content.subject}}</strong></dd>
            {{/if}}

            {{#if template.content.previewText}}
            <dt>Preview text
                {{#> ui/tooltip text="Preview text appears in the inbox after the subject line."}}<span
                    class="icon-[tabler--help-circle] size-4 text-base-content/50 align-text-bottom"></span>{{/ui/tooltip}}
            </dt>
            <dd>{{template.content.previewText}}</dd>
            {{/if}}

            {{#if template.format}}
            <dt>HTML source format</dt>
            <dd><span class="font-mono">{{format.name}}</span></dd>
            {{/if}}

        </dl>

        <div class="mt-6">
            <nav class="tabs tabs-bordered" aria-label="Template content" role="tablist" data-tabs>
                <button type="button" class="tab active" id="html-tab" data-tab="#html" role="tab" aria-controls="html"
                    aria-selected="true">HTML</button>
                <button type="button" class="tab" id="text-tab" data-tab="#text" role="tab" aria-controls="text"
                    aria-selected="false">Plain text</button>
            </nav>
            <div class="mt-[1rem]">
                <div id="html" role="tabpanel" aria-labelledby="html-tab">

                    <div id="html-preview" class="code-editor">{{template.content.html}}</div>

                </div>
                <div id="text" class="hidden" role="tabpanel" aria-labelledby="text-tab">

                    <div id="text-preview" class="code-editor">{{template.content.text}}</div>

                </div>
            </div>
        </div>
    </div>
</div>

{{#> ui/modal id="deleteModal" title="Delete Template"}}
<div class="modal-body">
    <p>Are you sure you want to delete <strong>{{template.name}}</strong>? This action cannot be
        undone.</p>
</div>
<div class="modal-footer">
    <form method="post" action="/admin/templates/delete" class="flex gap-2">
        <input type="hidden" name="crumb" value="{{crumb}}" />
        <input type="hidden" name="template" value="{{template.id}}" />
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#deleteModal"}}
        {{> ui/btn label="Delete template" variant="error" type="submit"}}
    </form>
</div>
{{/ui/modal}}

{{!-- no #crumb input: the layout already renders the element the script reads --}}
<input type="hidden" id="template" value="{{template.id}}" />

{{#> ui/modal id="sendTestModal" title="Send test email" dialogClass="max-w-3xl"}}
<div class="modal-body space-y-4">

    {{#unless account}}
    {{> ui/form-field id="inputAccount" name="account" label="Account ID" required=true hint="The account ID to send email as."}}
    {{/unless}}

    {{> ui/form-field id="inputTo" name="inputTo" type="email" label="Recipient's email address" required=true hint="Where to send the test email to."}}

    {{#> ui/details id="jsonStructure" summary="Handlebars payload" class="card border border-base-content/10" summaryClass="px-4 py-2"}}
    <div>
        <div id="editor-json" class="code-editor" style="height: 10rem;"></div>
        <span class="helper-text">Enter the JSON structure for the
            "render.params" API parameter.<br /><code>"keyName"</code> property in this JSON structure
            becomes
            <code>\{{params.keyName}}</code> in the template.</span>
    </div>
    {{/ui/details}}

</div>
<div class="modal-footer">
    {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#sendTestModal"}}
    <button type="button" id="send-test-btn" class="btn btn-primary">
        <span class="icon-[tabler--mail-forward] size-4" id="send-test-icon"></span> Send email
    </button>
</div>
{{/ui/modal}}

{{#> ui/modal id="alertModal" titleId="alertModalLabel" title=" "}}
<div class="modal-body">
    <p id="alertModalContent"></p>
</div>
<div class="modal-footer">
    {{> ui/btn label="Close" variant="neutral" style="soft" overlay="#alertModal"}}
</div>
{{/ui/modal}}

<script src="/static/js/ace/ace.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {

        function showAlert(title, content) {
            document.getElementById('alertModalLabel').textContent = title;
            document.getElementById('alertModalContent').textContent = content;

            uiModal.open('#alertModal');
        }

        const editorJson = ace.edit("editor-json");
        editorJson.setTheme("ace/theme/xcode");
        editorJson.session.setMode("ace/mode/json");
        editorJson.session.setValue('{\n    "keyName": "key value"\n}');

        let inputAccount = document.getElementById('inputAccount')
        let inputTo = document.getElementById('inputTo')

        let sendTestBtn = document.getElementById("send-test-btn");

        document.getElementById('sendTestModal').addEventListener('open.overlay', () => {

            editorJson.session.setValue('{\n    "keyName": "value"\n}');

            if (inputAccount) {
                inputAccount.value = '';
            }
            inputTo.value = '';

            document.getElementById('jsonStructure').open = false;
        });

        let hasValidJson = true;

        function setStateUpdate() {
            let accountValue = true;
            if (inputAccount) {
                accountValue = inputAccount.value.trim();
            }

            let toValue = inputTo.value.trim();
            if (!accountValue || !toValue || !hasValidJson) {
                sendTestBtn.disabled = true;
            } else {
                sendTestBtn.disabled = false;
            }
        }

        editorJson.session.on('change', function (delta) {
            // delta.start, delta.end, delta.lines, delta.action
            let curval = editorJson.getValue().trim();
            try {
                if (curval) {
                    let parsed = JSON.parse(curval);
                    if (parsed && typeof parsed !== 'object') {
                        throw new Error('Not an object')
                    }
                }
                hasValidJson = true;
            } catch (err) {
                hasValidJson = false;
            }
            setStateUpdate();
        });

        if (inputAccount) {
            inputAccount.addEventListener('input', setStateUpdate);
            inputAccount.addEventListener('change', setStateUpdate);
            inputAccount.addEventListener('keyup', setStateUpdate);
        }

        inputTo.addEventListener('input', setStateUpdate);
        inputTo.addEventListener('change', setStateUpdate);
        inputTo.addEventListener('keyup', setStateUpdate);

        setStateUpdate();


        const sendTestPayload = async () => {

            const payload = {
                crumb: document.getElementById('crumb').value,
                template: document.getElementById('template').value
            }

            if (inputAccount) {
                payload.account = inputAccount.value.trim()
            }

            payload.to = inputTo.value.trim()

            let templateVars = editorJson.getValue().trim();
            if (templateVars) {
                templateVars = JSON.parse(templateVars);
            }

            if (templateVars && typeof templateVars === 'object') {
                payload.params = templateVars
            }

            const res = await fetch('/admin/templates/test', {
                method: 'post',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify(payload)
            })
            if (!res.ok) {
                throw new Error(`HTTP error! status: ${res.status}`);
            }

            const data = await res.json();

            if (data.error) {
                throw new Error(data.error);
            }

            return data;
        }

        let iconElm = document.getElementById('send-test-icon');
        let toggleSpinner = (enabled) => {

            if (enabled) {
                iconElm.classList.remove('icon-[tabler--loader-2]', 'animate-spin');
                iconElm.classList.add('icon-[tabler--mail-forward]');
                sendTestBtn.disabled = false;
            } else {
                iconElm.classList.remove('icon-[tabler--mail-forward]');
                iconElm.classList.add('icon-[tabler--loader-2]', 'animate-spin');
                sendTestBtn.disabled = true;
            }
        }

        let sending = false;
        function sendTestEmail() {
            if (sending) {
                return;
            }
            sending = true;
            toggleSpinner(false);
            sendTestPayload().then(info => {
                toggleSpinner(true);
                sending = false;

                uiModal.close('#sendTestModal');

                showAlert('Message sent', `${info.response} as ${info.queueId}`)
            }).catch(err => {
                toggleSpinner(true);
                sending = false;
                showAlert('Error', err.message);
            })
        }

        sendTestBtn.addEventListener('click', sendTestEmail);


        const editorHtml = ace.edit("html-preview", {
            showGutter: true
        });

        const editorText = ace.edit("text-preview", {
            showGutter: true
        });


        editorHtml.setReadOnly(true);
        editorHtml.setShowPrintMargin(false);
        editorHtml.setHighlightActiveLine(false);

        editorText.setReadOnly(true);
        editorText.setShowPrintMargin(false);
        editorText.setHighlightActiveLine(false);

        editorHtml.setTheme("ace/theme/kuroir");
        editorHtml.session.setMode("ace/mode/handlebars");

        editorText.setTheme("ace/theme/kuroir");
        editorText.session.setMode("ace/mode/handlebars");

    });
</script>
