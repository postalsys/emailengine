{{#> ui/page-header title="Templates" icon="icon-[tabler--template]" subtitle="Reusable subject and body content you can reference by ID when sending." badgeLabel=total badgeVariant="neutral" class="mb-6"}}
{{> ui/btn href=newLink label="Create template" icon="icon-[tabler--plus]"}}
{{/ui/page-header}}

{{#if query}}
{{> ui/search-crumb parentHref="/admin/templates" parentLabel="Templates" query=query}}
{{else if account}}
{{> ui/breadcrumb parentHref="/admin/templates" parentLabel="Templates" current=account.name class="mb-6"}}
{{/if}}

{{#if templates}}
<div class="card bg-base-100 shadow-md mb-6">
    {{#if account}}
    <div class="card-body">
        <div>
            Currently showing email templates for <strong><a href="/admin/accounts/{{account.account}}"
                    class="link link-animated">{{account.name}}</a></strong>. These templates cannot be
            used by other accounts.
        </div>
    </div>
    {{/if}}

    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th class="w-12"><span class="sr-only">Actions</span></th>
                </tr>
            </thead>

            <tbody>
                {{#each templates}}
                <tr class="hover:bg-base-200/60">

                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/templates/template/" id) label="Open template"}}
                        <div><strong>{{name}}</strong></div>
                        {{> ui/entity-id id=id label="Template ID"}}
                    </td>
                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/templates/template/" id)}}{{description}}
                    </td>

                    <td class="relative text-end">
                        {{> ui/row-actions openHref=(concat "/admin/templates/template/" id) label="Template actions"
                        deleteModal="#deleteTemplate" deleteId=id deleteName=name}}
                    </td>

                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    {{> ui/pagination showPaging=showPaging prevPage=prevPage nextPage=nextPage pageLinks=pageLinks}}
</div>
{{else}}
{{#> ui/list-empty noun="templates" query=query firstPage=firstPage createHref=newLink createLabel="Create your first template" clearHref="/admin/templates"}}
{{#if account}}
<div class="mb-2">
    Currently showing email templates for <strong><a href="/admin/accounts/{{account.account}}"
            class="link link-animated">{{#if account.name}}{{account.name}}{{else}}{{account.email}}{{/if}}</a></strong>.
    These templates cannot be used by other accounts.
</div>
{{/if}}
{{/ui/list-empty}}
{{/if}}

{{> ui/delete-modal id="deleteTemplate" noun="template" action="/admin/templates/delete" fieldName="template"}}

{{#> ui/details summary="Usage example" class="card bg-base-100 shadow-md mb-6"}}
<div>
        <p class="mb-4">When sending emails using the submission API endpoint, do not set <code>"subject"</code>,
            <code>"html"</code> and <code>"text"</code> properties. Instead, set the <code>"template"</code>
            property with the template ID value and, optionally, <code>"render"</code> definition if you are using
            Markdown format as the HTML source or you want to use the Handlebars variables.
        </p>

        <pre class="ee-code-block">$ curl "<span class="cur-base-url" data-origin="">http://127.0.0.1:3000</span>/v1/account/example/submit" \
  -H "Authorization: Bearer &lt;token&gt;" \
  -H "Content-type: application/json" \
  -d '{
    &quot;from&quot;: {
      &quot;name&quot;: &quot;sender name&quot;,
      &quot;address&quot;: &quot;sender@example.com&quot;
    },
    &quot;to&quot;: [
      {
        &quot;name&quot;: &quot;recipient name&quot;,
        &quot;address&quot;: &quot;recipient@example.com&quot;
      }
    ],
    &quot;template&quot;: &quot;AAABgUIbuG0AAAAE&quot;,
    &quot;render&quot;: {
      &quot;params&quot;: {
        &quot;key&quot;: &quot;value&quot;
      }
    }
  }'</pre>

        <hr class="my-4">
        <div class="text-base-content/60">
            <p>This example assumes that you use <code>\{{params.key}}</code> in the subject, html or plain-text
                content of the template.</p>
        </div>

        <p class="mt-4 mb-0"><a href="https://learn.emailengine.app/docs/sending/templates" target="_blank"
                rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">Learn more about
                templates</a>.</p>

</div>
{{/ui/details}}
