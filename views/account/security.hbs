{{> security_header}}

<div class="card bg-base-100 shadow-md mb-6">



    <div class="card-body">

        <ul class="divide-base-content/10 divide-y">

            <li class="py-4">
                <div class="grid grid-cols-3 items-center gap-4">
                    <div>Username</div>
                    <div>
                        {{username}}
                    </div>
                    <div class="text-end">
                        {{#if authData.enabled}}
                        {{> ui/btn label="Sign out everywhere" variant="primary" style="outline"
                        id="logout-all-btn" overlay="#logoutAllModal"}}
                        {{/if}}
                    </div>
                </div>
            </li>

            <li class="py-4">
                <div class="grid grid-cols-3 items-center gap-4">
                    <div>Password</div>
                    <div>
                        {{#if authData.enabled}} ******** {{else}}Not configured{{/if}}
                    </div>
                    <div class="text-end">
                        {{#if authData.enabled}}
                        {{> ui/btn label="Change password" variant="primary" style="outline" size="sm"
                        href="/admin/account/password"}}
                        {{else}}
                        {{> ui/btn label="Create password" variant="primary" style="outline" size="sm"
                        href="/admin/account/password"}}
                        {{/if}}
                    </div>
                </div>
            </li>

            {{#if authData.enabled}}
            <li class="py-4">
                <div class="grid grid-cols-3 items-center gap-4">
                    <div>Two-Factor Authentication (2FA)</div>
                    <div>
                        {{#if totp.enabled}}
                        {{> ui/badge label="Authenticator app" variant="success"}}
                        {{else}}
                        {{> ui/badge label="Not configured" variant="neutral" soft=true}}
                        {{/if}}
                    </div>
                    <div class="text-end">
                        {{#if totp.enabled}}
                        {{> ui/btn label="Disable 2FA" variant="error" style="outline" id="disable-tfa-btn"
                        overlay="#disableTfaModal"}}
                        {{else}}
                        {{> ui/btn label="Enable 2FA" variant="primary" style="outline" id="enable-tfa-btn"
                        overlay="#enableTfaModal"}}
                        {{/if}}
                    </div>
                </div>
            </li>

            <li class="py-4">
                <div class="grid grid-cols-3 items-start gap-4">
                    <div class="pt-1">Passkeys
                        <br><small class="text-base-content/60">Sign in with just a passkey - no password or additional
                            verification needed.</small>
                    </div>
                    <div>
                        {{#if passkeys.length}}
                        <ul class="mb-0 space-y-2">
                            {{#each passkeys}}
                            <li>
                                <strong>{{this.name}}</strong><br>
                                <small class="text-base-content/60">Added {{this.createdAtFormatted}}</small>
                                <form method="post" action="/admin/account/passkeys/delete" class="inline ms-2">
                                    <input type="hidden" name="crumb" value="{{../crumb}}" />
                                    <input type="hidden" name="credentialId" value="{{this.id}}" />
                                    <button type="submit" class="btn btn-sm btn-outline btn-error"
                                        title="Remove passkey" onclick="return confirm('Remove this passkey?');">
                                        Remove
                                    </button>
                                </form>
                            </li>
                            {{/each}}
                        </ul>
                        {{else}}
                        {{> ui/badge label="None registered" variant="neutral" soft=true}}
                        {{/if}}
                    </div>
                    <div class="text-end">
                        {{#if serviceUrl}}
                        {{> ui/btn label="Add passkey" variant="primary" style="outline" id="register-passkey-btn"
                        icon="icon-[tabler--fingerprint]"}}
                        {{else}}
                        {{#> ui/tooltip text="Set a Service URL in configuration before registering passkeys"}}
                        {{!-- pointer-events-none: disabled buttons swallow hover, which would keep
                              the wrapping tooltip from ever showing --}}
                        <button type="button" class="btn btn-outline btn-neutral pointer-events-none" disabled>
                            Add passkey
                        </button>
                        {{/ui/tooltip}}
                        <br><small class="text-base-content/60">Requires Service URL</small>
                        {{/if}}
                    </div>
                </div>
            </li>

            <li class="py-4">
                <div class="grid grid-cols-3 items-center gap-4">
                    <div>Single Sign-On (SSO)</div>
                    <div>
                        {{#if providers.okta}}
                        {{> ui/badge label="Okta" variant="success"}}
                        {{/if}}
                        {{#if providers.oidc}}
                        {{> ui/badge label=providers.oidc.name variant="success"}}
                        {{/if}}
                        {{#unless providers.any}}
                        {{> ui/badge label="Not configured" variant="neutral" soft=true}}
                        {{/unless}}
                    </div>
                    <div class="text-end space-y-1">
                        {{> ui/btn label="Okta setup" variant="primary" style="outline" id="sso-instructions"
                        overlay="#ssoInstructionsModal"}}
                        {{> ui/btn label="OIDC setup" variant="primary" style="outline" id="oidc-instructions"
                        overlay="#oidcInstructionsModal"}}
                    </div>
                </div>
            </li>
            {{/if}}
        </ul>
    </div>
</div>

{{#> ui/modal id="disableTfaModal" title="Disable two-factor authentication" titleId="disableTfaModalLabel"}}
<div class="modal-body">
    <p>Disabling two-factor authentication will make your account less secure. Are you sure you want to continue?</p>
</div>
<div class="modal-footer">
    <form method="post" action="/admin/account/tfa/disable" class="flex gap-2">
        <input type="hidden" name="crumb" value="{{crumb}}" />
        <input type="hidden" name="type" value="totp" />
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#disableTfaModal"}}
        {{> ui/btn label="Disable 2FA" variant="error" type="submit"}}
    </form>
</div>
{{/ui/modal}}

{{#> ui/modal id="enableTfaModal" title="Enable two-factor authentication" titleId="enableTfaModalLabel"}}
<form method="post" action="/admin/account/tfa/enable">
    <div class="modal-body space-y-4">

        <div>
            <img src="{{totp.dataUrl}}" class="mx-auto block max-w-[200px]" alt="TOTP QR code">
        </div>

        <div>
            {{#> ui/form-field id="code"
            label="Scan the QR code with your authenticator app (such as Google Authenticator or Authy), then enter the 6-digit verification code below."
            error=errors.code}}
            <input type="text" pattern="[0-9]{6}" class="input{{#if errors.code}} is-invalid{{/if}}" id="code"
                name="code" required />
            {{/ui/form-field}}
        </div>

    </div>
    <div class="modal-footer">

        <input type="hidden" name="crumb" value="{{crumb}}" />
        <input type="hidden" name="type" value="totp" />
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#enableTfaModal"}}
        {{> ui/btn label="Enable 2FA" type="submit"}}
    </div>
</form>
{{/ui/modal}}

{{#> ui/modal id="logoutAllModal" title="Sign out from all devices" titleId="logoutAllModalLabel"}}
<form method="post" action="/admin/account/logout-all">
    <div class="modal-body">

        <p>This will sign you out from all browsers and devices where you're currently signed in. You'll need to sign
            in again on each device.</p>

    </div>
    <div class="modal-footer">

        <input type="hidden" name="crumb" value="{{crumb}}" />
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#logoutAllModal"}}
        {{> ui/btn label="Sign out everywhere" type="submit" icon="icon-[tabler--logout]"}}
    </div>
</form>
{{/ui/modal}}

{{#> ui/modal id="ssoInstructionsModal" title="Configure Single Sign-On with Okta" titleId="ssoInstructionsModalLabel"
dialogClass="max-w-5xl"}}
<div class="modal-body">

    <p class="mb-2">Follow these steps to configure Single Sign-On with Okta:</p>
    <ol class="list-decimal ps-6 mb-4 space-y-1">
        <li>Create a new web application in your Okta dashboard using the Redirect URI below</li>
        <li>Configure the required environment variables for EmailEngine</li>
        <li>Restart EmailEngine to apply the changes</li>
    </ol>

    <p class="mb-4"><strong>Redirect URI for your Okta application:</strong><br>
        <code>{{serviceUrl}}/admin/login/okta</code>
    </p>

    <div class="overflow-x-auto">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Environment variable</th>
                    <th>Current value</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <th>
                        <code>OKTA_OAUTH2_ISSUER</code>
                    </th>
                    <td>
                        {{#if okta.OKTA_OAUTH2_ISSUER}}
                        <code class="inline-block overflow-hidden">{{okta.OKTA_OAUTH2_ISSUER}}</code>
                        {{else}}
                        Not configured (enter your Okta issuer URL)
                        {{/if}}
                    </td>
                </tr>

                <tr>
                    <th><code>OKTA_OAUTH2_CLIENT_ID</code></th>
                    <td>
                        {{#if okta.OKTA_OAUTH2_CLIENT_ID}}
                        <code class="inline-block overflow-hidden">{{okta.OKTA_OAUTH2_CLIENT_ID}}</code>
                        {{else}}
                        Not configured
                        {{/if}}
                    </td>
                </tr>

                <tr>
                    <th><code>OKTA_OAUTH2_CLIENT_SECRET</code></th>
                    <td>
                        {{#if okta.OKTA_OAUTH2_CLIENT_SECRET}}
                        <code class="inline-block overflow-hidden">{{okta.OKTA_OAUTH2_CLIENT_SECRET}}</code>
                        {{else}}
                        Not configured
                        {{/if}}

                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>
<div class="modal-footer">
    {{> ui/btn label="Close" variant="neutral" style="soft" overlay="#ssoInstructionsModal"}}
</div>
{{/ui/modal}}

{{#> ui/modal id="oidcInstructionsModal" title="Configure Single Sign-On with OIDC" titleId="oidcInstructionsModalLabel"
dialogClass="max-w-5xl"}}
<div class="modal-body">

    <p class="mb-4">EmailEngine works with any standards-compliant OpenID Connect provider - Keycloak, Authentik,
        Azure AD/Entra, Google Workspace, and others. The provider's endpoints are read automatically from
        its discovery document (<code>{{oidc.OIDC_ISSUER}}/.well-known/openid-configuration</code>)
        when EmailEngine starts.</p>

    <ol class="list-decimal ps-6 mb-4 space-y-1">
        <li>Register a confidential OIDC client (authorization code flow) in your identity provider using the
            Redirect URI below</li>
        <li>Configure the required environment variables for EmailEngine</li>
        <li>Restart EmailEngine to apply the changes</li>
    </ol>

    <p class="mb-4"><strong>Redirect URI for your OIDC client:</strong><br>
        <code>{{serviceUrl}}/admin/login/oidc</code>
    </p>

    <div class="overflow-x-auto">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Environment variable</th>
                    <th>Current value</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <th><code>OIDC_ISSUER</code></th>
                    <td>
                        {{#if oidc.OIDC_ISSUER}}
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_ISSUER}}</code>
                        {{else}}
                        Not configured (enter your OIDC issuer URL)
                        {{/if}}
                    </td>
                </tr>

                <tr>
                    <th><code>OIDC_CLIENT_ID</code></th>
                    <td>
                        {{#if oidc.OIDC_CLIENT_ID}}
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_CLIENT_ID}}</code>
                        {{else}}
                        Not configured
                        {{/if}}
                    </td>
                </tr>

                <tr>
                    <th><code>OIDC_CLIENT_SECRET</code></th>
                    <td>
                        {{#if oidc.OIDC_CLIENT_SECRET}}
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_CLIENT_SECRET}}</code>
                        {{else}}
                        Not configured
                        {{/if}}
                    </td>
                </tr>

                <tr>
                    <th><code>OIDC_PROVIDER_NAME</code><br><small class="text-base-content/60">optional</small></th>
                    <td>
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_PROVIDER_NAME}}</code>
                        <br><small class="text-base-content/60">Label shown on the sign-in button</small>
                    </td>
                </tr>

                <tr>
                    <th><code>OIDC_ALLOWED_USERS</code><br><small class="text-base-content/60">optional</small></th>
                    <td>
                        {{#if oidc.OIDC_ALLOWED_USERS}}
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_ALLOWED_USERS}}</code>
                        {{else}}
                        Not set
                        {{/if}}
                        <br><small class="text-base-content/60">Comma-separated allow-list of emails and/or
                            <code>@domain</code> entries</small>
                    </td>
                </tr>

                <tr>
                    <th><code>OIDC_ALLOWED_GROUPS</code><br><small class="text-base-content/60">optional</small></th>
                    <td>
                        {{#if oidc.OIDC_ALLOWED_GROUPS}}
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_ALLOWED_GROUPS}}</code>
                        {{else}}
                        Not set
                        {{/if}}
                        <br><small class="text-base-content/60">Comma-separated group names. A user is allowed if their
                            email matches <code>OIDC_ALLOWED_USERS</code> OR they belong to
                            one of these groups. When both are empty, anyone the identity provider authenticates
                            can sign in.</small>
                    </td>
                </tr>

                <tr>
                    <th><code>OIDC_GROUPS_CLAIM</code><br><small class="text-base-content/60">optional</small></th>
                    <td>
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_GROUPS_CLAIM}}</code>
                        <br><small class="text-base-content/60">userinfo claim that carries group membership (default
                            <code>groups</code>); may be a dotted path such as
                            <code>realm_access.roles</code></small>
                    </td>
                </tr>

                <tr>
                    <th><code>OIDC_FORCED</code><br><small class="text-base-content/60">optional</small></th>
                    <td>
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_FORCED}}</code>
                        <br><small class="text-base-content/60">When true, the login page redirects straight to the
                            identity provider and local password/passkey sign-in is disabled. If discovery fails at
                            startup the local form is shown as a fallback.</small>
                    </td>
                </tr>

                <tr>
                    <th><code>OIDC_LOGOUT</code><br><small class="text-base-content/60">optional</small></th>
                    <td>
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_LOGOUT}}</code>
                        <br><small class="text-base-content/60">When true, signing out also ends the identity-provider
                            session (RP-initiated logout via the end_session endpoint).</small>
                    </td>
                </tr>

                <tr>
                    <th><code>OIDC_POST_LOGOUT_REDIRECT_URI</code><br><small
                            class="text-base-content/60">optional</small></th>
                    <td>
                        {{#if oidc.OIDC_POST_LOGOUT_REDIRECT_URI}}
                        <code class="inline-block overflow-hidden">{{oidc.OIDC_POST_LOGOUT_REDIRECT_URI}}</code>
                        {{else}}
                        Not set - the identity provider shows its own logged-out page
                        {{/if}}
                        <br><small class="text-base-content/60">Where the IdP returns after logout (must be a registered
                            post logout redirect URI). Point it at
                            <code>{{serviceUrl}}/admin/login?loggedout=1</code> for an in-app
                            signed-out screen.</small>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <p class="mb-1"><strong>Keycloak example</strong></p>
    <ul class="list-disc ps-6 mb-4 space-y-1">
        <li>Issuer: <code>https://&lt;keycloak-host&gt;/realms/&lt;realm&gt;</code></li>
        <li>Client type: OpenID Connect, confidential (Client authentication on), Standard Flow enabled</li>
        <li>Valid redirect URI: <code>{{serviceUrl}}/admin/login/oidc</code></li>
        <li>For group-based access: add a <em>Group Membership</em> mapper to the client (Token Claim Name
            <code>groups</code>, "Add to userinfo" enabled), then set
            <code>OIDC_ALLOWED_GROUPS</code></li>
        <li>For return-to-app after logout (optional): set
            <code>OIDC_POST_LOGOUT_REDIRECT_URI</code> and add that URL to the client's
            Valid post logout redirect URIs</li>
    </ul>

    <p class="text-base-content/60 text-sm mb-0">Note: signing in via SSO is a standalone factor - TOTP is not
        prompted, and local password/passkey management is disabled for SSO sessions. With
        <code>OIDC_LOGOUT</code> off, signing out clears only the local EmailEngine
        session, not the identity-provider session.</p>

</div>
<div class="modal-footer">
    {{> ui/btn label="Close" variant="neutral" style="soft" overlay="#oidcInstructionsModal"}}
</div>
{{/ui/modal}}

{{#> ui/modal id="registerPasskeyModal" title="Register a new passkey" titleId="registerPasskeyModalLabel"}}
<div class="modal-body space-y-4">
    {{#if authData.enabled}}
    <div>
        {{#> ui/form-field id="passkey-current-password" label="Current password"}}
        <input type="password" class="input" id="passkey-current-password" placeholder="Enter your current password"
            maxlength="256" autocomplete="current-password" />
        <span class="helper-text">Confirm your identity before registering a new passkey.</span>
        {{/ui/form-field}}
    </div>
    {{/if}}
    <div>
        {{#> ui/form-field id="passkey-name" label="Passkey name"}}
        <input type="text" class="input" id="passkey-name" placeholder="e.g., MacBook Touch ID" maxlength="100" />
        <span class="helper-text">A friendly name to help you identify this passkey.</span>
        {{/ui/form-field}}
    </div>
    <div id="passkey-register-error" class="text-error text-sm hidden"></div>
    <div id="passkey-register-success" class="text-success text-sm hidden">
        Passkey registered successfully.
    </div>
</div>
<div class="modal-footer">
    <input type="hidden" id="security-crumb" value="{{crumb}}" />
    {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#registerPasskeyModal"}}
    {{> ui/btn label="Register passkey" id="passkey-register-confirm-btn"}}
</div>
{{/ui/modal}}

<script src="/static/vendor/simplewebauthn/browser.min.js"></script>
<script src="/static/js/passkey-register.js"></script>
