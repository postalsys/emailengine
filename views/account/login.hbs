<div class="text-center">
    <h1 class="text-xl font-semibold text-base-content mb-6">Sign in to EmailEngine</h1>
</div>

{{#if loggedOut}}
<div class="alert alert-soft alert-info justify-center mb-6" role="alert">You have been signed out.</div>
{{/if}}

{{#unless forceLogin}}
<form class="space-y-4" method="post" action="/admin/login">
    {{!-- the login layout renders no global #crumb, so the page provides it
          (login-passkey.js reads it by id) --}}
    <input type="hidden" id="crumb" name="crumb" value="{{crumb}}" />
    <input type="hidden" name="next" value="{{values.next}}" />

    <div>
        <input type="text" class="input{{#if errors.username}} is-invalid{{/if}}"
            id="loginUsername" name="username" placeholder="Username" value="{{values.username}}">
        {{#if errors.username}}
        <span class="helper-text text-error">{{errors.username}}</span>
        {{/if}}
    </div>
    <div>
        <input type="password" class="input{{#if errors.password}} is-invalid{{/if}}"
            id="loginPassword" name="password" placeholder="Password">
        {{#if errors.password}}
        <span class="helper-text text-error">{{errors.password}}</span>
        {{/if}}
    </div>

    <!-- Always enable persistent sessions; no UI toggle for now -->
    <input type="hidden" name="remember" value="Y" />
    <div>
        <button type="submit" class="btn btn-primary btn-block">
            Sign in
        </button>
    </div>
</form>

{{#if passkeysAvailable}}
<div class="divider text-base-content/60 text-sm my-4">or</div>
<div>
    <button type="button" class="btn btn-primary btn-block" id="passkey-login-btn">
        <span class="icon-[tabler--fingerprint] size-4"></span><span id="passkey-login-btn-label">Sign in with a passkey</span>
    </button>
    <div id="passkey-error" class="text-error text-sm mt-2 text-center hidden"></div>
</div>
{{/if}}
{{/unless}}

{{#if providers.any}}
{{#unless forceLogin}}
<div class="divider text-base-content/60 text-sm my-4">or</div>
{{/unless}}
{{#if providers.okta}}
<div class="mt-2">
    <a href="/admin/login/okta" class="btn btn-primary btn-block">
        <span class="icon-[tabler--login-2] size-4"></span>Sign in with Okta SSO
    </a>
</div>
{{/if}}
{{#if providers.oidc}}
<div class="mt-2">
    <a href="/admin/login/oidc" class="btn btn-primary btn-block">
        <span class="icon-[tabler--login-2] size-4"></span>Sign in with {{providers.oidc.name}}
    </a>
</div>
{{/if}}
{{/if}}

{{#unless forceLogin}}
<hr class="my-4">
<div class="text-center">
    <a class="link link-animated text-sm" href="https://emailengine.app/reset-password" target="_blank"
        rel="noopener noreferrer" referrerpolicy="no-referrer">Forgot your password?</a>
</div>
{{/unless}}
