{{> ui/page-header title="System Threads" icon="icon-[tabler--cpu]" class="mb-1"}}

{{#if apiWorkerWarning}}
<div class="alert alert-soft alert-warning mt-6 block" role="alert">
    <span class="icon-[tabler--alert-triangle] size-4 align-text-bottom"></span>
    <strong>Multiple API workers are not active.</strong>
    {{#equals apiWorkerWarning.reason "port"}}
    <code>EENGINE_WORKERS_API</code> is set to {{apiWorkerWarning.requested}}, but EmailEngine could not verify
    <code>SO_REUSEPORT</code> support because the API port was unavailable while probing at startup, so only a single
    API worker was started. This is usually a transient conflict and may clear on the next restart.
    {{else}}
    <code>EENGINE_WORKERS_API</code> is set to {{apiWorkerWarning.requested}}, but this platform does not support
    <code>SO_REUSEPORT</code> (requires Linux with Node.js 23.1 or newer), so only a single API worker was started.
    {{/equals}}
</div>
{{/if}}

<div class="card bg-base-100 shadow-md mt-6 mb-6">

    <div class="overflow-x-auto">
        <table class="table">

            <thead>
                <tr>
                    <th>Thread Type</th>
                    <th class="text-end">ID</th>
                    <th>Uptime</th>
                    <th class="text-end">Memory</th>
                    <th class="text-end">Accounts</th>
                    <th class="text-end">Sent</th>
                    <th class="text-end">Received</th>
                    <th>&nbsp;</th>
                </tr>
            </thead>

            <tbody>
                {{#each threads}}
                <tr{{#if isUnresponsive}} class="bg-error/10"{{/if}}>
                    <td>{{description}}

                        {{#if config}}
                        {{#> ui/tooltip-rich icon="icon-[tabler--info-circle]"}}
                        <strong>Configuration</strong><br>
                        {{config.key}}={{config.value}}
                        {{/ui/tooltip-rich}}
                        {{/if}}

                        {{#if isUnresponsive}}
                        {{> ui/badge label="Unresponsive" variant="error"}}
                        {{#if errorMessage}}
                        {{#> ui/tooltip-rich icon="icon-[tabler--alert-triangle] text-error"}}
                        <strong>Error</strong><br>
                        {{errorMessage}}
                        {{/ui/tooltip-rich}}
                        {{/if}}
                        {{else if healthBadge}}
                        {{> ui/badge label=healthBadge variant=healthBadgeType}}
                        {{/if}}

                    </td>
                    <td class="text-end">{{formatInteger threadId userLocale}}</td>
                    <td>
                        <span class="relative-time" data-time="{{timeStr}}"></span>
                    </td>
                    <td class="text-end">
                        {{#if isUnresponsive}}
                        <span class="text-error font-bold">{{heapUsed}}</span>
                        {{else}}
                        {{heapUsed}}
                        {{/if}}
                    </td>
                    <td class="text-end">
                        {{#if accounts}}
                        <a href="/admin/internals/thread/{{threadId}}"
                            class="link link-animated">{{formatInteger accounts userLocale}}</a>
                        {{else}}
                        {{formatInteger accounts userLocale}}
                        {{/if}}
                    </td>
                    <td class="text-end">{{formatInteger called userLocale}}</td>
                    <td class="text-end">{{formatInteger messages userLocale}}</td>
                    <td class="text-end">

                        {{#> ui/tooltip text="Download memory snapshot"}}
                        <button type="button" class="btn btn-info btn-soft btn-circle btn-sm snapshot-thread-btn"
                            data-thread="{{threadId}}" aria-label="Download memory snapshot"><span
                                class="icon-[tabler--cloud-download] size-4"></span></button>
                        {{/ui/tooltip}}

                        {{#if isMain}}
                        {{!-- invisible placeholder keeps the action column aligned --}}
                        <button type="button" class="btn btn-error btn-soft btn-circle btn-sm kill-thread-btn invisible"
                            data-thread="{{threadId}}" aria-label="Kill this thread"><span
                                class="icon-[tabler--trash] size-4"></span></button>
                        {{else}}
                        {{#> ui/tooltip text="Restart thread"}}
                        <button type="button" class="btn btn-error btn-soft btn-circle btn-sm kill-thread-btn"
                            data-thread="{{threadId}}" aria-label="Restart thread"><span
                                class="icon-[tabler--trash] size-4"></span></button>
                        {{/ui/tooltip}}
                        {{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>

        </table>
    </div>

</div>

{{#> ui/modal id="killThread" title="Restart Thread" titleId="killThreadLabel"}}
<div class="modal-body">
    Restart this thread? Any ongoing operations will be interrupted.
</div>
<div class="modal-footer">
    <form method="post" action="/admin/internals/kill" class="flex gap-2">
        <input type="hidden" name="crumb" value="{{crumb}}">
        <input type="hidden" id="kill-thread" name="thread" value="">
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#killThread"}}
        {{> ui/btn label="Restart Thread" variant="error" type="submit"}}
    </form>
</div>
{{/ui/modal}}

{{#> ui/modal id="snapshotThread" title="Memory Snapshot" titleId="snapshotThreadLabel"}}
<div class="modal-body">
    Generate a memory snapshot for debugging? This may briefly affect thread performance.
</div>
<div class="modal-footer">
    <form method="post" id="snapshot-form" action="/admin/internals/snapshot" target="_blank" rel="noopener noreferrer"
        class="flex gap-2">
        <input type="hidden" name="crumb" value="{{crumb}}">
        <input type="hidden" id="snapshot-thread" name="thread" value="">
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#snapshotThread"}}
        {{> ui/btn label="Download Snapshot" variant="info" type="submit"}}
    </form>
</div>
{{/ui/modal}}

<script>
    document.addEventListener('DOMContentLoaded', () => {
        for (let elm of document.querySelectorAll('.kill-thread-btn')) {
            elm.addEventListener('click', e => {
                e.preventDefault();
                document.getElementById('kill-thread').value = elm.dataset.thread;
                uiModal.open('#killThread');
            });
        }

        for (let elm of document.querySelectorAll('.snapshot-thread-btn')) {
            elm.addEventListener('click', e => {
                e.preventDefault();
                document.getElementById('snapshot-thread').value = elm.dataset.thread;
                uiModal.open('#snapshotThread');
            });
        }

        document.getElementById('snapshot-form').addEventListener('submit', () => {
            uiModal.close('#snapshotThread');
        });
    });
</script>
