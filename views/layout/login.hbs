<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="EmailEngine Application page; The Ultimate Email API for Developers" />
    <meta name="author" content="Postal Systems OÜ">

    <title>{{#if pageTitleFull}}{{pageTitleFull}}{{else}}{{pageBrandName}}{{#if pageTitle}} &ndash;
        {{pageTitle}}{{/if}}{{/if}}</title>

    <link rel="apple-touch-icon" href="/static/favicon/apple-touch-icon.png" sizes="180x180" />
    <link rel="icon" href="/static/favicon/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/static/favicon/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="manifest" href="/static/favicon/manifest.json" />
    <link rel="icon" href="/favicon.ico" />

    {{> theme_init}}

    <link href="/static/fonts/pt-sans-font.css" rel="stylesheet">

    <link href="/static/css/flyonui.css" rel="stylesheet">

</head>

<body class="from-primary to-secondary min-h-screen bg-gradient-to-br">

    <div class="container mx-auto px-4">

        <div class="flex justify-center">

            <div class="w-full max-w-4xl">

                <div class="card bg-base-100 my-12 overflow-hidden shadow-lg">
                    <div class="grid grid-cols-1 lg:grid-cols-2">
                        <div class="bg-login-page-image hidden lg:block"></div>
                        <div class="alert-margin">
                            {{> alerts}}

                            <div class="p-12">

                                {{{content}}}
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

    <script src="/static/js/jquery-3.6.0.min.js" crossorigin="anonymous"></script>

    <script src="/static/js/flyonui.js"></script>
    <script src="/static/js/bootstrap-compat.js"></script>
    <script src="/static/js/ui.js"></script>


    <script src="/static/js/app.js"></script>

    {{#if passkeysAvailable}}
    <script src="/static/vendor/simplewebauthn/browser.min.js"></script>
    <script src="/static/js/login-passkey.js"></script>
    {{/if}}

</body>

</html>
