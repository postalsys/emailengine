<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="EmailEngine Application page; The Ultimate Email API for Developers" />
    <meta name="author" content="Postal Systems OÜ">

    <title>{{#if pageTitleFull}}{{pageTitleFull}}{{else}}{{pageBrandName}}{{#if pageTitle}} &ndash;
        {{pageTitle}}{{/if}}{{/if}}</title>

    <link rel="apple-touch-icon" href="/static/favicon/apple-touch-icon.png" sizes="180x180" />
    <link rel="icon" href="/static/favicon/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/static/favicon/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="manifest" href="/static/favicon/manifest.json" />
    <link rel="icon" href="/favicon.ico" />

    {{> theme_init}}

    <!-- Font Awesome is still loaded for server-driven dynamic icons; removed at the end of the theme migration -->
    <link href="/static/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">

    <link href="/static/fonts/pt-sans-font.css" rel="stylesheet">

    <link rel="stylesheet" href="/static/css/highlight.min.css">

    <link href="/static/css/flyonui.css" rel="stylesheet">

    {{#if injectHtmlHead}}
    {{{injectHtmlHead}}}
    {{/if}}

</head>

<body class="bg-base-200 min-h-screen" data-sse-changes="true">

    <!-- Sidebar -->
    <aside id="layout-sidebar"
        class="overlay overlay-open:translate-x-0 drawer drawer-start w-sidebar max-w-full inset-y-0 start-0 hidden h-full [--auto-close:lg] lg:z-40 lg:block lg:translate-x-0 lg:shadow-none"
        aria-label="Sidebar" tabindex="-1">
        <div class="drawer-body bg-base-100 border-base-content/20 flex h-full flex-col border-e p-0">

            <button type="button" class="btn btn-text btn-circle btn-sm absolute end-3 top-3 lg:hidden"
                aria-label="Close" data-overlay="#layout-sidebar">
                <span class="icon-[tabler--x] size-4"></span>
            </button>

            <!-- Brand -->
            <div class="border-base-content/20 flex items-center justify-center border-b px-4 py-5">
                <a href="/" class="flex items-center">
                    <img src="/static/logo/EmailEngine_logo_horiz.png" alt="EmailEngine" class="block max-h-8 max-w-full">
                </a>
            </div>

            <div class="grow overflow-y-auto">
                {{>side_menu}}
            </div>

        </div>
    </aside>
    <!-- End of Sidebar -->

    <!-- Content column -->
    <div class="flex min-h-screen flex-col lg:ps-sidebar">

        {{#if iframePage}}

        <div id="content" class="flex h-screen flex-col">
            {{{content}}}
        </div>

        {{else}}

        <!-- Topbar -->
        <header class="bg-base-100 border-base-content/20 sticky top-0 z-30 border-b">
            <nav class="navbar flex items-center gap-2 px-4 py-2">

                <button type="button" class="btn btn-text btn-square btn-sm lg:hidden" aria-haspopup="dialog"
                    aria-expanded="false" aria-controls="layout-sidebar" data-overlay="#layout-sidebar"
                    aria-label="Open menu">
                    <span class="icon-[tabler--menu-2] size-5"></span>
                </button>

                {{#if searchTarget}}
                <!-- Topbar search -->
                <form class="hidden sm:flex items-center gap-2 grow max-w-xl" method="get" action="{{searchTarget}}">

                    {{#if stateOptions}}
                    <div class="dropdown relative inline-flex shrink-0">
                        <button type="button" id="search-state-dropdown" class="dropdown-toggle btn btn-soft btn-sm"
                            aria-haspopup="menu" aria-expanded="false">
                            {{#if selectedState}}{{selectedState.label}}{{else}}All{{/if}}
                            <span class="icon-[tabler--chevron-down] size-4"></span>
                        </button>
                        <ul class="dropdown-menu dropdown-open:opacity-100 hidden min-w-40"
                            role="menu" aria-orientation="vertical" aria-labelledby="search-state-dropdown">
                            {{#each stateOptions}}
                            {{#if divider}}
                            <li><div class="divider my-1"></div></li>
                            {{else}}
                            <li><a class="dropdown-item{{#if selected}} dropdown-active{{/if}}" href="{{url}}">{{label}}</a></li>
                            {{/if}}
                            {{/each}}
                        </ul>
                    </div>
                    <input type="hidden" name="state" value="{{state}}">
                    {{/if}}

                    <div class="input input-sm grow">
                        <span class="icon-[tabler--search] text-base-content/60 my-auto me-2 size-4 shrink-0"></span>
                        <input type="text" class="grow" placeholder="{{searchPlaceholder}}" aria-label="Search"
                            name="query" value="{{query}}">
                    </div>

                    <button class="btn btn-primary btn-sm" type="submit">Search</button>

                </form>
                {{/if}}

                <div class="ms-auto flex items-center gap-1">

                    {{#if licenseInfo.suspended}}
                    <div class="tooltip [--placement:left] inline-flex me-2">
                        <div class="tooltip-toggle text-error flex cursor-default items-center gap-1">
                            <span class="icon-[tabler--heartbeat] size-5"></span>
                            <span class="text-sm">Engine is <strong>stopped</strong></span>
                        </div>
                        <span class="tooltip-content tooltip-shown:opacity-100 tooltip-shown:visible" role="tooltip">
                            <span class="tooltip-body">EmailEngine is currently not running and does not process any
                                email accounts</span>
                        </span>
                    </div>
                    {{/if}}

                    {{#if systemAlerts}}
                    <!-- System alerts -->
                    <div class="dropdown relative inline-flex">
                        <button type="button" id="alertsDropdown" class="dropdown-toggle btn btn-text btn-circle btn-sm relative"
                            aria-haspopup="menu" aria-expanded="false" aria-label="System notifications">
                            <span class="icon-[tabler--bell] size-5"></span>
                            <span class="badge badge-error badge-sm absolute -top-1 -end-1 px-1.5">{{systemAlerts.length}}</span>
                        </button>
                        <ul class="dropdown-menu dropdown-open:opacity-100 hidden w-80 max-w-[90vw]" role="menu"
                            aria-orientation="vertical" aria-labelledby="alertsDropdown">
                            <li class="dropdown-header">System notifications</li>
                            {{#each systemAlerts}}
                            <li>
                                <a class="dropdown-item flex items-start gap-3" href="{{url}}">
                                    <span class="bg-{{eeColor level}} text-white flex size-8 shrink-0 items-center justify-center rounded-full">
                                        <i class="{{#if brand}}fab{{else}}fas{{/if}} fa-{{icon}}"></i>
                                    </span>
                                    <span class="text-sm whitespace-normal">
                                        {{#if verbatim}}
                                        {{{message}}}
                                        {{else}}
                                        {{message}}
                                        {{/if}}
                                    </span>
                                </a>
                            </li>
                            {{/each}}
                        </ul>
                    </div>
                    {{/if}}

                    <!-- Theme toggle -->
                    <button type="button" class="theme-toggle-btn btn btn-text btn-circle btn-sm" aria-label="Toggle theme">
                        <span class="theme-toggle-dark icon-[tabler--moon] size-5"></span>
                        <span class="theme-toggle-light icon-[tabler--sun] size-5 hidden"></span>
                    </button>

                    <!-- User menu -->
                    <div class="dropdown relative inline-flex">
                        <button type="button" id="userDropdown" class="dropdown-toggle btn btn-text btn-sm flex items-center gap-2"
                            aria-haspopup="menu" aria-expanded="false" aria-label="User menu">
                            {{#if authData.name}}
                            <span class="hidden lg:inline text-base-content/70 text-sm font-normal">{{authData.name}}</span>
                            {{/if}}
                            <img class="size-7 rounded-full" src="/static/undraw_profile.svg" alt="">
                        </button>
                        <ul class="dropdown-menu dropdown-open:opacity-100 hidden min-w-52 end-0" role="menu"
                            aria-orientation="vertical" aria-labelledby="userDropdown">
                            {{#if authData.isAdmin}}
                            <li>
                                <a class="dropdown-item{{#if menuAccountSecurity}} dropdown-active{{/if}}" href="/admin/account/security">
                                    <span class="icon-[tabler--shield-lock] size-4"></span>
                                    Account security
                                </a>
                            </li>
                            {{#if authData.enabled}}
                            <li><div class="divider my-1"></div></li>
                            {{/if}}
                            {{/if}}
                            {{#if authData.enabled}}
                            <li>
                                <a class="dropdown-item" href="/admin/logout">
                                    <span class="icon-[tabler--logout] size-4"></span>
                                    Sign out
                                </a>
                            </li>
                            {{/if}}
                        </ul>
                    </div>

                </div>

            </nav>
        </header>
        <!-- End of Topbar -->

        <!-- Page content -->
        <div id="content" class="grow">
            <div class="w-full px-6 py-6">

                <div id="toastContainer" class="fixed top-16 right-6 z-[10000] w-80 max-w-[90vw]"></div>

                {{> alerts}}

                {{#unless licenseInfo.active}}
                {{#unless hideLicenseWarning}}
                {{#> ui/stat-card id="license-warning" variant="error" title="License key missing" icon="icon-[tabler--key]" class="mb-6"}}

                {{#if licenseInfo.suspended}}
                <div class="alert alert-error mb-4" role="alert">
                    EmailEngine is currently not syncing any accounts. Please restart the application or
                    register a valid license key to enable syncing.
                </div>
                {{/if}}

                <p class="mb-3">To use all the features of EmailEngine, you need to provide a valid license key.</p>
                <div class="flex flex-wrap gap-2">

                    {{#if trialPossible}}
                    {{> ui/btn id="start-trial-btn" variant="success" icon="icon-[tabler--gift]" label="Start a 14-day trial"}}
                    {{/if}}

                    {{> ui/btn href="/admin/config/license" variant="primary" icon="icon-[tabler--arrow-right]" label="Register a license"}}

                </div>

                {{/ui/stat-card}}
                {{/unless}}
                {{/unless}}

                {{#unless authData.enabled}}
                {{#unless disableAuthWarning}}
                {{#> ui/stat-card variant="error" title="Authentication not enabled" icon="icon-[tabler--shield-lock]" class="mb-6"}}

                <p class="mb-3">To enable authentication for EmailEngine, please set a password for the admin
                    user account.</p>
                <div>
                    {{> ui/btn href="/admin/account/password" variant="primary" icon="icon-[tabler--arrow-right]" label="Enable authentication"}}
                </div>

                {{/ui/stat-card}}
                {{/unless}}
                {{/unless}}

                {{{content}}}

            </div>
        </div>
        <!-- End of page content -->

        <!-- Footer -->
        <footer class="bg-base-100 border-base-content/20 border-t py-4 mt-auto">
            <div class="text-base-content/70 text-center text-sm">
                <a href="{{packageData.homepage}}" target="_blank" rel="noopener noreferrer" class="link link-animated">EmailEngine</a>
                v{{packageData.version}}.
                <span>&copy; 2020-{{currentYear}}</span>
                <a class="link link-animated" href="https://postalsys.com/contact" target="_blank" rel="noopener noreferrer">Postal Systems O&Uuml;</a>.
                <a class="link link-animated" href="/admin/legal">License and terms</a>.
            </div>
        </footer>
        <!-- End of Footer -->
        {{/if}}

    </div>
    <!-- End of content column -->

    <script src="/static/js/jquery-3.6.0.min.js" crossorigin="anonymous"></script>

    <script src="/static/js/flyonui.js"></script>
    <script src="/static/js/bootstrap-compat.js"></script>
    <script src="/static/js/ui.js"></script>

    <script src="/static/vendor/handlebars/handlebars.min-v4.7.9.js"></script>
    <script src="/static/js/clipboard.min.js"></script>

    <script src="/static/js/bootstrap-autocomplete.min.js"></script>

    <script src="/static/js/highlight.min.js"></script>

    <script src="/static/js/app.js"></script>


    {{#if trialPossible}}
    {{#> ui/modal id="activateTrial" title="Start a 14-day trial" hideClose=true}}
    <div class="modal-body">
        Provisioning a trial license, please wait <span class="loading loading-spinner loading-sm align-middle"></span>
    </div>
    {{/ui/modal}}

    <input type="hidden" name="crumb" id="crumb" value="{{crumb}}" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            let trialBtn = document.getElementById('start-trial-btn');
            if (!trialBtn) {
                return;
            }

            let handleActivation = async () => {

                const res = await fetch('/admin/config/license/trial', {
                    method: 'post',
                    headers: { 'content-type': 'application/json' },
                    body: JSON.stringify({
                        crumb: document.getElementById('crumb').value
                    })
                });

                if (!res.ok) {
                    throw new Error('Request failed with status ' + res.status);
                }

                let data = await res.json();

                if (!data || !data.success) {
                    console.log(data)
                    throw new Error(data.error || 'Request failed');
                }

                return 1
            }

            trialBtn.addEventListener('click', e => {
                e.preventDefault();

                uiModal.open('#activateTrial');

                handleActivation().then(() => {
                    uiModal.close('#activateTrial');
                    document.getElementById('license-warning').style.display = 'none';
                    window.location.reload();
                }).catch(err => {
                    uiModal.close('#activateTrial');
                    showToast(err.message, 'alert-triangle');
                });
            });
        });
    </script>

    {{/if}}

    {{#if updateBrowserInfo}}
    <input type="hidden" id="browser-info-crumb" value="{{crumb}}" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            let sendBrowserInfo = async () => {
                let timezone = false;
                try {
                    timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
                } catch (err) {
                    console.error(err);
                }

                try {
                    const res = await fetch('/admin/config/browser', {
                        method: 'post',
                        headers: { 'content-type': 'application/json' },
                        body: JSON.stringify({
                            crumb: document.getElementById('browser-info-crumb').value,
                            serviceUrl: window.location.origin || false,
                            timezone: timezone || false,
                            language: navigator.language || false
                        })
                    });

                    if (!res.ok) {
                        console.error('Failed to post browser info');
                    } else {
                        let serviceUrlformEntry = document.querySelector('#settingsServiceUrl')
                        if (serviceUrlformEntry && !serviceUrlformEntry.value) {
                            serviceUrlformEntry.value = window.location.origin || ''
                        }
                    }
                } catch (err) {
                    console.error(err);
                }

            }

            sendBrowserInfo().catch(err => console.error(err))
        });
    </script>
    {{/if}}
</body>

</html>
