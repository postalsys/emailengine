<!DOCTYPE html>
<html lang="en" class="h-full">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="EmailEngine Application page; The Ultimate Email API for Developers" />
    <title>EmailEngine</title>

    {{> head_assets}}

    <link href="/static/css/flyonui.css" rel="stylesheet">

</head>

<body class="bg-base-100 flex min-h-full flex-col">
    <main role="main" class="shrink-0 grow">

        <div class="container mx-auto px-4 mt-6">
            <div class="flex">
                <img src="/static/logo/EmailEngine_logo_horiz.png" class="block max-h-20 max-w-full" alt="EmailEngine">
            </div>

            <div class="mt-6 max-w-3xl">
                {{> alerts}}
            </div>

            {{{content}}}


        </div>
    </main>

    <footer class="mt-auto py-4">
        <div class="container mx-auto px-4">
            <div>
                EmailEngine
                <span class="text-base-content/60">&copy; 2020-{{currentYear}}</span>
                Postal Systems OÜ.
                {{!-- version marker only: the license key must not appear in
                      page source - this layout serves unauthenticated pages --}}
                <!-- v{{packageData.version}} -->
            </div>
        </div>
    </footer>

    <script src="/static/js/flyonui.js"></script>
    <script src="/static/js/ui.js"></script>
</body>

</html>
