{{> gateways_header}}

{{> ui/breadcrumb parentHref="/admin/gateways" parentLabel="Gateways" current="New" class="mt-6 mb-6"}}

<form method="post" action="/admin/gateways/new">
    <input type="hidden" name="crumb" id="crumb" value="{{crumb}}">

    <div class="card bg-base-100 shadow-md mb-6">

        <div class="card-header flex items-center justify-between">
            <h6 class="card-title text-primary">New Gateway</h6>
            <div class="dropdown relative inline-flex">
                <button type="button" class="dropdown-toggle btn btn-text btn-circle btn-sm" id="gateway-actions-menu"
                    aria-haspopup="menu" aria-expanded="false" aria-label="Actions">
                    <span class="icon-[tabler--dots-vertical] size-4"></span>
                </button>
                <ul class="dropdown-menu dropdown-open:opacity-100 hidden min-w-44 end-0" role="menu"
                    aria-orientation="vertical" aria-labelledby="gateway-actions-menu">
                    <li class="dropdown-header">Actions:</li>
                    <li><a class="dropdown-item test-connection" href="#" id="test-verify-btn">
                            <span class="icon-[tabler--send] size-4"></span> <span>Test Connection</span></a></li>
                </ul>
            </div>
        </div>

        <div class="card-body space-y-4">

            {{> ui/form-field id="gateway" name="gateway" label="Gateway ID" value=values.gateway error=errors.gateway placeholder="sendgrid-main" lpignore=true hint="Unique identifier for this gateway. Leave empty to auto-generate."}}

            {{>gateway_form}}

        </div>
    </div>

    <div class="mb-6">
        {{> ui/btn label="Create Gateway" type="submit" icon="icon-[tabler--send]"}}
    </div>
</form>

{{>gateway_js}}
