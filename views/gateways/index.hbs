{{#> ui/page-header title="Gateways" icon="icon-[tabler--send]" class="mb-6"}}
{{> ui/btn href="/admin/gateways/new" label="Add Gateway" icon="icon-[tabler--plus]"}}
{{/ui/page-header}}

<p class="mb-6">
    Route outgoing emails through SMTP gateways instead of individual user email servers.
</p>

{{#> ui/stat-card variant="info" icon="icon-[tabler--info-circle]" class="mb-6" title=""}}
<p class="mb-2">SMTP gateways are independent mail servers for sending emails. Use your own infrastructure or
    third-party services like SendGrid, Amazon SES, Mailgun, and similar providers.</p>
<p class="mb-1"><strong>How to use:</strong></p>
<ul class="list-disc ps-6 space-y-1 mb-0">
    <li>API: Add <code>gateway: "gateway-id"</code> to your <a
            href="https://api.emailengine.app/#operation/postV1AccountAccountSubmit" target="_blank"
            rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">submit request</a></li>
    <li>SMTP: Include header <code>X-EE-Gateway: gateway-id</code></li>
</ul>
{{/ui/stat-card}}

{{#if gateways}}

<div class="card bg-base-100 shadow-md mb-6">

    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr>
                    <th>Gateway ID</th>
                    <th>Name</th>
                    <th>Emails Sent</th>
                    <th>Last Activity</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                {{#each gateways}}
                <tr class="hover:bg-base-200/60">
                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/gateways/gateway/" gateway) label="Open gateway"}}
                        {{gateway}}
                    </td>
                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/gateways/gateway/" gateway)}}<strong>{{name}}</strong>
                    </td>
                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/gateways/gateway/" gateway)}}{{deliveries}}
                    </td>

                    <td class="relative">
                        {{> ui/row-link href=(concat "/admin/gateways/gateway/" gateway)}}
                        {{#if timeStr}}
                        <span class="relative-time" data-time="{{timeStr}}"></span>
                        {{else}}
                        <small><em>Never used</em></small>
                        {{/if}}
                    </td>

                    <td class="relative w-32">
                        {{> ui/row-link href=(concat "/admin/gateways/gateway/" gateway)}}
                        {{!-- live state badge with an error tooltip; wrapping link
                              lifts the badge above the row overlay --}}
                        <a href="/admin/gateways/gateway/{{gateway}}" class="relative z-[1] inline-flex">
                            {{> ui/state-badge label=label account=gateway pointer=true}}
                        </a>
                    </td>

                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    {{> ui/pagination showPaging=showPaging prevPage=prevPage nextPage=nextPage pageLinks=pageLinks}}
</div>

{{else}}
{{#> ui/card}}
        {{#if firstPage}}
        No gateways have been configured yet. <a href="/admin/gateways/new" class="link link-animated">Add your first
            gateway</a>.
        {{else}}
        No gateways found.
        {{/if}}
    
{{/ui/card}}
{{/if}}
