{{#> ui/page-header title="Email Gateways" icon="icon-[tabler--send]" class="mb-6"}}
{{> ui/btn href="/admin/gateways/new" label="Add Gateway" icon="icon-[tabler--plus]"}}
{{/ui/page-header}}

<p class="mb-6">
    Route outgoing emails through SMTP gateways instead of individual user email servers.
</p>

{{#> ui/stat-card variant="info" icon="icon-[tabler--info-circle]" class="mb-6" title=""}}
<p class="mb-2">SMTP gateways are independent mail servers for sending emails. Use your own infrastructure or
    third-party services like SendGrid, Amazon SES, Mailgun, and similar providers.</p>
<p><strong>How to use:</strong><br>
    * API: Add <code>gateway: "gateway-id"</code> to your <a
        href="https://api.emailengine.app/#operation/postV1AccountAccountSubmit" target="_blank"
        rel="noopener noreferrer" referrerpolicy="no-referrer" class="link link-animated">submit request</a><br>
    * SMTP: Include header <code>X-EE-Gateway: gateway-id</code>
</p>
{{/ui/stat-card}}

{{#if gateways}}

<div class="card bg-base-100 shadow-md mb-6">

    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr>
                    <th>Gateway ID</th>
                    <th>Name</th>
                    <th>Emails Sent</th>
                    <th>Last Activity</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                {{#each gateways}}
                <tr class="hover:bg-base-200/60">
                    <td class="relative">
                        <a href="/admin/gateways/gateway/{{gateway}}" class="absolute inset-0"
                            aria-label="Open gateway"></a>
                        {{gateway}}
                    </td>
                    <td class="relative">
                        <a href="/admin/gateways/gateway/{{gateway}}" class="absolute inset-0" tabindex="-1"
                            aria-hidden="true"></a><strong>{{name}}</strong>
                    </td>
                    <td class="relative">
                        <a href="/admin/gateways/gateway/{{gateway}}" class="absolute inset-0" tabindex="-1"
                            aria-hidden="true"></a>{{deliveries}}
                    </td>

                    <td class="relative">
                        <a href="/admin/gateways/gateway/{{gateway}}" class="absolute inset-0" tabindex="-1"
                            aria-hidden="true"></a>
                        {{#if timeStr}}
                        <span class="relative-time" data-time="{{timeStr}}"></span>
                        {{else}}
                        <small><em>Never used</em></small>
                        {{/if}}
                    </td>

                    <td class="relative w-32">
                        <a href="/admin/gateways/gateway/{{gateway}}" class="absolute inset-0" tabindex="-1"
                            aria-hidden="true"></a>
                        {{!-- live state badge with an error tooltip; wrapping link
                              lifts the badge above the row overlay --}}
                        <a href="/admin/gateways/gateway/{{gateway}}" class="relative z-[1] inline-flex">
                            {{> ui/state-badge label=label account=gateway pill=true pointer=true}}
                        </a>
                    </td>

                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    {{#if showPaging}}
    <div class="card-footer border-base-content/10 border-t px-6 py-[1rem]">
        {{> ui/pagination prevPage=prevPage nextPage=nextPage pageLinks=pageLinks}}
    </div>
    {{/if}}
</div>

{{else}}
<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-body">
        {{#if firstPage}}
        No gateways have been configured yet. <a href="/admin/gateways/new" class="link link-animated">Add your first
            gateway</a>.
        {{else}}
        No gateways found.
        {{/if}}
    </div>
</div>
{{/if}}
