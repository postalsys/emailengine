{{> gateways_header}}

{{> ui/breadcrumb parentHref="/admin/gateways" parentLabel="Gateways" current=gateway.gateway class="mt-6 mb-6"}}

<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-body">

        <div class="mb-4 flex flex-wrap gap-2" role="toolbar" aria-label="Gateway actions">

            {{#> ui/tooltip text="Modify gateway settings"}}
            <a class="btn btn-soft btn-sm" href="/admin/gateways/edit/{{gateway.gateway}}">
                <span class="icon-[tabler--edit] size-4"></span> Edit gateway
            </a>
            {{/ui/tooltip}}

            {{#> ui/tooltip text="Remove this gateway"}}
            <button type="button" class="btn btn-soft btn-sm" data-overlay="#deleteModal" id="delete-btn">
                <span class="icon-[tabler--trash] size-4"></span> Delete gateway
            </button>
            {{/ui/tooltip}}

        </div>

        <h6 class="card-title mb-6">{{gateway.name}}</h6>

        {{#if gateway.lastError}}
        <dl class="ee-dl">
            <dt>Connection Error</dt>
            <dd>{{gateway.lastError.description}}</dd>

            {{#if gateway.lastError.response}}
            <dt>Server Response</dt>
            <dd><code>{{gateway.lastError.response}}</code></dd>
            {{/if}}
        </dl>

        <hr>
        {{/if}}

        <dl class="ee-dl">
            {{#if gateway.gateway}}
            <dt>Gateway ID</dt>
            <dd>
                <strong>{{gateway.gateway}}</strong>

                {{!-- live state badge with an error tooltip --}}
                {{> ui/state-badge label=label account=gateway.gateway}}
            </dd>
            {{/if}}

            {{#if gateway.deliveries}}
            <dt>Emails Sent</dt>
            <dd>{{gateway.deliveries}}</dd>
            {{/if}}

            {{#if gateway.user}}
            <dt>Username</dt>
            <dd>{{gateway.user}}</dd>
            {{/if}}

            {{#if gateway.pass}}
            <dt>Password</dt>
            <dd>********</dd>
            {{/if}}

            {{#if gateway.host}}
            <dt>Server</dt>
            <dd>{{gateway.host}}</dd>
            {{/if}}

            {{#if gateway.port}}
            <dt>Port</dt>
            <dd>{{gateway.port}}</dd>
            {{/if}}

            <dt>Encryption</dt>
            <dd>{{#if gateway.secure}}TLS/SSL{{else}}STARTTLS (when available){{/if}}
            </dd>
        </dl>

    </div>
</div>

{{#> ui/modal id="deleteModal" title="Delete Gateway"}}
<div class="modal-body">
    <p>Delete gateway "{{gateway.name}}"? This action cannot be undone.</p>
</div>
<div class="modal-footer">
    <form method="post" action="/admin/gateways/delete/{{gateway.gateway}}" class="flex gap-2">
        <input type="hidden" name="crumb" value="{{crumb}}" />
        {{> ui/btn label="Cancel" variant="neutral" style="soft" overlay="#deleteModal"}}
        {{> ui/btn label="Delete Gateway" variant="error" type="submit"}}
    </form>
</div>
{{/ui/modal}}
